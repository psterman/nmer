.sidebar-section { padding: 4px 8px 2px; }
.sidebar-section-title {
  font-size: var(--vk-panel-font-sm); letter-spacing: 1px; color: var(--text-xs);
  text-transform: uppercase; margin-bottom: 2px;
}
.sidebar-item {
  display: flex; align-items: center; gap: 4px;
  padding: 4px 8px 4px 12px;
  font-size: var(--vk-panel-font); font-family: var(--font-ui);
  color: var(--text-dim);
  cursor: pointer;
  border-radius: 3px;
  transition: background .1s, color .1s;
  border-left: 2px solid transparent;
}
.sidebar-item:hover { background: #0d1f10; color: var(--matrix-green); }
.sidebar-item.active {
  background: #071409;
  color: var(--matrix-green);
  border-left-color: var(--matrix-green);
  text-shadow: 0 0 6px #00ff4155;
}
.sidebar-item.all { padding-left: 10px; font-weight: 600; }
.mol-ico {
  width: 16px;
  text-align: center;
  margin-right: 2px;
  font-size: 12px;
}
.mol-name {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.mol-count {
  font-size: 10px;
  color: var(--text-xs);
}
.sidebar-item.active .mol-count {
  color: var(--matrix-green);
}

