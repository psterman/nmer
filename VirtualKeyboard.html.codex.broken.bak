function closeConflictModal() {
  document.getElementById('conflict-overlay').classList.remove('visible');
}

// close on overlay click
document.getElementById('conflict-overlay').addEventListener('click', (e) => {
  if (e.target === e.currentTarget) {
    closeConflictModal();
    postToAhk({ type: 'resolveConflict', confirm: false });
    updateHudSnapshot();
  }
