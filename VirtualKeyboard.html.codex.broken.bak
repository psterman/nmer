  display: flex;
  flex-direction: column;
  width: calc(100% / var(--vk-ui-scale));
  min-height: calc(100% / var(--vk-ui-scale));
  height: calc(100% / var(--vk-ui-scale));
  transform: scale(var(--vk-ui-scale));
  transform-origin: top left;
}
