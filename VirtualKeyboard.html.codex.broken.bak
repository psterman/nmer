#hud-icon {
  color: var(--orange);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 2px;
  text-shadow: var(--glow);
  flex-shrink: 0;
}
#hud-status {
  flex: 1;
  font-size: 11px;
  color: var(--text-dim);
  font-weight: 300;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
#hud-status.success {
  color: #7ef0ae;
  text-shadow: 0 0 8px rgba(72, 196, 125, .5);
}
#hud-status.error {
  color: #ff9b9b;
  text-shadow: 0 0 8px rgba(255, 99, 99, .45);
}
#hud-hint {
  flex-basis: 100%;
  order: 10;
  margin: 0;
  padding: 6px 0 2px;
  border-top: 1px solid var(--border);
  font-size: 10px;
  font-weight: 400;
  color: var(--text-dim);
  line-height: 1.5;
  display: none;
}
#hud-hint code {
  font-family: Consolas, ui-monospace, monospace;
  font-size: 10px;
  color: var(--orange);
  background: #1a1a1a;
  padding: 1px 5px;
  border-radius: 2px;
}
#hud-hint .hud-hint-main { color: var(--text); font-weight: 600; }
#hud-hint .hud-hint-sub { color: var(--text-dim); }
#hud-hint .hud-hint-warn { color: #e67e22; }
#vk-host-mode-hint {
  flex-basis: 100%;
  order: 8;
  margin: 0;
  padding: 4px 0 0;
  font-size: 10px;
  font-weight: 400;
  color: #9a8a74;
  line-height: 1.45;
  display: none;
}
#vk-host-mode-hint.visible { display: block; }
#admin-warning {
  display: none;
  flex-basis: 100%;
  order: 20;
  margin: 0;
  padding: 7px 10px;
  border: 1px solid rgba(255, 204, 0, .45);
  border-radius: 8px;
  background: linear-gradient(180deg, rgba(255, 204, 0, .12), rgba(255, 204, 0, .04));
  color: #ffe089;
  font-family: var(--font-ui);
  font-size: 11px;
  line-height: 1.45;
}
#admin-warning.visible { display: block; }
#hud-dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: var(--border2);
  flex-shrink: 0;
  transition: background .3s, box-shadow .3s;
}
#hud-dot.on {
  background: var(--orange);
  box-shadow: var(--glow);
  animation: pulse 2s ease-in-out infinite;
}
@keyframes pulse { 0%,100%{opacity:1}50%{opacity:.4} }
#hud-save {
  font-family: var(--font);
  font-size: 10px;
  font-weight: 600;
  color: var(--text-dim);
  background: transparent;
  border: 1px solid var(--border2);
  border-radius: 3px;
  padding: 2px 10px;
  cursor: pointer;
  letter-spacing: 1px;
  transition: color .15s, border-color .15s, box-shadow .15s;
}
#hud-save:hover { color: var(--orange); border-color: var(--orange); box-shadow: var(--glow); }

