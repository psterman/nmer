  testBtn.title       = '闂傚倸鍊搁崐鎼佸磹閹间礁纾瑰瀣捣閻棗霉閿濆浜ら柤鏉挎健濮婃椽顢楅埀顒傜矓閻㈢纾婚柨鐔哄У閻撴瑩鏌熼婊冾暭妞ゃ儱顦伴〃銉╂倷椤忓嫮浼堥梺鍝勮嫰缁夌懓鐣烽锕€绀嬫い鎰枎娴滃墽鎲搁悧鍫濈瑨缂佺嫏鍥ㄧ厵闂傚倸顕崝宥夋煃闁垮绗掗棁澶愭煥濠靛棙鍣洪柛鐔哄仱閺屾盯鎮㈤崫鍕埛缂備浇椴哥敮鐐哄焵椤掑﹦绉甸柛瀣闇夋い鏃堟暜閸嬫挾鎲撮崟顒傤槶闂佺娅曢幑鍥春閻愬搫绠ｉ柣姗嗗亜娴滈箖鏌ㄥ┑鍡欏嚬缂併劏濮ら妵?;
  testBtn.textContent = '闂?;
  testBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    postToAhk({ type: 'executeCommand', commandId: cmdId });
  });

  actions.append(editBtn, clearBtn, resetBtn, testBtn);
  row.append(nameEl, keyEl, actions);
  return row;
}
