.k-bks  { flex: 2.25 1 0 !important; min-width: 34px; }
.k-tab  { flex: 1.55 1 0 !important; min-width: 38px; }
.pt-tabs { display: flex; gap: 6px; margin: 4px 0 8px; flex-wrap: wrap; }
.pt-tab { padding: 4px 10px; border: 1px solid #333; border-radius: 6px; color: #bbb; background: #171717; cursor: pointer; font-size: 12px; }
.pt-tab.active { color: #ff8c2a; border-color: #ff8c2a; }
.k-caps { flex: 1.65 1 0 !important; min-width: 42px; }
.k-enter{ flex: 2.15 1 0 !important; min-width: 48px; }
.k-lsh  { flex: 2.05 1 0 !important; min-width: 52px; }
.k-rsh  { flex: 2.05 1 0 !important; min-width: 52px; }
.k-ctrl { flex: 1.25 1 0 !important; min-width: 36px; }
.k-alt  { flex: 1.15 1 0 !important; min-width: 34px; }
.k-spc  { flex: 6.25 1 0 !important; min-width: 120px; }
.k-win  { flex: 1.05 1 0 !important; min-width: 32px; }
.k-fn   { flex: 1 1 0 !important; min-width: 22px; font-size: 7px; }
.k-f    { flex: 1 1 0 !important; font-size: 7px; }
/* caps-lock dot */
.k-caps::after {
  content:''; position:absolute; top:2px; right:2px;
  width:3px; height:3px; border-radius:50%;
  background: var(--border);
}
.k-caps.caps-on::after { background: var(--orange); box-shadow: var(--glow); }

