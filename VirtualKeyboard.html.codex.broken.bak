#layout-toggle {
  font-family: var(--font);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 1.1px;
  color: var(--text-dim);
  background: var(--surface3);
  border: 1px solid var(--border2);
  border-radius: 999px;
  padding: 4px 10px;
  cursor: pointer;
  transition: color .15s, border-color .15s, box-shadow .15s;
  flex-shrink: 0;
}
#layout-toggle:hover { color: var(--matrix-green); border-color: var(--matrix-green); box-shadow: var(--glow-green); }
#layout-toggle.native {
  color: var(--matrix-green);
  border-color: var(--matrix-green);
  box-shadow: var(--glow-green);
}
#layout-help {
  font-family: var(--font-ui);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: .5px;
  color: #d8b07a;
  background: rgba(36, 24, 12, .65);
  border: 1px solid rgba(230,126,34,.35);
  border-radius: 999px;
  padding: 4px 10px;
  cursor: pointer;
  transition: color .15s, border-color .15s, box-shadow .15s, background .15s;
  flex-shrink: 0;
}
#layout-help:hover {
  color: #ffd4a6;
  border-color: rgba(230,126,34,.8);
  box-shadow: 0 0 0 1px rgba(230,126,34,.25) inset, 0 0 12px rgba(230,126,34,.22);
  background: rgba(50, 31, 16, .78);
}

