}

async function handleKeyboardDropToSlot(toIndex) {
  const incoming = normalizeDashboardItem(state.draggedDashboardItem);
  if (!incoming) return false;
  const existing = getDashboardItemAt(toIndex);
  if (existing && existing.commandId !== incoming.commandId) {
    const confirm = await confirmDashboardOverwrite(existing, incoming);
    if (!confirm) return false;
  }
  applyDashboardItemToSlot(toIndex, incoming, -1);
  return true;
}

function ensureDashboardSlots() {
  const grid = document.getElementById('dashboard-grid');
  if (!grid) return;
  const cfg = ensureDashboardStateSize();
  const need = cfg.length;
  if (grid.children.length !== need) {
    grid.innerHTML = '';
    for (let i = 0; i < need; i++) {
      const slot = document.createElement('div');
      slot.className = 'dashboard-slot';
      grid.appendChild(slot);
    }
  }
  Array.from(grid.children).forEach((slot, index) => {
    renderDashboardSlot(slot, cfg[index], index);
  });
}

function syncDashboardDropCue(active) {
  const container = document.getElementById('dashboard-container');
  if (!container) return;
  container.classList.toggle('drop-active', !!active && state.dashboardDragActive);
}

function buildDashboardBridgePayload(type, extra) {
  return Object.assign({
    type,
    layout: dashboardLayout,
    dashboardConfig: serializeDashboardConfig(),
  }, extra || {});
}

function postDashboardAdd(item, toIndex) {
  if (!item?.commandId || toIndex < 0) return;
  postToAhk(buildDashboardBridgePayload('dashboardAdd', {
    commandId: item.commandId,
    toIndex,
    sourceAhkKey: item.sourceAhkKey || '',
    sourceDisplayKey: item.sourceDisplayKey || '',
  }));
}

function postDashboardMove(item, fromIndex, toIndex) {
  if (!item?.commandId || fromIndex < 0 || toIndex < 0 || fromIndex === toIndex) return;
  postToAhk(buildDashboardBridgePayload('dashboardMove', {
    commandId: item.commandId,
    fromIndex,
    toIndex,
    sourceAhkKey: item.sourceAhkKey || '',
    sourceDisplayKey: item.sourceDisplayKey || '',
  }));
}

function postDashboardRemove(item, fromIndex) {
  if (!item?.commandId || fromIndex < 0) return;
  postToAhk(buildDashboardBridgePayload('dashboardRemove', {
    commandId: item.commandId,
    fromIndex,
  }));
}

function flashInvalidKeyDrag(keyEl) {
  if (!keyEl) return;
  keyEl.classList.remove('drag-invalid');
  void keyEl.offsetWidth;
  keyEl.classList.add('drag-invalid');
  setTimeout(() => keyEl.classList.remove('drag-invalid'), 280);
}

function removeDashboardItemAt(index, notify = true) {
  const cfg = ensureDashboardStateSize();
  const removed = cfg[index];
  if (!removed) return;
  cfg[index] = null;
  renderDashboardSlot(getDashboardSlotEl(index), null, index);
  if (notify) postDashboardRemove(removed, index);
}

function endDashboardDragState() {
  state.dashboardDragActive = false;
  state.draggedDashboardItem = null;
  cleanupDashboardDragPreview();
  syncDashboardDropCue(false);
}

function initDashboardDrag() {
  if (dashboardInited) return;
  if (typeof Sortable === 'undefined') {
    console.warn('[VK] Sortable.js not loaded');
    return;
  }
  const keyboard = document.getElementById('keyboard');
  const grid = document.getElementById('dashboard-grid');
  const container = document.getElementById('dashboard-container');
  if (!keyboard || !grid || !container) return;

  applyDashboardLayout(dashboardLayout);

  document.querySelectorAll('.dashboard-layout-btn').forEach((btn) => {
    btn.addEventListener('click', () => applyDashboardLayout(btn.dataset.layout));
  });

  container.addEventListener('dragenter', () => {
    if (state.dashboardDragActive) syncDashboardDropCue(true);
  });
  container.addEventListener('dragover', (ev) => {
    if (!state.dashboardDragActive) return;
    ev.preventDefault();
    syncDashboardDropCue(true);
  });
  container.addEventListener('dragleave', (ev) => {
    if (!container.contains(ev.relatedTarget)) syncDashboardDropCue(false);
  });
  container.addEventListener('drop', (ev) => {
    if (ev.defaultPrevented) return;
    if (!state.draggedDashboardItem) return;
    ev.preventDefault();
    const slot = ev.target.closest('.dashboard-slot');
    const toIndex = slotIndexFromEl(slot);
    if (toIndex >= 0) {
      handleKeyboardDropToSlot(toIndex).finally(() => endDashboardDragState());
    } else {
      endDashboardDragState();
    }
  });

  grid.addEventListener('contextmenu', (ev) => {
    const slot = ev.target.closest('.dashboard-slot');
    if (!slot) return;
    ev.preventDefault();
    const index = slotIndexFromEl(slot);
    openDashboardContextMenu(ev.pageX, ev.pageY, index);
  });

  const menu = document.getElementById('dashboard-context-menu');
  menu.addEventListener('click', (ev) => {
    const btn = ev.target.closest('.dashboard-menu-item');
    if (!btn) return;
    const action = btn.dataset.menuAction || '';
    const slotIndex = state.dashboardMenuSlotIndex;
    const item = getDashboardItemAt(slotIndex);
    closeDashboardContextMenu();
    if (action === 'paste') {
      pasteDashboardClipboardToSlot(slotIndex);
      return;
    }
    if (!item) return;
    if (action === 'remove') {
      removeDashboardItemAt(slotIndex, true);
      return;
    }
    if (action === 'edit') {
      openDashboardEditModal(item).then((data) => {
        if (!data) return;
        patchDashboardItemAt(slotIndex, {
          customTitle: data.title,
          customNote: data.note,
          customShortcut: data.shortcut,
        }, true);
      });
      return;
    }
    if (action === 'copy') {
      state.dashboardClipboard = item;
      setHud(`闂傚倸鍊搁崐鎼佸磹瀹勬噴褰掑炊椤掑鏅悷婊冪Ч濠€渚€姊虹紒妯虹伇婵☆偄瀚划濠氭偐缂佹鍘甸梺纭咁潐閸旓箓宕靛▎鎴犵＜闁绘﹢娼ч弸娑欐叏婵犱胶鐭欑€规洖鐖奸、妤呭焵椤掍緡鏀伴梻鍌欑濠€杈ㄦ櫠濡も偓椤灝螣閼测晝鐒奸梺鍛婂姀閺傚倹绂嶅鍫熺厸闁稿本绻嶉崵娆撴煟韫囧﹥娅嗙紒缁樼☉椤斿繘顢欓悡搴ｎ啇婵＄偑鍊栧ú鈺冨緤閸撗勫床婵犻潧妫鈺傘亜閹存梹鏉洪柛鏃€鍨垮濠氬即閻旇櫣褰惧銈嗙墬绾板秴锕㈤幍顔瑰亾濞戞瑧绠炴慨濠傤煼瀹曟帒鈻庨幇顔哄仒闁诲氦顫夊ú鏍倶濮樿泛绠為柕濞炬櫅缁犳氨鎲稿鍏犲綊寮介鐔哄帾婵犵數鍊崘顭戜患濡炪倕楠哥换妯侯潖濞差亜绠伴幖娣灮椤︺儵姊虹粙鍖℃敾闁诡喖鍊块獮濠傤煥閸涱喖鏋傞梺鍛婃磵閺呮瑧鑺辨繝姘拺閻熸瑥瀚欢鏌ユ煟閺嶎偄甯舵い顒€锕、姘跺焵椤掑嫬钃熼柨婵嗩槸缁犲鎮楅崹顐ｅ仩闁逞屽墯鐢繝寮诲鍫闂佸憡鎸婚悷褏鍒掔拠宸悑濠㈣泛锕﹂敍鐔兼⒑閸涘娈樺ù鍏肩箓鐓ゆい蹇撳珋瑜旈弻娑㈠Ψ閿濆懎顬夊┑鐐茬墔閸楁娊寮婚敐澶嬪亹闁煎鍊楃粣妤呮⒑闂堟稒顥戦柛瀣崌濮婅櫣鎮伴垾鍏呭闂備礁鍚嬫禍浠嬪磿椤栨稓顩叉繝濠傜墛閻撴盯鏌涢幇鈺佸缂佷讲鏅滅换娑㈠礂閻撳骸顫嶇紓浣虹帛閻╊垰鐣烽妸鈺婃晣闁绘洑鐒﹂敍鍡涙⒒娴ｅ憡鎯堥柣顒€銈稿畷鐗堟償閵婏箑浠奸梺璺ㄥ枔婵敻宕戠€ｎ喗鐓曟い鎰剁悼缁犳牗銇勮箛鏇炐ｅǎ鍥э躬閹瑩顢旈崟銊ヤ壕闁靛牆顦崒銊ф喐閻楀牆绗掔紒鈧径鎰厵閺夊牊鍎抽々顒傗偓瑙勬尫缁舵岸寮诲☉銏犖ㄦい鏃傚帶閳锋帡姊烘潪鎵槮闁挎洦浜璇测槈閵忕姷顔掑┑掳鍊愰崑鎾绘煕閻旇泛宓嗙€?{state.commands[item.commandId]?.name || item.commandId}`);
      return;
    }
    if (action === 'cut') {
      state.dashboardClipboard = item;
      removeDashboardItemAt(slotIndex, true);
      setHud(`闂傚倸鍊搁崐鎼佸磹瀹勬噴褰掑炊椤掑鏅悷婊冪Ч濠€渚€姊虹紒妯虹伇婵☆偄瀚划濠氭偐缂佹鍘甸梺纭咁潐閸旓箓宕靛▎鎴犵＜闁绘﹢娼ч弸娑欐叏婵犱胶鐭欑€规洖鐖奸、妤呭焵椤掍緡鏀伴梻鍌欑濠€杈ㄦ櫠濡も偓椤灝螣閼测晝鐒奸梺鍛婂姦閸犳鎮￠崘顔界厱婵犻潧妫楅鈺呮煛閸℃瑥鏋旈柟鎻掓啞鐎佃偐鈧潧鎽滈弳顐⑩攽椤旂》鏀绘俊鐐扮矙瀵宕ㄧ€涙ê鈧兘鏌ら懝鐗堢【妞ゅ浚鍘界换婵嬪煕閳ь剟宕熼鈧崬澶愭⒑閸濆嫮鐒跨紒杈ㄦ礃缁傛帡鏁冮崒姘鳖槶閻熸粌閰ｅ畷姘槈濡粍妫冮幃鈺呮濞戞鍕冮梺姹囧焺閸ㄧ晫鎹㈠┑瀣仒妞ゆ棃鏁崑鎾绘晲鎼粹剝鐏嶉梺绋匡功閸忔﹢骞冨Δ鈧埥澶娾枍椤撗傞偗闁糕斁鍋撳銈嗗笒鐎氼參寮崡鐐冨酣宕惰闊剟鏌熼鐣屾噰妞ゃ垺妫冨畷鐔煎Ω閵夈倕顥氶梻浣告惈缁嬩線宕㈡總鍛婂珔闁绘柨鍚嬮悡蹇撯攽閻愰潧浜炬繛鍛噽閻ヮ亪骞嗚缁夋椽鏌＄仦鍓ф创闁炽儻绠撻獮瀣攽閸モ晛钂嬮梻鍌欑劍閹爼宕愰弽顬℃椽寮介鐔虹暢闂傚倷鑳剁划顖炴晪濠碘槅鍨伴敃顏勭暦閺囥垹绠涢柣妤€鐗忛崢閬嶆煟鎼搭垳绉靛ù婊勭矒閸┾偓妞ゆ巻鍋撴繛纭风節閹即顢氶埀顒€顕ｆ禒瀣垫晝闁靛繒濮锋禍浼存⒒娴ｈ棄鍚归柛鐘崇墵瀹曟垶绻濋崶褍鎯為梺鍦劋閸ㄧ喖寮ㄦ禒瀣闁规儼妫勭壕褰掓煙閻楀牊绶茬痪鎯ь煼閺岀喖宕滆鐢稒銇勯妷銉︻棞妞ゎ厼娼￠幊婊堟濞戞﹩娼旈梻浣虹帛閹稿爼宕曢懠顒佸床婵犻潧顑嗛ˉ鍫熺箾閹寸偟鎳愭俊顐熲偓鎰佹富闁靛牆鍟崝銈呪攽閻愨晛浜鹃梻浣告惈閻寰婃禒瀣р偓锕傚Ω閳轰礁鑰垮┑掳鍊愰崑鎾绘煙椤栨粌浠х紒?{state.commands[item.commandId]?.name || item.commandId}`);
      return;
    }
    if (action === 'pin') {
      pinDashboardItem(item);
    }
  });

  document.addEventListener('click', (ev) => {
    if (!menu.classList.contains('open')) return;
    if (ev.target.closest('#dashboard-context-menu')) return;
    closeDashboardContextMenu();
  });
  window.addEventListener('resize', closeDashboardContextMenu);
  document.addEventListener('scroll', closeDashboardContextMenu, true);
  document.addEventListener('keydown', (ev) => {
    if (ev.key === 'Escape') {
      closeDashboardContextMenu();
      if (state.dashboardOverwriteResolver) closeDashboardOverwriteModal(false);
      if (state.dashboardEditResolver) closeDashboardEditModal(null);
    }
  });

  const overwriteOverlay = document.getElementById('dashboard-overwrite-overlay');
  document.getElementById('dashboard-overwrite-confirm').addEventListener('click', () => {
    closeDashboardOverwriteModal(true);
  });
  document.getElementById('dashboard-overwrite-cancel').addEventListener('click', () => {
    closeDashboardOverwriteModal(false);
  });
  overwriteOverlay.addEventListener('click', (ev) => {
    if (ev.target === overwriteOverlay) closeDashboardOverwriteModal(false);
  });

  const editOverlay = document.getElementById('dashboard-edit-overlay');
  const editTitle = document.getElementById('dashboard-edit-title');
  const editNote = document.getElementById('dashboard-edit-note');
  const editShortcut = document.getElementById('dashboard-edit-shortcut');
  const collectEditForm = () => ({
    title: (editTitle.value || '').trim(),
    note: (editNote.value || '').trim(),
    shortcut: (editShortcut.value || '').trim(),
  });
  document.getElementById('dashboard-edit-save').addEventListener('click', () => {
    closeDashboardEditModal(collectEditForm());
  });
  document.getElementById('dashboard-edit-cancel').addEventListener('click', () => {
    closeDashboardEditModal(null);
  });
  editOverlay.addEventListener('click', (ev) => {
    if (ev.target === editOverlay) closeDashboardEditModal(null);
  });
  [editTitle, editNote, editShortcut].forEach((input) => {
    input.addEventListener('keydown', (ev) => {
      if (ev.key === 'Enter') {
        ev.preventDefault();
        closeDashboardEditModal(collectEditForm());
      }
    });
  });

  keyboard.addEventListener('dragstart', (ev) => {
    const keyEl = ev.target.closest('.k');
    if (!keyEl) return;
    const meta = getCommandMetaByElement(keyEl);
    if (!meta) {
      ev.preventDefault();
      flashInvalidKeyDrag(keyEl);
      return;
    }
    state.draggedDashboardItem = meta;
    state.dashboardDragActive = true;
    syncDashboardDropCue(true);
    keyEl.classList.add('dashboard-drag-source');

    if (ev.dataTransfer) {
      ev.dataTransfer.effectAllowed = 'copy';
      ev.dataTransfer.dropEffect = 'copy';
      ev.dataTransfer.setData('text/plain', meta.commandId);
      const preview = createDashboardDragPreview(meta);
      ev.dataTransfer.setDragImage(preview, preview.offsetWidth / 2, preview.offsetHeight / 2);
    }
  });

  keyboard.addEventListener('dragend', (ev) => {
    const keyEl = ev.target.closest('.k');
    if (keyEl) keyEl.classList.remove('dashboard-drag-source');
    endDashboardDragState();
  });

  keyboard.addEventListener('mousedown', (ev) => {
    const keyEl = ev.target.closest('.k');
    if (!keyEl) return;
    if (!getCommandMetaByElement(keyEl))
      flashInvalidKeyDrag(keyEl);
  });

  grid.addEventListener('dragover', (ev) => {
    if (!state.draggedDashboardItem) return;
    const slot = ev.target.closest('.dashboard-slot');
    if (!slot) return;
    ev.preventDefault();
    syncDashboardDropCue(true);
  });

  grid.addEventListener('drop', (ev) => {
    if (!state.draggedDashboardItem) return;
    const slot = ev.target.closest('.dashboard-slot');
    const toIndex = slotIndexFromEl(slot);
    if (toIndex < 0) return;
    ev.preventDefault();
    ev.stopPropagation();
    handleKeyboardDropToSlot(toIndex).finally(() => endDashboardDragState());
  });

  const bindSlotSortable = (slot) => {
    if (!slot || slot.dataset.sortableBound === '1') return;
    slot.dataset.sortableBound = '1';
    new Sortable(slot, {
      group: { name: 'actions', pull: true, put: true },
      animation: 90,
      easing: 'cubic-bezier(0.2,0,0,1)',
      swapThreshold: 0.62,
      invertSwap: true,
      forceFallback: false,
      fallbackTolerance: 3,
      draggable: '.dashboard-item',
      ghostClass: 'dashboard-drag-ghost',
      chosenClass: 'dashboard-drag-chosen',
      dragClass: 'dashboard-dragging',
      onStart: () => {
        state.dashboardDragActive = true;
      },
      onAdd: (evt) => {
        const toSlot = evt.to;
        const fromSlot = evt.from;
        const toIndex = slotIndexFromEl(toSlot);
        const fromIndex = slotIndexFromEl(fromSlot);

        Array.from(toSlot.querySelectorAll('.dashboard-item')).forEach((it) => {
          if (it !== evt.item) it.remove();
        });

        const item = dashboardItemFromElement(evt.item);
        if (!item) {
          evt.item.remove();
          endDashboardDragState();
          return;
        }
        const swapped = swapDashboardSlots(fromIndex, toIndex);
        if (!swapped) applyDashboardItemToSlot(toIndex, item, fromIndex);
      },
      onUpdate: (evt) => {
        const toIndex = slotIndexFromEl(evt.to);
        const fromIndex = slotIndexFromEl(evt.from);
        const item = dashboardItemFromElement(evt.item);
        if (!item || toIndex < 0 || fromIndex < 0) return;
        postDashboardMove(item, fromIndex, toIndex);
      },
      onEnd: () => {
        endDashboardDragState();
      },
    });
  };

  grid.querySelectorAll('.dashboard-slot').forEach(bindSlotSortable);
  const mo = new MutationObserver(() => {
    grid.querySelectorAll('.dashboard-slot').forEach(bindSlotSortable);
  });
  mo.observe(grid, { childList: true });

  renderDashboardFloatDock();
  dashboardInited = true;
}

