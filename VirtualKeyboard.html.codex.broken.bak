  const zone = document.getElementById('keyboard-zone');
  zone.classList.remove('fade-switch');
  void zone.offsetWidth;
  zone.classList.add('fade-switch');
  setTimeout(() => zone.classList.remove('fade-switch'), 120);

  const prefix = getActivePrefix();
  const focusCmdId = state.focusedCmdId;
  const focusAKey = focusCmdId
    ? (state.bindings[focusCmdId]?.explicitNone
        ? ''
        : (state.bindings[focusCmdId]?.ahkKey || state.suggestedBindings[focusCmdId] || ''))
    : '';
  state.focusedMods = focusAKey
    ? {
        ctrl: focusAKey.includes('^'),
        alt: focusAKey.includes('!'),
        shift: focusAKey.includes('+'),
      }
    : null;
  const focusLookup = /^(\^\^|\+\+|!!)$/.test(focusAKey) ? focusAKey : focusAKey.replace(/[\^!+]/g, '');
  document.querySelectorAll('.k').forEach(el => {
    const baseKey = el.dataset.ahkkey;
    if (!baseKey) return;
    el.dataset.mappedCmdId = '';
    el.dataset.mappedAhkKey = '';
    const lbl = ensureMapLabel(el);
    el.classList.remove('bound', 'slot-occupied', 'slot-available', 'slot-suggested');
    lbl.textContent = '';
    if (isModifierBaseKey(baseKey)) {
      if (focusCmdId) {
        if (/^(\^\^|\+\+|!!)$/.test(focusAKey)) {
          const keys = doubleAhkToKeys(focusAKey);
          if (keys.includes(baseKey)) {
            el.classList.add('bound', 'slot-occupied');
            el.dataset.mappedCmdId = focusCmdId;
            el.dataset.mappedAhkKey = focusAKey;
            const cmdName = state.commands[focusCmdId]?.name || focusCmdId;
            lbl.textContent = cmdName.length > 22 ? cmdName.slice(0, 20) + '闂? : cmdName;
          }
        }
        return;
      }
      const dbl = modifierToDoubleAhkKey(baseKey);
      if (dbl) {
        const cmdId = state.ahkKeyIndex[dbl];
        if (cmdId) {
          const hasReal = !!(state.bindings[cmdId]?.ahkKey);
          el.classList.add('bound', 'slot-occupied');
          el.dataset.mappedCmdId = cmdId;
          el.dataset.mappedAhkKey = dbl;
          if (!hasReal) el.classList.add('slot-suggested');
          const cmdName = state.commands[cmdId]?.name || cmdId;
          lbl.textContent = cmdName.length > 22 ? cmdName.slice(0, 20) + '闂? : cmdName;
        }
      }
