.k .k-face {
  position: absolute;
  right: 2px;
  bottom: 1px;
  left: 4px;
  text-align: right;
  font-size: 6px;
  font-weight: 500;
  line-height: 1;
  color: #fff !important;
  pointer-events: none;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.k .k-face .sub {
  font-size: 5px;
  color: #fff !important;
  font-weight: 300;
}
.k .map-label {
  position: absolute;
  top: 2px;
  left: 2px;
  right: 2px;
  bottom: auto;
  text-align: center;
  font-size: 7px;
  font-weight: 600;
  color: var(--matrix-green);
  line-height: 1.15;
  max-height: calc(100% - 11px);
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  white-space: normal;
  word-break: break-word;
  pointer-events: none;
}
.k .map-label:empty {
  display: none;
}
.kb-right-rail-stack .k .map-label {
  font-size: 6px;
  max-height: calc(100% - 9px);
}
.k:hover {
  background: #222; border-color: var(--border2);
  color: var(--text); z-index: 2;
}
.k.bound {
  border-bottom-color: var(--matrix-green) !important;
  color: var(--matrix-green) !important;
  animation: breath 3s ease-in-out infinite;
}
@keyframes breath {
  0%,100% { box-shadow: 0 0 4px #00ff4122; }
  50%      { box-shadow: var(--glow-green); }
}
.k.recording-target {
  border-color: var(--cyan) !important;
  box-shadow: var(--glow-cyan) !important;
  color: var(--cyan) !important;
  animation: none !important;
}
.k.mod-active {
  border-color: #35ff88 !important;
  color: #35ff88 !important;
  box-shadow: 0 0 10px #35ff8899 !important;
}
.k.slot-occupied {
  background: #2c1500;
  border-color: var(--orange) !important;
}
.k.slot-available {
  background: transparent;
  border-color: #6e3f16 !important;
}
.k.slot-suggested.slot-occupied {
  border-color: #5a5a5a !important;
  border-style: dashed;
}
.k.ripple {
  animation: ripplePulse 0.8s ease-out;
}
@keyframes ripplePulse {
  0%   { box-shadow: 0 0 0 0 #e67e22aa; }
  100% { box-shadow: 0 0 0 22px #e67e2200; }
}
.k:active, .k.pressed {
  background: #2a1a00;
  border-bottom-width: 1px;
  transform: translateY(2px);
}
/* 缂傚倸鍊搁崐鎼佸磹閹间礁纾归柟闂寸绾惧綊鏌熼梻瀵割槮缁惧墽鎳撻—鍐偓锝庝簻椤掋垺銇勯幇顏嗙煓闁哄被鍔戦幃銏ゅ传閸曟垯鍨介弻娑㈠Ω閵夈儮鍋撻崹顕呮綎濠电姵鑹鹃柋鍥煟閺冣偓娴滀粙鍩€椤掍礁娴柡宀嬬節瀹曢亶顢橀悩鍨闂備礁鎼惌澶岀礊娴ｈ鍙忛柍褜鍓熼弻鏇㈠醇濠靛浂妫￠梻浣诡儥閸欏啫顫忓ú顏勭闁绘劖褰冮‖澶岀磽娴ｇ瓔鍤欓柛鐔跺嵆楠炴垿濮€閻橆偅顫嶅┑顔筋殔濡寮查悩宸富闁靛牆妫欓ˉ鍡欌偓瑙勬礈閺佸骞嗛崟顒佸劅闁挎繂娲ㄩ敍婵囩箾鏉堝墽绋荤憸鏉垮暞缁傚秵銈ｉ崘鈹炬嫼缂備礁顑堝▔鏇㈡倶闁秵鐓曢悗锝庡墮娴犻亶鏌熼娆嶅€楅悿鈧梺鍦檸閸ㄩ亶寮埀顒勬⒒娴ｈ櫣甯涢柛鏃€顭囨禍绋库枎閹邦噮娴勯梺闈涚箞閸婃牠鎮￠弴銏＄厸闁稿本绻嶉崵娆撴煃瑜滈崜姘舵偋濠婂牆绠查柕蹇曞Л閺€浠嬫倵閿濆簼绨介柛鏃撶畱椤啴濡堕崱妤冪憪缂備讲鍋撳〒姘ｅ亾妞ゃ垺宀搁弻鍡楊吋閸℃せ鍋撻崹顐ょ闁瑰鍋熼幊鎰版煟閹哄秶鐭欓柡灞剧☉铻ｉ柛蹇撳悑濮ｅ嫮绱撴担浠嬪摵闁圭顭烽獮蹇涘川閺夋垹顦梺鍦帛鐢帗绔熸径瀣╃箚闁绘劦浜滈埀顒佺墵瀹曞綊宕奸弴鐔蜂画闂侀潧顦崝搴㈢娴犲鈷掑〒姘ｅ亾闁逞屽墰閸嬫盯鎳熼娑欐珷閻庢稒蓱閸欏繐鈹戦悩鎻掝仼闁告柨顑嗙换娑氬枈閸欐﹢鍋楀Δ鐘靛仜缁夊綊銆佸▎鎴炲磯闁靛ě鍐€為梻鍌氬€搁崐椋庣矆娓氣偓楠炲鏁撻悩铏珖闂侀潧绻堥崹缁樼▔瀹ュ鐓涚€广儱楠搁獮鏍煛閸曗晛鍔﹂柡灞界Х椤т線鏌涢幘鏉戝摵濠碉紕鏁诲畷鐔碱敍濮橀硸鍞洪梻浣虹《閸撴繈濡甸悙瀵哥彾闁哄洨鍠撶弧鈧梺姹囧灲濞佳嗏叴闂備胶顭堥鍡涘箲閸パ屾綎婵炲樊浜堕弫鍡涙煃瑜滈崜娑氬垝閺冨倵鍋撻悽娈跨劸妞ゃ儲鑹鹃埞鎴︽偐瀹曞浂鏆￠梺缁樻尵閸犳牠寮婚悢鍏肩劷闁挎洍鍋撳褜鍨堕弻宥囩磼濡崵顦ㄧ紓浣虹帛閻╊垶鐛鈧獮鍥ㄦ媴閸濆嫭鍊梻鍌欑閹碱偊寮甸鍌滅煓闁规儳顕々鐑芥煥閺囩偛鈧悂鎯屽Δ鍛厪濠㈣鍨伴幊鎰版偩閸愭祴鏀介柣妯虹仛閺嗏晠鏌涚€ｎ偆娲撮柟顔ㄥ嫮绡€闁搞儯鍎崑鎾诲礃椤旂厧鑰垮┑鈽嗗灠閻ㄧ兘寮ㄩ搹顐ょ瘈闁汇垽娼у瓭濠电偞娼欓崐鍨嚕椤愩埄鍚嬮柛鈩冪懅閻﹀牊绻濋悽闈浶㈤柛濠冩倐椤㈡棃鍩￠崒婊咁啎闂佸壊鍋呯换鍕倿閸涘﹥鍙忓┑鐘插閸斿鎮楅悽闈涘付闁宠閰ｉ獮鎺楀籍閹寸倫褔姊婚崒娆戭槮闁规祴鈧剚娼栫憸鐗堝笒閸ㄥ倿鏌涢…鎴濇珮闁搞倖娲栭埞鎴︽偐鐎圭姴顥濋柟顖滃枛濮婃椽妫冨☉杈ㄐら梺鎼炲妽濡炰粙鏁愰悙宸悑闁告侗浜濋弬鈧梻浣哥枃濡嫬螞濡ゅ懏鍊堕柨婵嗩槹閻撴洘淇婇婊冃㈡繛灞傚€濋幃鐐寸節濮橆厸鎷哄銈嗗坊閸嬫挾绱掓径灞炬毈闁?AHK InputHook 闂傚倸鍊搁崐鎼佸磹閹间礁纾归柟闂寸绾惧湱鈧懓瀚崳纾嬨亹閹烘垹鍊炲銈嗗笒閿曪妇绮欒箛鏃傜瘈闁靛骏绲剧涵鐐亜閹存繃鍠橀柕鍡楁嚇楠炴捇骞戝Δ鈧紞濠囧箖閳轰緡鍟呮い鏃傚帶婢瑰牏绱撻崒娆掝唹闁稿鎸搁…鍧楁嚋闂堟稑顫嶉梺缁樻尰閻熲晛顕ｉ崼鏇為唶婵犻潧妫岄幐鍐⒑娴兼瑧绉ù婊冪埣瀵鏁愭径濠勵唺闂佺懓顕慨宕囧垝閻㈠憡鈷戦梻鍫熺⊕閹兼劙鎮楀顐㈠祮闁绘侗鍠氶埀顒婄秵閸犳寮查弻銉︾厱闁斥晛鍟伴幊鈧梺閫炲苯澧柨鏇濡叉劙骞樼€涙ê顎撻梺闈╁瘜閸樼危閸垻纾藉ù锝堟鐢盯鎮介婊冧粶閸?*/
.k.key-live {
  background: #2a1a00;
  border-bottom-width: 1px;
  transform: translateY(2px);
  box-shadow: var(--glow-cyan);
  border-color: var(--cyan) !important;
  color: var(--cyan) !important;
}
