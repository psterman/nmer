#cmd-search-bar {
  flex-shrink: 0;
  display: flex; align-items: center; gap: 6px;
  padding: 6px 10px;
  border-bottom: 1px solid var(--border);
  background: var(--surface);
}
#cmd-search {
  flex: 1;
  font-family: var(--font);
  font-size: var(--vk-panel-font);
  background: var(--surface3);
  border: 1px solid var(--border2);
  border-radius: 4px;
  color: var(--text);
  padding: 3px 8px;
  outline: none;
  transition: border-color .15s;
}
#cmd-search:focus {
  border-color: var(--matrix-green);
  box-shadow: 0 0 0 1px #00ff4133, 0 0 10px #00ff4122;
  color: var(--text);
}
#cmd-search::placeholder { color: var(--text-xs); transition: color .2s; }
#cmd-search:focus::placeholder { color: var(--border2); }
#cmd-count {
  font-size: var(--vk-panel-font-sm); color: var(--text-xs);
  flex-shrink: 0; min-width: 52px; text-align: right;
}
#atom-tabs {
  flex-shrink: 0;
  display: flex;
  gap: 6px;
  align-items: center;
  padding: 6px 10px;
  border-bottom: 1px solid var(--border);
  background: #101010;
  overflow-x: auto;
}
#atom-tabs::-webkit-scrollbar { height: 5px; }
#atom-tabs::-webkit-scrollbar-thumb { background: #1e3a22; border-radius: 4px; }
.atom-tab {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  border: 1px solid #333;
  border-radius: 999px;
  padding: 3px 10px;
  color: #bbb;
  background: #171717;
  cursor: pointer;
  font-size: 11px;
  white-space: nowrap;
  transition: .12s ease;
}
.atom-tab:hover {
  border-color: #3f653f;
  color: #cdeccd;
}
.atom-tab.active {
  color: #ffb15a;
  border-color: #ff8c2a;
  box-shadow: 0 0 0 1px rgba(230,126,34,.16) inset;
}
.atom-tab .atom-count {
  color: var(--text-xs);
}
.atom-tab.active .atom-count {
  color: #ffb15a;
}
#cmd-list-wrapper {
  flex: 1;
  overflow-y: auto;
  padding: 0;
}
/* scrollbar */
#cmd-list-wrapper::-webkit-scrollbar { width: 6px; }
#cmd-list-wrapper::-webkit-scrollbar-track { background: var(--bg); }
#cmd-list-wrapper::-webkit-scrollbar-thumb { background: #1e3a22; border-radius: 3px; }
#cmd-list-wrapper::-webkit-scrollbar-thumb:hover { background: #00ff4144; }
.no-command-found {
  padding: 16px 10px;
  text-align: center;
  color: var(--text-xs);
  font-size: var(--vk-panel-font);
  letter-spacing: 1px;
}

.cmd-group-header {
  padding: 4px 10px 3px;
  font-size: var(--vk-panel-font-sm); letter-spacing: 1px; color: var(--text-xs);
  text-transform: uppercase;
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  position: sticky; top: 0; z-index: 1;
}
.cmd-row {
  display: flex; align-items: center;
  padding: 0 10px;
  height: 32px;
  border-bottom: 1px solid var(--border);
  font-size: var(--vk-panel-font);
  cursor: default;
  transition: background .1s;
}
.cmd-row:hover { background: #111; }
.cmd-row.has-binding { background: #0e0c00; }
.cmd-row.has-binding:hover { background: #161000; }
.cmd-row.active-focus {
  outline: 1px solid #e67e2288;
  background: #1a1300 !important;
}
.cmd-row.flash-jump {
  animation: cmd-jump-flash .55s ease-out;
}
@keyframes cmd-jump-flash {
  0%   { box-shadow: 0 0 0 0 rgba(230,126,34,.0); background: #2a1a00; }
  35%  { box-shadow: 0 0 0 2px rgba(230,126,34,.5); background: #322000; }
  100% { box-shadow: 0 0 0 0 rgba(230,126,34,.0); background: #1a1300; }
}
.cmd-row.recording {
  background: #1a0e00 !important;
  animation: rec-pulse 1s ease-in-out infinite;
}
@keyframes rec-pulse {
  0%,100% { background: #1a0e00; }
  50%      { background: #2a1800; }
}
.cmd-name {
  flex: 1;
  color: var(--text);
  font-family: var(--font-ui);
  display: flex;
  align-items: center;
  gap: 7px;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.cmd-icon {
  width: 14px;
  text-align: center;
  color: #ff9f43;
  flex-shrink: 0;
}
.cmd-title {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.cmd-hit {
  flex-shrink: 0;
  font-size: 10px;
  color: #7dd3fc;
  border: 1px solid #27506a;
  border-radius: 999px;
  padding: 1px 6px;
  background: rgba(14,45,59,.45);
}
.cmd-mark {
  background: rgba(251,191,36,.22);
  color: #fef3c7;
  border-radius: 2px;
  padding: 0 1px;
}
.cmd-row.recording .cmd-name {
  color: var(--orange);
}
.cmd-key {
  min-width: 100px;
  font-family: var(--font);
  font-size: var(--vk-panel-font-sm);
  color: var(--text-dim);
  text-align: right;
  padding-right: 12px;
}
.cmd-row.binding-custom .cmd-key { color: var(--orange-lt); }
.cmd-row.binding-suggested .cmd-key { color: #8b8b8b; }
.cmd-row.binding-none .cmd-key { color: #666; }
.cmd-row.recording .cmd-key {
  color: var(--cyan);
  animation: blink 1s step-end infinite;
}
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:.3} }
.cmd-actions {
  display: flex; gap: 4px; align-items: center;
  flex-shrink: 0;
}
.btn-icon {
  font-size: 12px;
  color: var(--text-xs);
  background: transparent;
  border: 1px solid transparent;
  border-radius: 3px;
  width: 22px; height: 22px;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  transition: color .1s, border-color .1s;
}
.btn-icon:hover { color: var(--orange); border-color: var(--border2); }
.btn-icon.danger:hover { color: #e74c3c; border-color: #e74c3c66; }
.btn-icon.active-rec {
  color: var(--cyan);
  border-color: var(--cyan);
  box-shadow: var(--glow-cyan);
}
#keyboard-zone.fade-switch .k .map-label {
  animation: fadeSwitch .1s linear;
}
@keyframes fadeSwitch {
  0% { opacity: .2; }
  100% { opacity: 1; }
}

