.kr-nav-up {
  display: flex;
  justify-content: center;
  width: 100%;
}
.kr-nav-up .k {
  flex: 0 0 var(--kb-arrow-w);
  width: var(--kb-arrow-w);
  min-width: var(--kb-arrow-w);
  max-width: var(--kb-arrow-w);
  padding: 0 1px;
}
.kr-nav.kr-arrows {
  justify-content: center;
  gap: 2px;
}
.kr-nav.kr-arrows > .k {
  flex: 0 0 var(--kb-arrow-w);
  width: var(--kb-arrow-w);
  min-width: var(--kb-arrow-w);
  max-width: var(--kb-arrow-w);
  padding: 0 1px;
}
