const SCENARIO_META = [
  { id: 'ai', name: 'AI', icon: 'fa-robot', color: '#7dd3fc' },
  { id: 'search', name: 'Search', icon: 'fa-magnifying-glass', color: '#a3e635' },
  { id: 'favorite', name: 'Favorites', icon: 'fa-star', color: '#fbbf24' },
  { id: 'dialogue', name: 'Chat', icon: 'fa-comments', color: '#c4b5fd' },
  { id: 'clipboard', name: 'Clipboard', icon: 'fa-clipboard', color: '#fca5a5' },
  { id: 'prompt', name: 'Prompts', icon: 'fa-lightbulb', color: '#fdba74' },
  { id: 'draft', name: 'Drafts', icon: 'fa-pen-to-square', color: '#86efac' },
  { id: 'screenshot', name: 'Screenshot', icon: 'fa-camera', color: '#93c5fd' },
  { id: 'settings', name: 'Settings', icon: 'fa-gear', color: '#d1d5db' },
];
function uniqueArray(arr) {
  const out = [];
  const seen = new Set();
  for (const item of arr || []) {
    const v = String(item || '').trim();
    if (!v) continue;
    const k = v.toLowerCase();
    if (seen.has(k)) continue;
    seen.add(k);
    out.push(v);
  }
  return out;
}

function normalizeKeywordList(input) {
  if (Array.isArray(input)) return uniqueArray(input);
  if (typeof input !== 'string') return [];
  return uniqueArray(input.split(/[\s,|]+/g));
}

function inferCommandIconClass(cmdId, cmd) {
  const text = (cmdId + ' ' + (cmd?.name || '') + ' ' + (cmd?.desc || '')).toLowerCase();
  if (/screenshot|capture|ocr|image|ch_t|ch_p/.test(text)) return 'fa-camera';
  if (/clipboard|copy|paste|ch_c|ch_v|ch_x/.test(text)) return 'fa-clipboard';
  if (/search|find|ch_f|ch_g/.test(text)) return 'fa-magnifying-glass';
  if (/prompt|template|pqp/.test(text)) return 'fa-lightbulb';
  if (/draft|hub|capsule|newprompt/.test(text)) return 'fa-pen-to-square';
  if (/setting|config|qa_settings|cursor_settings/.test(text)) return 'fa-gear';
  if (/voice|mic/.test(text)) return 'fa-microphone';
  if (/terminal|shell|cmd/.test(text)) return 'fa-terminal';
  if (/browser|web/.test(text)) return 'fa-globe';
  if (/keyboard|key|hotkey|vk/.test(text)) return 'fa-keyboard';
  if (/ai|assistant|explain|refactor|optimize/.test(text)) return 'fa-wand-magic-sparkles';
  if (/exit|close|quit/.test(text)) return 'fa-power-off';
  return 'fa-bolt';
}

function buildGuessedKeywords(cmdId, cmd) {
  const text = (cmdId + ' ' + (cmd?.name || '') + ' ' + (cmd?.desc || '')).toLowerCase();
  const words = [];
  if (/ai|explain|refactor|optimize/.test(text)) words.push('ai', 'explain', 'refactor', 'optimize', 'rewrite');
  if (/search|find/.test(text)) words.push('search', 'find', 'lookup');
  if (/clipboard|copy|paste/.test(text)) words.push('clipboard', 'copy', 'paste', 'history');
  if (/prompt|template/.test(text)) words.push('prompt', 'template', 'instruction');
  if (/draft|hub|capsule/.test(text)) words.push('draft', 'capture', 'stash');
  if (/screenshot|capture|ocr/.test(text)) words.push('screenshot', 'capture', 'ocr', 'image');
  if (/setting|config/.test(text)) words.push('settings', 'config', 'preferences');
  if (/voice|mic/.test(text)) words.push('voice', 'speech');
  if (/dialog|chat|conversation/.test(text)) words.push('chat', 'conversation');
  words.push(cmdId);
  if (cmd?.name) words.push(cmd.name);
  if (cmd?.desc) words.push(cmd.desc);
  return uniqueArray(words);
}

function enrichCommands(rawCommands) {
  const out = {};
  for (const [cmdId, val] of Object.entries(rawCommands || {})) {
    const cmd = (val && typeof val === 'object') ? { ...val } : { name: cmdId, desc: '' };
    const ownKeywords = normalizeKeywordList(cmd.keywords);
    cmd.icon = cmd.icon || inferCommandIconClass(cmdId, cmd);
    cmd.keywords = uniqueArray([...ownKeywords, ...buildGuessedKeywords(cmdId, cmd)]);
    out[cmdId] = cmd;
  }
  return out;
}

function classifyScenarioIdForCommand(cmdId, cmd, category) {
  const text = (cmdId + ' ' + (cmd?.name || '') + ' ' + (cmd?.desc || '') + ' '
    + (category?.id || '') + ' ' + (category?.name || '')).toLowerCase();
  if (/screenshot|capture|ocr|ch_t|ch_p/.test(text)) return 'screenshot';
  if (/newprompt|hub|capsule|draft/.test(text)) return 'draft';
  if (/prompt|template|pqp/.test(text)) return 'prompt';
  if (/clipboard|copy|paste|ch_c|ch_v|ch_x/.test(text)) return 'clipboard';
  if (/search|find|ch_f|ch_g/.test(text)) return 'search';
  if (/chat|dialog|conversation|niuma/.test(text)) return 'dialogue';
  if (/favorite|star|pin/.test(text)) return 'favorite';
  if (/ai|assistant|explain|refactor|optimize|voice/.test(text)) return 'ai';
  return 'settings';
}

function classifyAtomName(scenarioId, cmdId, cmd, category) {
  const text = (cmdId + ' ' + (cmd?.name || '') + ' ' + (cmd?.desc || '') + ' '
    + (category?.id || '') + ' ' + (category?.name || '')).toLowerCase();
  if (scenarioId === 'ai') {
    if (/config|setting|api|model/.test(text)) return 'AI Settings';
    if (/voice/.test(text)) return 'Voice Input';
    if (/explain|refactor|optimize/.test(text)) return 'Code Assist';
    return 'AI Chat';
  }
  if (scenarioId === 'search') return /voice/.test(text) ? 'Voice Search' : 'Quick Search';
  if (scenarioId === 'clipboard') {
    if (/copy/.test(text)) return 'Copy Actions';
    if (/paste/.test(text)) return 'Paste Actions';
    return 'Clipboard Manage';
  }
  if (scenarioId === 'prompt') return /template/.test(text) ? 'Template Manage' : 'Prompt Tools';
  if (scenarioId === 'draft') return 'Draft Capture';
  if (scenarioId === 'screenshot') return /ocr/.test(text) ? 'OCR Capture' : 'Capture Tools';
  if (scenarioId === 'dialogue') return 'Conversation';
  if (scenarioId === 'favorite') return 'Favorite Actions';
  if (/keyboard|hotkey|vk/.test(text)) return 'Keyboard & Hotkeys';
  if (/window|sys_/.test(text)) return 'System Window';
  return 'Preferences';
}
function buildScenariosFromCategories() {
  const scenarioMap = new Map();
  for (const meta of SCENARIO_META) {
    scenarioMap.set(meta.id, { ...meta, tabs: [], tabMap: new Map(), count: 0 });
  }
  const routeMap = {};
  const visited = new Set();

  const addCommand = (cmdId, category) => {
    const cmd = state.commands[cmdId];
    if (!cmd) return;
    const scenarioId = classifyScenarioIdForCommand(cmdId, cmd, category);
    const scenario = scenarioMap.get(scenarioId) || scenarioMap.get('settings');
    const tabName = classifyAtomName(scenarioId, cmdId, cmd, category);
    const tabId = scenario.id + '::' + tabName;
    let tab = scenario.tabMap.get(tabId);
    if (!tab) {
      tab = { id: tabId, name: tabName, commands: [] };
      scenario.tabMap.set(tabId, tab);
      scenario.tabs.push(tab);
    }
    if (!tab.commands.includes(cmdId)) {
      tab.commands.push(cmdId);
      scenario.count += 1;
      if (!routeMap[cmdId]) {
        routeMap[cmdId] = { scenarioId: scenario.id, tabId, categoryId: category?.id || '' };
      }
    }
  };

  for (const category of state.categories || []) {
    for (const cmdId of category?.commands || []) {
      addCommand(cmdId, category);
      visited.add(cmdId);
    }
  }
  for (const cmdId of Object.keys(state.commands || {})) {
    if (!visited.has(cmdId)) addCommand(cmdId, { id: 'misc', name: 'Misc' });
  }

  state.scenarios = SCENARIO_META
    .map((meta) => scenarioMap.get(meta.id))
    .filter((scenario) => !!scenario)
    .map((scenario) => ({
      id: scenario.id,
      name: scenario.name,
      icon: scenario.icon,
      color: scenario.color,
      count: scenario.count,
      tabs: scenario.tabs,
    }));
  state.commandRoutes = routeMap;
}

function getScenarioById(id) {
  return (state.scenarios || []).find((s) => s.id === id) || null;
}

function ensureActiveScenarioAndTab() {
  if (!state.scenarios.length) {
    state.filter = '';
    state.activeTab = 'all';
    return;
  }
  if (!getScenarioById(state.filter)) {
    const firstWithCmd = state.scenarios.find((s) => (Number(s.count) || 0) > 0);
    state.filter = (firstWithCmd || state.scenarios[0]).id;
  }
  const scenario = getScenarioById(state.filter);
  if (!scenario) {
    state.activeTab = 'all';
    return;
  }
  if (state.activeTab !== 'all' && !scenario.tabs.some((t) => t.id === state.activeTab)) {
    state.activeTab = 'all';
  }
}

function escapeRegExp(text) {
  return String(text || '').replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
}

function highlightQuery(text, query) {
  const src = String(text || '');
  const q = String(query || '').trim();
  if (!q) return escapeHtml(src);
  const regex = new RegExp('(' + escapeRegExp(q) + ')', 'ig');
  return escapeHtml(src).replace(regex, '<mark class="cmd-mark">$1</mark>');
}

