let vkLastAltTapAt = 0;

function tryExecuteDoubleAltFromClick(ahkKey, el, e) {
  if (ahkKey !== 'LAlt' && ahkKey !== 'RAlt') return false;
  const now = Date.now();
  if (vkLastAltTapAt > 0 && (now - vkLastAltTapAt) < VK_ALT_DBL_MS) {
    vkLastAltTapAt = 0;
    e.preventDefault();
    e.stopPropagation();
    const cmdId = state.ahkKeyIndex['!!'];
    if (cmdId) {
      postToAhk({ type: 'executeCommand', commandId: cmdId });
      triggerKeyRipple('!!');
      focusCommandById(cmdId);
    }
    el.classList.add('pressed');
    setTimeout(() => el.classList.remove('pressed'), 180);
    return true;
  }
  vkLastAltTapAt = now;
  return false;
}

document.querySelectorAll('.k').forEach(el => {
  el.addEventListener('click', (e) => {
    const ahkKey = el.dataset.ahkkey;
    if (!ahkKey) return;
    if (tryExecuteDoubleAltFromClick(ahkKey, el, e)) return;
    const mappedCmdId = el.dataset.mappedCmdId || state.ahkKeyIndex[ahkKey] || '';
    if (mappedCmdId) focusCommandById(mappedCmdId);
    el.classList.add('pressed');
    setTimeout(() => el.classList.remove('pressed'), 180);
  });
  el.addEventListener('dblclick', (e) => {
    const ahkKey = el.dataset.ahkkey;
    if (!ahkKey) return;
    if (ahkKey === 'LAlt' || ahkKey === 'RAlt') return;
    const dbl = modifierToDoubleAhkKey(ahkKey);
    if (!dbl) return;
    e.preventDefault();
    const cmdId = state.ahkKeyIndex[dbl];
    if (!cmdId) return;
    postToAhk({ type: 'executeCommand', commandId: cmdId });
    triggerKeyRipple(dbl);
    focusCommandById(cmdId);
  });
});

