.kb-main-strip > .k,
.kb-main-left-col > .kr > .k {
  flex: 1 1 0;
  min-width: 12px;
}
.kr-gap {
  flex: 0 0 auto !important;
  width: 6px;
  min-width: 6px;
  pointer-events: none;
}
.k {
  position: relative;
  display: block;
  height: var(--kb-key-h, 26px);
  min-height: var(--kb-key-h, 26px);
  min-width: 16px;
  padding: 2px 4px 3px;
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: 3px;
  border-bottom: 2px solid #1a1a1a;
  font-family: var(--font);
  font-size: 8px; font-weight: 500;
  color: var(--text-dim);
  cursor: pointer;
  transition: background .1s, border-color .1s, box-shadow .1s, color .1s, transform .05s;
  flex-shrink: 1;
  line-height: 1.15;
}
