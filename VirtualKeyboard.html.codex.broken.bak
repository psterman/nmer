#reset-all {
  font-family: var(--font);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 1.1px;
  color: var(--text-dim);
  background: var(--surface3);
  border: 1px solid var(--border2);
  border-radius: 999px;
  padding: 4px 10px;
  cursor: pointer;
  transition: color .15s, border-color .15s, box-shadow .15s;
  flex-shrink: 0;
}
#reset-all:hover { color: var(--orange); border-color: var(--orange); box-shadow: 0 0 0 1px rgba(230,126,34,.18) inset, 0 0 18px rgba(230,126,34,.22); }

