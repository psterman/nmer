function setHud(msg, connected) {
  document.getElementById('hud-status').textContent = msg;
  if (connected !== undefined) {
    state.connected = connected;
    document.getElementById('hud-dot').className = connected ? 'on' : '';
  }
}

function renderAdminWarning() {
  const el = document.getElementById('admin-warning');
  if (!el) return;
  const text = (state.adminWarning || '').trim();
  if (!text) {
    el.classList.remove('visible');
    el.textContent = '';
    return;
  }
  el.textContent = text;
  el.classList.add('visible');
}

function escapeHtml(s) {
  if (s == null || s === '') return '';
  const d = document.createElement('div');
  d.textContent = String(s);
  return d.innerHTML;
}

function syncLastActionCurrentKeyFromBindings() {
  const id = state.lastActionId;
  if (!id) {
    state.lastActionCurrentKey = '';
    return;
  }
  const b = state.bindings[id];
  if (b?.explicitNone) {
    state.lastActionCurrentKey = '';
    return;
  }
  if (b?.ahkKey) {
    state.lastActionCurrentKey = b.displayKey || b.ahkKey;
    return;
  }
  const sk = state.suggestedBindings[id];
  if (sk) {
    const u = (sk.length === 1 && /[a-zA-Z]/.test(sk)) ? sk.toUpperCase() : sk;
    state.lastActionCurrentKey = 'CapsLock+' + u;
    return;
  }
  state.lastActionCurrentKey = '';
}

function renderHudHint() {
  const el = document.getElementById('hud-hint');
  if (!el) return;
  if (state.recording || !state.quickBindActive) {
    el.style.display = 'none';
    el.innerHTML = '';
    return;
  }

  el.style.display = 'block';
  syncLastActionCurrentKeyFromBindings();
  const id = state.lastActionId || '';
  const name = state.lastActionName || '';
  const curKey = state.lastActionCurrentKey || '';

  const keyLine = curKey
    ? '<br><span class="hud-hint-sub">Current shortcut: <code>' + escapeHtml(curKey) + '</code></span>'
    : '';

  if (id) {
    el.innerHTML =
      '<span class="hud-hint-main">Last action: </span><b>' + escapeHtml(name || id) + '</b> <code>' + escapeHtml(id) + '</code>'
      + keyLine
      + '<br><span class="hud-hint-sub">Tip: run an action first, then hold CapsLock and press a target key to bind quickly.</span>';
  } else {
    el.innerHTML =
      '<span class="hud-hint-main">No recent action to bind.</span>'
      + '<br><span class="hud-hint-sub">Run any command once, then hold CapsLock to quick-bind.</span>';
  }
}

function renderHostModeHint() {
  const el = document.getElementById('vk-host-mode-hint');
  if (!el) return;
  if (!state.connected) {
    el.classList.remove('visible');
    el.textContent = '';
    return;
  }
  el.classList.add('visible');
  if (state.embeddedHost) {
    el.textContent = 'Embedded mode: bindings sync with CursorHelper immediately.';
  } else {
    el.textContent = 'Standalone mode: bindings are registered in this process and synced when possible.';
  }
}

function updateHudSnapshot(connected) {
  const n = Object.keys(state.bindings).filter((k) => state.bindings[k]?.ahkKey).length;
  let line1 = 'Connected | ' + n + ' bindings';
  if (state.quickBindActive) line1 += ' | Quick-bind ON';
  setHud(line1, connected);
  renderHostModeHint();
  renderHudHint();
}
function flashBindSuccessHud(message) {
  const hud = document.getElementById('hud-status');
  if (!hud) return;
  hud.classList.remove('error');
  hud.classList.add('success');
  setHud(message);
  setTimeout(() => {
    hud.classList.remove('success');
    updateHudSnapshot();
  }, 700);
}

function flashBindErrorHud(message) {
  const hud = document.getElementById('hud-status');
  if (!hud) return;
  hud.classList.remove('success');
  hud.classList.add('error');
  setHud(message);
  setTimeout(() => {
    hud.classList.remove('error');
    updateHudSnapshot();
  }, 1600);
}

// AHK key string -> KeyboardEvent.code (for keyboard highlight)
// e.g. "q" -> "KeyQ",  "Escape" -> "Escape",  "F5" -> "F5"
function ahkKeyToDataKey(ahkKey) {
  // strip modifiers
  const base = ahkKey.replace(/[\^!+]/g, '');
  if (/^[a-z]$/.test(base)) return 'Key' + base.toUpperCase();
  if (/^[0-9]$/.test(base)) return 'Digit' + base;
  return base; // Escape, F1..F12, Space, etc.
}

// KeyboardEvent -> AHK hotkey string
function buildAhkKey(e) {
  const mods = (e.ctrlKey ? '^' : '') + (e.altKey ? '!' : '') + (e.shiftKey ? '+' : '');
  const base  = keyCodeToAhkBase(e.code);
  return mods + base;
}

function buildDisplayKey(e) {
  const parts = [];
  if (e.ctrlKey)  parts.push('Ctrl');
  if (e.altKey)   parts.push('Alt');
  if (e.shiftKey) parts.push('Shift');
  parts.push(keyCodeToDisplay(e.code));
  return parts.join('+');
}

function keyCodeToAhkBase(code) {
  if (/^Key([A-Z])$/.test(code)) return code.slice(3).toLowerCase();
  if (/^Digit([0-9])$/.test(code)) return code.slice(5);
  const map = {
    Escape:'Escape', Enter:'Enter', Space:'Space', Tab:'Tab',
    Backspace:'Backspace', Delete:'Delete', Insert:'Insert',
    Home:'Home', End:'End', PageUp:'PgUp', PageDown:'PgDn',
    ArrowUp:'Up', ArrowDown:'Down', ArrowLeft:'Left', ArrowRight:'Right',
    F1:'F1', F2:'F2', F3:'F3', F4:'F4', F5:'F5', F6:'F6',
    F7:'F7', F8:'F8', F9:'F9', F10:'F10', F11:'F11', F12:'F12',
    Minus:'-', Equal:'=', BracketLeft:'[', BracketRight:']',
    Backslash:'\\', Semicolon:';', Quote:"'", Backquote:'``',
    Comma:',', Period:'.', Slash:'/',
    PrintScreen:'PrintScreen', ScrollLock:'ScrollLock', Pause:'Pause',
    CapsLock:'CapsLock',
    ShiftLeft:'LShift', ShiftRight:'RShift',
    ControlLeft:'LCtrl', ControlRight:'RCtrl',
    AltLeft:'LAlt', AltRight:'RAlt',
    MetaLeft:'LWin', MetaRight:'RWin',
    ContextMenu:'AppsKey',
  };
  return map[code] || code;
}

function keyCodeToDisplay(code) {
  if (/^Key([A-Z])$/.test(code)) return code.slice(3);
  if (/^Digit([0-9])$/.test(code)) return code.slice(5);
  const map = {
    Escape: 'Esc', Enter: 'Enter', Space: 'Space', Tab: 'Tab',
    Backspace: 'Bks', Delete: 'Del', Insert: 'Ins',
    Home: 'Home', End: 'End', PageUp: 'PgUp', PageDown: 'PgDn',
    ArrowUp: 'Up', ArrowDown: 'Down', ArrowLeft: 'Left', ArrowRight: 'Right',
    F1: 'F1', F2: 'F2', F3: 'F3', F4: 'F4', F5: 'F5', F6: 'F6',
    F7: 'F7', F8: 'F8', F9: 'F9', F10: 'F10', F11: 'F11', F12: 'F12',
    Minus: '-', Equal: '=',
  };
  return map[code] || code;
}
function isModifierOnlyAhkBase(base) {
  return base === 'LShift' || base === 'RShift'
    || base === 'LCtrl' || base === 'RCtrl'
    || base === 'LAlt' || base === 'RAlt'
    || base === 'LWin' || base === 'RWin'
    || base === 'CapsLock';
}

function normalizeCompareBase(base) {
  if (!base) return '';
  const map = {
    LShift: 'Shift', RShift: 'Shift',
    LCtrl: 'Ctrl', RCtrl: 'Ctrl',
    LAlt: 'Alt', RAlt: 'Alt',
    LWin: 'Win', RWin: 'Win',
    PgUp: 'PageUp', PgDn: 'PageDown',
  };
  return map[base] || base;
}

function maybePromptAutoFallback() {
  const now = Date.now();
  if (state.nativeLayout) return;
  if (mismatchDetector.mismatchCount < 3) return;
  if (now < mismatchDetector.promptCooldownUntil) return;
  mismatchDetector.promptCooldownUntil = now + 15000;

  const ok = confirm('Switch to compatible keyboard mode (NATIVE)?');
  if (ok) {
    state.nativeLayout = true;
    updateLayoutToggleUI();
    postToAhk({ type: 'setLayoutMode', native: true });
    setHud('Keyboard mismatch detected. Switched to NATIVE mode.');
    mismatchDetector.mismatchCount = 0;
  } else {
    setHud('Keyboard mismatch still exists. You can switch layout mode manually.', state.connected);
  }
}

function checkLayoutMismatch() {
  const webTick = mismatchDetector.lastWebTick;
  const ahkTick = mismatchDetector.lastAhkTick;
  if (!webTick || !ahkTick) return;
  if (Math.abs(webTick - ahkTick) > 140) return;

  const webBase = normalizeCompareBase(mismatchDetector.lastWebBase);
  const ahkBase = normalizeCompareBase(mismatchDetector.lastAhkBase);
  if (!webBase || !ahkBase) return;

  const now = Date.now();
  if (webBase === ahkBase) {
    mismatchDetector.mismatchCount = 0;
    return;
  }
  if (now - mismatchDetector.lastMismatchTick < 5000)
    mismatchDetector.mismatchCount += 1;
  else
    mismatchDetector.mismatchCount = 1;
  mismatchDetector.lastMismatchTick = now;
  maybePromptAutoFallback();
}

function trackWebKeyDown(e) {
  if (!e || e.isComposing || e.repeat) return;
  const base = keyCodeToAhkBase(e.code || '');
  if (!base || isModifierOnlyAhkBase(base)) return;
  mismatchDetector.lastWebBase = base;
  mismatchDetector.lastWebTick = Date.now();
  checkLayoutMismatch();
}

function trackAhkPreview(base, phase) {
  if (phase !== 'down') return;
  if (!base || isModifierOnlyAhkBase(base)) return;
  mismatchDetector.lastAhkBase = base;
  mismatchDetector.lastAhkTick = Date.now();
  checkLayoutMismatch();
}

