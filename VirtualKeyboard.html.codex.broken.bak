function renderSidebar() {
  const list = document.getElementById('sidebar-list');
  list.innerHTML = '';
  ensureActiveScenarioAndTab();

  for (const scenario of state.scenarios || []) {
    const item = document.createElement('div');
    item.className = 'sidebar-item' + (state.filter === scenario.id ? ' active' : '');
    item.innerHTML =
      '<span class="mol-ico" style="color:' + escapeHtml(scenario.color || '#ff9f43') + ';">'
      + '<i class="fa-solid ' + escapeHtml(scenario.icon || 'fa-circle') + '"></i></span>'
      + '<span class="mol-name">' + escapeHtml(scenario.name || scenario.id) + '</span>'
      + '<span class="mol-count">' + (Number(scenario.count) || 0) + '</span>';
    item.addEventListener('click', () => {
      state.filter = scenario.id;
      state.activeTab = 'all';
      renderSidebar();
      renderAtomTabs();
      renderCommandList();
    });
    list.appendChild(item);
  }
}

function renderAtomTabs() {
  const wrap = document.getElementById('atom-tabs');
  if (!wrap) return;
  wrap.innerHTML = '';
  ensureActiveScenarioAndTab();
  const scenario = getScenarioById(state.filter);
  if (!scenario) return;

  const allBtn = document.createElement('button');
  allBtn.type = 'button';
  allBtn.className = 'atom-tab' + (state.activeTab === 'all' ? ' active' : '');
  allBtn.innerHTML = '<i class="fa-solid fa-layer-group"></i><span>闂傚倸鍊搁崐鎼佸磹閹间礁纾归柣鎴ｅГ閸ゅ嫰鏌涢锝嗙５闁逞屽墾缁犳挸鐣锋總绋款潊闁炽儱鍟跨花銉╂⒒娴ｇ顥忛柛瀣╃窔瀹曟洘娼忛埡鍐劶婵犮垼鍩栭崝鏍偂濞嗘挸绾ч柛顐ｇ箓閳锋棃鏌ｉ敐鍫滃惈闁汇儺浜獮鍡氼槼闁稿鍎甸弻鐔碱敊缁涘鐣堕梺瀹犳椤︻垶鍩㈡惔鈭ョ喖鎮℃惔鈱掋劌鈹戦敍鍕杭闁稿﹥鍔欏鎻掆攽鐎ｎ亞顦у┑顔姐仜閸嬫挻顨ラ悙鎻掓殺闁靛洦鍔欓獮鎺楀箣閻樻祴鍋撻悙鐑樷拺闂傚牊渚楅悞楣冩煕鎼达紕锛嶇紒顔硷工閻ｏ繝鏌囬敂钘夌槣?/span>'
    + '<span class="atom-count">' + (scenario.count || 0) + '</span>';
  allBtn.addEventListener('click', () => {
    state.activeTab = 'all';
    renderAtomTabs();
    renderCommandList();
  });
  wrap.appendChild(allBtn);

  for (const tab of scenario.tabs || []) {
    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'atom-tab' + (state.activeTab === tab.id ? ' active' : '');
    btn.innerHTML = '<i class="fa-solid fa-circle-dot"></i><span>'
      + escapeHtml(tab.name || '婵犵數濮烽弫鍛婃叏閻戣棄鏋侀柟闂寸绾剧粯绻涢幋娆忕労闁轰礁顑嗛妵鍕箻鐠虹儤鐎鹃梺鍛婄懃缁绘劘鐏冮梺鎸庣箓閹冲酣寮搁妶澶嬬厸濞达絽澹婇崕鎴︽煙閹绘帗鍟為柟顖涙婵℃悂濡疯閺?) + '</span><span class="atom-count">'
      + ((tab.commands || []).length) + '</span>';
    btn.addEventListener('click', () => {
      state.activeTab = tab.id;
      renderAtomTabs();
      renderCommandList();
    });
    wrap.appendChild(btn);
  }
}

function commandMatchesSearch(cmdId, cmd, search) {
  const q = String(search || '').trim().toLowerCase();
  if (!q) return { ok: true, keywordHit: '' };
  const name = String(cmd?.name || '').toLowerCase();
  const desc = String(cmd?.desc || '').toLowerCase();
  const id = String(cmdId || '').toLowerCase();
  if (name.includes(q) || desc.includes(q) || id.includes(q))
    return { ok: true, keywordHit: '' };
  for (const kw of cmd?.keywords || []) {
    const k = String(kw || '').toLowerCase();
    if (!k) continue;
    if (k.includes(q) || q.includes(k))
      return { ok: true, keywordHit: kw };
  }
  return { ok: false, keywordHit: '' };
}

function renderCommandList() {
  const container = document.getElementById('cmd-list');
  const search = String(state.search || '').trim();
  container.innerHTML = '';
  let total = 0;

  ensureActiveScenarioAndTab();
  const scenario = getScenarioById(state.filter);
  if (!scenario) {
    document.getElementById('cmd-count').textContent = '0 婵犵數濮烽弫鍛婃叏閻戣棄鏋侀柟闂寸绾惧鏌ｉ幇顒佹儓闁搞劌鍊块弻娑㈩敃閿濆棛顦ョ紓浣哄Т缂嶅﹪寮诲澶婁紶闁告洦鍋€閸嬫挻绻濆銉㈠亾閸涙潙鐭楀璺虹灱閻﹀牊绻濋悽闈浶㈤柛濠勭帛閺呭爼寮撮悩鐢碉紲闂佺粯锕㈠褔鍩㈤崼銉︾厸閻忕偟鏅晥闂佺硶鏂侀崜婵嬪箯閸涙潙宸濆┑鐘插枤閸熲偓婵?;
    container.appendChild(mkEl('div', 'no-command-found', '[NO COMMAND FOUND]'));
    state.lastFilteredCmdIds = [];
    return;
  }

  const targetTabs = state.activeTab === 'all'
    ? (scenario.tabs || [])
    : (scenario.tabs || []).filter((tab) => tab.id === state.activeTab);

  state.lastFilteredCmdIds = [];
  for (const tab of targetTabs) {
    const visibleCmds = (tab.commands || []).filter((cmdId) => {
      const cmd = state.commands[cmdId];
      if (!cmd) return false;
      return commandMatchesSearch(cmdId, cmd, search).ok;
    });
    if (visibleCmds.length === 0) continue;

    if (state.activeTab === 'all') {
      const hdr = mkEl('div', 'cmd-group-header', tab.name);
      container.appendChild(hdr);
    }

    for (const cmdId of visibleCmds) {
      const hit = commandMatchesSearch(cmdId, state.commands[cmdId], search).keywordHit;
      container.appendChild(makeCmdRow(cmdId, search, hit));
      state.lastFilteredCmdIds.push(cmdId);
      total++;
    }
  }

  document.getElementById('cmd-count').textContent = total + ' 婵犵數濮烽弫鍛婃叏閻戣棄鏋侀柟闂寸绾惧鏌ｉ幇顒佹儓闁搞劌鍊块弻娑㈩敃閿濆棛顦ョ紓浣哄Т缂嶅﹪寮诲澶婁紶闁告洦鍋€閸嬫挻绻濆銉㈠亾閸涙潙鐭楀璺虹灱閻﹀牊绻濋悽闈浶㈤柛濠勭帛閺呭爼寮撮悩鐢碉紲闂佺粯锕㈠褔鍩㈤崼銉︾厸閻忕偟鏅晥闂佺硶鏂侀崜婵嬪箯閸涙潙宸濆┑鐘插枤閸熲偓婵?;
  if (total === 0) {
    container.appendChild(mkEl('div', 'no-command-found', '[NO COMMAND FOUND]'));
  } else if (total === 1) {
    const onlyId = state.lastFilteredCmdIds[0];
    const binding = state.bindings[onlyId];
    if (binding?.explicitNone) return;
    if (binding?.ahkKey) triggerKeyRipple(binding.ahkKey);
    else if (state.suggestedBindings[onlyId]) triggerKeyRipple(state.suggestedBindings[onlyId]);
  }
}

function findRouteByCommand(cmdId) {
  return state.commandRoutes?.[cmdId] || null;
}

function focusCommandById(cmdId) {
  if (!cmdId || !state.commands[cmdId]) return false;
  const route = findRouteByCommand(cmdId);
  if (route) {
    state.filter = route.scenarioId;
    state.activeTab = route.tabId;
  } else if (state.scenarios.length) {
    state.filter = state.scenarios[0].id;
    state.activeTab = 'all';
  }
  state.focusedCmdId = cmdId;
  renderSidebar();
  renderAtomTabs();
  renderCommandList();
  renderKeyboardSlots();
  renderModifierKeys();
  const row = document.querySelector(`.cmd-row[data-cmd-id="${CSS.escape(cmdId)}"]`);
  if (row) {
    row.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    row.classList.remove('flash-jump');
    void row.offsetWidth;
    row.classList.add('flash-jump');
    setTimeout(() => row.classList.remove('flash-jump'), 620);
  }
  const key = state.bindings[cmdId]?.explicitNone ? '' : (state.bindings[cmdId]?.ahkKey || state.suggestedBindings[cmdId] || '');
  if (key) triggerKeyRipple(key);
  return true;
}

function makeCmdRow(cmdId, searchText, keywordHit) {
  const cmd     = state.commands[cmdId] || { name: cmdId, desc: '' };
  const binding = state.bindings[cmdId];
  const isNone = !!(binding?.explicitNone);
  const hasReal = !!(binding?.ahkKey);
  const hasSuggested = !!(state.suggestedBindings[cmdId]) && !hasReal && !isNone;
  const hasBind = hasReal || hasSuggested;
  const isRec   = state.recording === cmdId;

  const row = document.createElement('div');
  const isFocused = state.focusedCmdId === cmdId;
  row.className = 'cmd-row'
    + (hasBind ? ' has-binding' : '')
    + (isRec ? ' recording' : '')
    + (isFocused ? ' active-focus' : '')
    + (hasReal ? ' binding-custom' : hasSuggested ? ' binding-suggested' : isNone ? ' binding-none' : '');
  row.dataset.cmdId = cmdId;
  row.addEventListener('click', () => {
    state.focusedCmdId = cmdId;
    renderCommandList();
    renderKeyboardSlots();
    renderModifierKeys();
    const b = state.bindings[cmdId];
    const key = b?.explicitNone ? '' : (b?.ahkKey || state.suggestedBindings[cmdId] || '');
    if (key) triggerKeyRipple(key);
  });

  const nameEl = document.createElement('div');
  nameEl.className = 'cmd-name';
