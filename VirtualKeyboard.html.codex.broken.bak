  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 10px;
  padding: 8px 14px 8px;
  min-height: 42px;
  margin: 6px 8px 4px;
  border: 1px solid rgba(255,170,94,.28);
  border-radius: 12px;
  background: linear-gradient(180deg, rgba(255,171,92,.05), rgba(255,171,92,0)), var(--surface2);
  box-shadow: 0 10px 24px rgba(0,0,0,.36);
  overflow: hidden;
}
#hud::after {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: inherit;
  padding: 1px;
  background: linear-gradient(135deg, rgba(255,178,108,.28), rgba(255,154,82,.1) 46%, rgba(255,171,92,.16));
  -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  pointer-events: none;
  opacity: .72;
}
