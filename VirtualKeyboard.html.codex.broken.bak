#dashboard-container {
  flex: 0 0 auto;
  height: auto;
  min-height: 0;
  max-height: none;
  padding: 10px 12px 12px;
  background: linear-gradient(180deg, rgba(20,20,20,.92), rgba(10,10,10,.96));
  border-bottom: 1px solid var(--border);
  position: relative;
  overflow: hidden;
}
#dashboard-container.layout-2 {
  padding: 4px 10px 6px;
}
#dashboard-container.layout-2 #dashboard-toolbar {
  margin-bottom: 4px;
}
#dashboard-container.layout-2 #dashboard-title {
  font-size: 9px;
  letter-spacing: 1.4px;
  margin-bottom: 0;
}
#dashboard-title {
  font-family: var(--font);
  font-size: 10px;
  letter-spacing: 2.2px;
  color: var(--text-dim);
  margin: 0 0 10px 2px;
  text-shadow: 0 0 10px rgba(230,126,34,.18);
}
#dashboard-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  margin-bottom: 10px;
}
#dashboard-layout-switch {
  display: flex;
  gap: 6px;
  justify-content: center;
  flex-wrap: wrap;
}
.dashboard-layout-btn {
  border: 1px solid var(--border2);
  border-radius: 6px;
  background: #171717;
  color: var(--text-dim);
  font-family: var(--font);
  font-size: 10px;
  padding: 3px 8px;
  cursor: pointer;
  transition: .12s ease;
}
.dashboard-layout-btn:hover {
  color: var(--orange-lt);
  border-color: var(--orange);
}
.dashboard-layout-btn.active {
  color: var(--orange-lt);
  border-color: var(--orange);
  box-shadow: var(--glow);
}
#dashboard-grid {
  display: grid;
  grid-template-columns: repeat(var(--dashboard-cols, 4), minmax(0, 1fr));
  gap: clamp(6px, .65vw, 10px);
  height: auto;
  overflow: visible;
  padding-right: 0;
  align-content: start;
  justify-content: stretch;
}
#dashboard-grid::-webkit-scrollbar { width: 6px; }
#dashboard-grid::-webkit-scrollbar-track { background: transparent; }
#dashboard-grid::-webkit-scrollbar-thumb {
  background: rgba(230,126,34,.35);
  border-radius: 6px;
}
#dashboard-grid::-webkit-scrollbar-thumb:hover {
  background: rgba(243,156,18,.65);
}
#dashboard-grid.layout-1 { --dashboard-cols: 10; }
#dashboard-grid.layout-2 { --dashboard-cols: 10; }
#dashboard-grid.layout-multi { --dashboard-cols: 20; }
#dashboard-grid.layout-2 {
  grid-template-columns: repeat(10, minmax(0, 1fr));
  justify-content: stretch;
  gap: 4px;
}
#dashboard-grid.layout-2 .dashboard-slot {
  aspect-ratio: auto;
  height: clamp(24px, 3.2vh, 34px);
  border-radius: 7px;
}
.dashboard-slot {
  position: relative;
  width: 100%;
  height: auto;
  aspect-ratio: 1 / 1;
  min-width: 0;
  min-height: 0;
  border: 1px dashed rgba(230,126,34,.55);
  border-radius: 10px;
  background: radial-gradient(90% 90% at 15% 10%, rgba(230,126,34,.10), rgba(0,0,0,0) 55%),
              linear-gradient(180deg, rgba(20,20,20,.68), rgba(10,10,10,.84));
  box-shadow: 0 0 0 1px rgba(0,0,0,.35) inset;
  overflow: hidden;
  transition: border-color .12s ease, box-shadow .12s ease, background .12s ease, transform .12s ease;
}
.dashboard-slot.is-empty {
  background: radial-gradient(90% 90% at 15% 10%, rgba(230,126,34,.08), rgba(0,0,0,0) 55%),
              linear-gradient(180deg, rgba(18,18,18,.72), rgba(8,8,8,.9));
}
.dashboard-slot::after {
  content: '';
  position: absolute; inset: 0;
  background: linear-gradient(135deg, rgba(230,126,34,.18), rgba(0,0,0,0) 42%);
  opacity: 0;
  transition: opacity .12s ease;
  pointer-events: none;
}
.dashboard-slot:hover {
  border-color: rgba(243,156,18,.95);
  box-shadow: var(--glow), 0 0 0 1px rgba(243,156,18,.28) inset;
  transform: translateY(-1px);
}
.dashboard-slot:hover::after { opacity: .55; }
#dashboard-container.drop-active .dashboard-slot.is-empty {
  animation: dashboardSlotBreath 1.5s ease-in-out infinite;
  border-color: rgba(243,156,18,.82);
  box-shadow: 0 0 0 1px rgba(243,156,18,.26) inset, 0 0 18px rgba(230,126,34,.22);
}
#dashboard-container.drop-active .dashboard-slot.is-empty::after {
  opacity: .48;
}
.dashboard-slot.sortable-ghost {
  opacity: .65;
  border-style: solid;
  border-color: rgba(0,212,255,.55);
}
.dashboard-slot.sortable-chosen {
  box-shadow: var(--glow-hot), 0 0 0 1px rgba(230,126,34,.35) inset;
}
.dashboard-item {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  justify-content: space-between;
  padding: 8px;
  text-align: left;
  font-family: var(--font-ui);
  font-size: 12px;
  font-weight: 700;
  line-height: 1.2;
  letter-spacing: .3px;
  color: var(--text);
  background:
    radial-gradient(120% 120% at 18% 14%, rgba(255,183,77,.14), rgba(0,0,0,0) 38%),
    linear-gradient(180deg, rgba(230,126,34,.24), rgba(0,0,0,.08));
  cursor: grab;
  user-select: none;
  position: relative;
}
.dashboard-item::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(255,255,255,.03), rgba(255,255,255,0));
  pointer-events: none;
}
.dashboard-item {
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  min-height: 100%;
  padding: 4px;
}
.dashboard-item-main {
  width: 100%;
}
.dashboard-item-icon {
  min-width: 28px;
  min-height: 28px;
  padding: 0 8px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 9px;
  background: linear-gradient(180deg, rgba(255,164,64,.28), rgba(98,44,0,.34));
  box-shadow: 0 0 0 1px rgba(255,182,106,.2) inset, 0 0 16px rgba(230,126,34,.16);
  color: #fff1dc;
  font-size: 13px;
  font-family: var(--font);
  letter-spacing: .6px;
}
.dashboard-item-label {
  width: 100%;
  color: var(--text);
  font-weight: 700;
  line-height: 1;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: clamp(10px, 1.2vw, 14px);
}
.dashboard-item-tooltip {
  position: absolute;
  left: 50%;
  bottom: calc(100% + 8px);
  transform: translateX(-50%) translateY(4px);
  min-width: 120px;
  max-width: 220px;
  padding: 7px 9px;
  border: 1px solid rgba(255,180,106,.42);
  border-radius: 10px;
  background: linear-gradient(180deg, rgba(28,16,8,.96), rgba(10,10,10,.98));
  color: #fff0dd;
  box-shadow: 0 10px 26px rgba(0,0,0,.42), 0 0 20px rgba(230,126,34,.18);
  font-size: 11px;
  line-height: 1.35;
  opacity: 0;
  pointer-events: none;
  transition: opacity .14s ease, transform .14s ease;
  z-index: 8;
}
.dashboard-item:hover .dashboard-item-tooltip {
  opacity: 1;
  transform: translateX(-50%) translateY(0);
}
.dashboard-tooltip-name {
  display: block;
  font-weight: 800;
  color: #fff6ea;
}
.dashboard-tooltip-hint {
  display: block;
  margin-top: 4px;
  color: #ffcc98;
  font-size: 10px;
}
#dashboard-grid.layout-1 .dashboard-item { padding: 8px; }
#dashboard-grid.layout-1 .dashboard-item-icon { min-width: 30px; min-height: 30px; font-size: 14px; }
#dashboard-grid.layout-1 .dashboard-item-label { font-size: 11px; }
#dashboard-grid.layout-2 .dashboard-item { padding: 7px; }
#dashboard-grid.layout-2 .dashboard-item-icon { min-width: 28px; min-height: 28px; font-size: 13px; }
#dashboard-grid.layout-2 .dashboard-item-label { font-size: 10px; }
#dashboard-grid.layout-2 .dashboard-item {
  padding: 2px 3px;
}
#dashboard-grid.layout-2 .dashboard-item-label {
  font-size: 8px;
  line-height: 1.05;
  white-space: normal;
  overflow: hidden;
  text-overflow: clip;
  word-break: break-all;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
}
#dashboard-grid.layout-multi .dashboard-item { padding: 4px; }
#dashboard-grid.layout-multi .dashboard-item-main { gap: 3px; }
#dashboard-grid.layout-multi .dashboard-item-icon {
  min-width: 22px;
  min-height: 22px;
  padding: 0 5px;
  font-size: 10px;
  border-radius: 7px;
}
#dashboard-grid.layout-multi .dashboard-item-label {
  font-size: clamp(8px, 0.9vw, 10px);
  line-height: 1.1;
}
#dashboard-grid.layout-multi .dashboard-item-hint {
  font-size: 7px;
  padding: 2px 4px;
}
.dashboard-drag-ghost {
  opacity: .92 !important;
  border-color: rgba(255,172,74,.55) !important;
  background: linear-gradient(180deg, rgba(255,156,40,.16), rgba(68,26,0,.10)) !important;
  box-shadow: 0 4px 14px rgba(255,132,24,.16), 0 0 0 1px rgba(255,196,124,.20) inset !important;
  transform: none !important;
}
.dashboard-drag-chosen {
  box-shadow: 0 2px 10px rgba(255,137,26,.14), 0 0 0 1px rgba(255,186,112,.2) inset !important;
}
.dashboard-item.dashboard-dragging {
  transform: none;
}
.k.dashboard-dragging {
  transform: none !important;
}
.k.drag-invalid {
  animation: invalidKeyShake .26s ease;
  box-shadow: 0 0 0 1px rgba(255,78,78,.35) inset, 0 0 18px rgba(255,64,64,.42) !important;
}
.k.drag-invalid::after {
  opacity: .38;
  background: radial-gradient(circle at center, rgba(255,84,84,.35), rgba(255,84,84,0) 70%);
}
@keyframes dashboardSlotBreath {
  0%, 100% { transform: translateY(0) scale(1); }
  50% { transform: translateY(-1px) scale(1.03); }
}
@keyframes invalidKeyShake {
  0%, 100% { transform: translateX(0); }
  20% { transform: translateX(-2px); }
  40% { transform: translateX(2px); }
  60% { transform: translateX(-1px); }
  80% { transform: translateX(1px); }
}
.dashboard-item:active { cursor: grabbing; }
.dashboard-item[data-cmd-id=""] { opacity: .75; }
#dashboard-context-menu {
  position: fixed;
  display: none;
  min-width: 168px;
  background: #121212;
  border: 1px solid var(--orange);
  border-radius: 8px;
  box-shadow: var(--glow-hot), 0 8px 22px rgba(0, 0, 0, .45);
  padding: 6px;
  z-index: 12000;
}
#dashboard-context-menu.open { display: block; }
.dashboard-menu-item {
  width: 100%;
  border: 0;
  background: transparent;
  color: var(--text);
  text-align: left;
  padding: 6px 8px;
  border-radius: 6px;
  cursor: pointer;
  font-size: 11px;
}
.dashboard-menu-item:hover {
  background: #2a1a00;
  color: var(--orange-lt);
}
.dashboard-menu-item:disabled {
  opacity: .35;
  cursor: not-allowed;
  background: transparent;
  color: #9a8a74;
}
#dashboard-float-dock {
  position: fixed;
  right: 10px;
  top: 90px;
  z-index: 11500;
  display: none;
  flex-direction: column;
  gap: 7px;
  max-width: 180px;
}
.dashboard-float-btn {
  border: 1px solid rgba(255,150,64,.5);
  background: linear-gradient(180deg, rgba(28,15,5,.92), rgba(8,8,8,.95));
  color: #ffe8ca;
  border-radius: 10px;
  padding: 7px 9px;
  cursor: pointer;
  font-size: 11px;
  text-align: left;
  box-shadow: 0 0 18px rgba(255,137,26,.2), 0 0 0 1px rgba(255,180,96,.16) inset;
  transition: transform .12s ease, box-shadow .12s ease, border-color .12s ease;
}
.dashboard-float-btn:hover {
  transform: translateY(-1px);
  border-color: rgba(255,190,120,.75);
  box-shadow: 0 0 24px rgba(255,137,26,.32), 0 0 0 1px rgba(255,198,126,.28) inset;
}
.dashboard-float-btn .float-glyph {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 20px;
  height: 20px;
  margin-right: 6px;
  border-radius: 7px;
  background: rgba(255,160,64,.22);
  font-weight: 800;
  font-size: 10px;
}
.dashboard-float-btn .float-name {
  display: inline;
  font-weight: 700;
}
#dashboard-overwrite-overlay {
  position: fixed;
  inset: 0;
  display: none;
  align-items: center;
  justify-content: center;
  background: rgba(0,0,0,.62);
  backdrop-filter: blur(2px);
  z-index: 13000;
}
#dashboard-overwrite-overlay.visible { display: flex; animation: fadeIn .15s ease; }
#dashboard-overwrite-modal {
  width: min(460px, calc(100vw - 36px));
  background: linear-gradient(180deg, #151515, #0d0d0d);
  border: 1px solid #e67e22;
  border-radius: 14px;
  box-shadow: 0 0 0 1px rgba(255,176,89,.12) inset, 0 18px 48px rgba(0,0,0,.55), 0 0 34px rgba(230,126,34,.26);
  padding: 16px;
}
#dashboard-overwrite-modal .modal-title { margin-bottom: 10px; }
#dashboard-overwrite-modal .modal-body {
  color: #f3e2c9;
  font-size: 14px;
  line-height: 1.55;
  margin-bottom: 14px;
}
#dashboard-overwrite-modal .modal-actions {
  display: flex;
  justify-content: flex-end;
  gap: 10px;
}
#dashboard-edit-overlay {
  position: fixed;
  inset: 0;
  display: none;
  align-items: center;
  justify-content: center;
  background: rgba(0,0,0,.62);
  backdrop-filter: blur(2px);
  z-index: 13100;
}
#dashboard-edit-overlay.visible { display: flex; animation: fadeIn .15s ease; }
#dashboard-edit-modal {
  width: min(500px, calc(100vw - 34px));
  border: 1px solid #e67e22;
  border-radius: 14px;
  padding: 16px;
  background: linear-gradient(180deg, #151515, #0d0d0d);
  box-shadow: 0 0 0 1px rgba(255,176,89,.12) inset, 0 18px 48px rgba(0,0,0,.55), 0 0 34px rgba(230,126,34,.26);
}
.dashboard-edit-field { margin-bottom: 10px; }
.dashboard-edit-label {
  display: block;
  color: #e8b984;
  font-size: 12px;
  margin-bottom: 5px;
}
.dashboard-edit-input {
  width: 100%;
  box-sizing: border-box;
  border: 1px solid rgba(255,160,74,.45);
  background: rgba(18,12,8,.82);
  color: #f8ead5;
  border-radius: 9px;
  padding: 7px 9px;
  outline: none;
  font-size: 13px;
}
.dashboard-edit-input:focus {
  border-color: rgba(255,184,112,.95);
  box-shadow: 0 0 0 1px rgba(255,184,112,.22) inset, 0 0 16px rgba(255,130,30,.24);
}
</style>
<script src="https://app.local/assets/js/BasePanel.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>
</head>
