#conflict-overlay {
  display: none;
  position: fixed; inset: 0; z-index: 8888;
  background: rgba(0,0,0,.75);
  backdrop-filter: blur(2px);
  align-items: center; justify-content: center;
}
#conflict-overlay.visible { display: flex; animation: fadeIn .15s ease; }
@keyframes fadeIn { from { opacity:0; } to { opacity:1; } }
#conflict-modal {
  background: var(--surface2);
  border: 1px solid var(--warning-gold);
  border-top-width: 3px;
  box-shadow: var(--glow-gold), 0 8px 40px rgba(0,0,0,.8);
  border-radius: 6px;
  padding: 24px 28px 20px;
  min-width: 380px; max-width: 480px;
  font-family: var(--font);
}
#conflict-modal .modal-title {
  font-size: 11px;
  letter-spacing: 2px;
  font-weight: 700;
  color: var(--warning-gold);
  text-shadow: var(--glow-gold);
  margin-bottom: 14px;
}
#conflict-modal .modal-body {
  font-size: 12px;
  line-height: 1.7;
  color: var(--text-dim);
  font-family: var(--font-ui);
  margin-bottom: 20px;
}
#conflict-modal .modal-body strong {
  color: var(--text);
  font-family: var(--font);
}
#conflict-modal .modal-actions {
  display: flex; gap: 10px; justify-content: flex-end;
}
.modal-btn {
  font-family: var(--font);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 1px;
  padding: 5px 18px;
  border-radius: 3px;
  cursor: pointer;
  transition: box-shadow .15s, color .15s;
  border: 1px solid;
}
.modal-btn.confirm {
  color: var(--warning-gold);
  border-color: var(--warning-gold);
  background: #1a1200;
}
.modal-btn.confirm:hover { box-shadow: var(--glow-gold); }
.modal-btn.cancel {
  color: var(--text-dim);
  border-color: var(--border2);
  background: transparent;
}
.modal-btn.cancel:hover { color: var(--text); border-color: var(--border2); }

