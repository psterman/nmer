  if (state.recording) stopRecording();
  state.recording = cmdId;
  renderCommandList();
  // highlight corresponding key on keyboard if already bound
  if (state.bindings[cmdId]?.ahkKey) {
    const ak = state.bindings[cmdId].ahkKey;
    if (ak === '^^' || ak === '++' || ak === '!!') {
      doubleAhkToKeys(ak).forEach((k) => {
        document.querySelector(`.k[data-ahkkey="${CSS.escape(k)}"]`)?.classList.add('recording-target');
      });
    } else {
      const baseKey = ak.replace(/[\^!+]/g, '');
      document.querySelector(`.k[data-ahkkey="${CSS.escape(baseKey)}"]`)
        ?.classList.add('recording-target');
    }
  }
  setHud('MODE: CONFIG | RECORDING: ' + (state.commands[cmdId]?.name || cmdId) + ' | SINGLE OR DOUBLE-TAP');
  postToAhk({ type: 'startRecord', commandId: cmdId });
}

function stopRecording(restoreHud = true) {
  document.querySelectorAll('.k.recording-target').forEach(e => e.classList.remove('recording-target'));
  const wasRecording = state.recording != null;
  state.recording = null;
  renderCommandList();
  if (wasRecording)
    postToAhk({ type: 'cancelRecord' });
  if (restoreHud)
    updateHudSnapshot();
}

