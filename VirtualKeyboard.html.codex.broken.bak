.kb-right-rail-stack {
  grid-column: 2;
  grid-row: 1 / -1;
  display: flex;
  flex-direction: column;
  gap: 1px;
  width: 100%;
  min-width: 0;
  align-self: stretch;
  justify-content: flex-start;
}
.kb-rail-prt {
  display: flex;
  flex-wrap: nowrap;
  gap: 2px;
  width: 100%;
}
.kb-rail-prt > .k {
  flex: 1 1 0;
  min-width: 0;
  padding: 0 2px;
  font-size: 7px;
}
.kb-nav-cluster {
  display: flex;
  flex-direction: column;
  gap: 1px;
  width: 100%;
}
.kb-nav-cluster .kr {
  display: flex;
  flex-wrap: nowrap;
  gap: 2px;
  width: 100%;
}
.kb-nav-cluster .kr-nav > .k {
  flex: 1 1 0;
  min-width: 0;
  padding: 0 2px;
  font-size: 7px;
}
