￠弻娑氫沪閸撗勫櫘濡炪倧璁ｇ粻鎾诲蓟閻斿搫鏋堥柛妤冨仒閸犲﹤螖閻橀潧浠滈柨鏇樺妿缁鈽夊Ο閿嬵潔濠电偛妫楃换瀣姳閻㈠憡鈷掑ù锝堝Г绾爼鏌涢悩铏鞍闁逛究鍔戦獮姗€顢欓悡搴℃尋闂備線娼чˇ顐﹀疾濠婂牊鍋傞柕澶嗘櫆閻撶喖鏌￠崒娑橆嚋闁诡垰鐗忛埀顒佺⊕缁诲嫮妲愰幘瀛樺闁告繂瀚呴敐澶嬬厽闁冲搫锕ら悘锔锯偓娈垮枛椤嘲顕ｉ幘顔藉亜闁惧繐婀卞Σ鍥⒒婵犲骸浜滄繛璇у缁瑩骞掑Δ濠冩櫅閻庡箍鍎遍ˇ浼村煕閹寸姷纾藉ù锝堫嚃閻掔晫绱掗悩宕囧ⅹ闁宠鍨块幃娆戞嫚瑜嶆导鎰渻閵堝骸浜滅紒缁樏悾鐑筋敃閿曗偓缁€瀣亜閹捐泛鏋戞い鏃€娲熷缁樻媴鐟欏嫬浠╅梺绋垮缁挸鐣峰鈧垾锕傚箣閻橆偄浜鹃梺顒€绉甸埛鎺楁煕鐏炲墽鎳呮い锔肩畵閺岀喓鎷犺缁♀偓閻庢鍠栭…閿嬩繆濮濆矈妲奸悗瑙勬礀瀵埖绌辨繝鍥舵晬婵炲棙甯╅崝鍛存⒑閹肩偛鈧牕煤閻旂厧钃熼柨娑樺濞岊亪鎮归崶銊ョ祷濠殿喖閰ｅ娲寠婢跺﹥娈堕梺鍝ュУ閻楃姴顕ｆ繝姘嵆闁绘棃顥撶粣鐐烘⒑閸撴彃浜濈紒璇插€归幈銊╁閵堝棌鎷?function handleAhkMessage(msg) {
function handleAhkMessage(msg) {
  switch (msg.type) {
    case 'focus_input': {
      const input = document.getElementById('cmd-search');
      if (input) input.focus();
      break;
    }
    case 'init':
      handleInit(msg);
      break;
    case 'dashboardConfig':
      applyDashboardConfig(msg.dashboardConfig, msg.dashboardLayout || dashboardLayout);
      break;
    case 'bindingUpdated':
      handleBindingUpdated(msg);
      break;
    case 'setHud':
      setHud(msg.message);
      break;
    case 'modifierState':
      state.activeMods = {
        ctrl: !!msg.ctrl,
        alt: !!msg.alt,
        shift: !!msg.shift,
      };
      renderModifierKeys();
      renderKeyboardSlots();
      break;
    case 'keyPreview': {
      const base = msg.base;
      const phase = msg.phase;
      if (!base) break;
      trackAhkPreview(base, phase);
      const el = document.querySelector(`.k[data-ahkkey="${CSS.escape(base)}"]`);
      if (!el) break;
      if (phase === 'down')
        el.classList.add('key-live');
      else if (phase === 'up')
        el.classList.remove('key-live');
      break;
    }
    case 'keyPreviewClear':
      document.querySelectorAll('.k.key-live').forEach((e) => e.classList.remove('key-live'));
      break;
    case 'recordHint':
      if (msg.active) {
        state.recording = msg.commandId || state.recording;
        renderCommandList();
        setHud('MODE: CONFIG | SELECTED: ' + state.recording + ' | PRESS KEY OR DOUBLE-TAP');
      } else {
        stopRecording(false);
      }
      break;
    case 'recordPending': {
      const d = (msg.displayKey != null && msg.displayKey !== '') ? String(msg.displayKey) : '(key)';
      const w = typeof msg.waitMs === 'number' ? msg.waitMs : 400;
      const sec = (w / 1000).toFixed(1).replace(/\.0$/, '');
      if (msg.kind === 'dblMod')
        setHud('Recording: ' + d + ' | saving binding...');
      else
        setHud('Recording: got "' + d + '" | press another key within ' + sec + 's for combo');
      break;
    }
    case 'quickBindState':
      state.lastActionId = msg.lastActionId || '';
      state.lastActionName = msg.lastActionName || '';
      state.lastActionCurrentKey = msg.lastActionCurrentKey || '';
      state.quickBindActive = !!msg.quickBindActive;
      updateHudSnapshot();
      break;
    case 'bind_success': {
      const cmdName = msg.commandName || msg.commandId || 'Action';
      const disp = msg.displayKey || msg.ahkKey || '';
      flashBindSuccessHud('Bind saved: ' + cmdName + (disp ? ' <- ' + disp : ''));
      break;
    }
    case 'bind_error': {
      const cmdName = state.commands[msg.commandId]?.name || msg.commandId || 'Action';
      const key = msg.displayKey || msg.ahkKey || '';
      const reason = msg.message ? ' (' + msg.message + ')' : '';
      flashBindErrorHud('Bind failed: ' + cmdName + (key ? ' -> ' + key : '') + reason);
      break;
    }
    case 'adminWarning':
      state.adminWarning = msg.message || '';
      renderAdminWarning();
      break;
    case 'confirmConflict':
      handleConfirmConflict(msg);
      break;
    case 'layoutMode':
      state.nativeLayout = !!msg.native;
      updateLayoutToggleUI();
      break;
    default:
      console.warn('[VK] Unknown AHK msg:', msg.type);
  }
}

function displayKeyForCmd(cmdId) {
  const b = state.bindings[cmdId];
  if (b?.explicitNone) return '';
  if (b?.ahkKey) return b.displayKey || b.ahkKey;
  const sk = state.suggestedBindings[cmdId];
  if (sk) {
    const u = (sk.length === 1 && /[a-zA-Z]/.test(sk)) ? sk.toUpperCase() : sk;
    return 'CapsLock+' + u;
  }
  return '-';
}

function rebuildIndexes() {
