  for (const [cmdId, key] of Object.entries(state.suggestedBindings)) {
    const b = state.bindings[cmdId];
    if (b && (b.ahkKey || b.explicitNone)) continue;
    if (key && !state.suggestedByKey[key]) state.suggestedByKey[key] = cmdId;
  }
}

function handleInit(msg) {
  state.categories = msg.categories || [];
  state.commands   = enrichCommands(msg.commands || {});
  state.bindings   = msg.bindings   || {};
  state.suggestedBindings = msg.suggestedBindings || {};
  state.lastActionId = msg.lastActionId || '';
  state.lastActionName = msg.lastActionName || '';
  state.lastActionCurrentKey = msg.lastActionCurrentKey || '';
  state.quickBindActive = !!msg.quickBindActive;
  state.isAdmin = msg.isAdmin !== false;
  state.adminWarning = msg.adminWarning || '';
  state.embeddedHost = msg.embeddedHost !== false;

  buildScenariosFromCategories();
  ensureActiveScenarioAndTab();
  rebuildIndexes();

  applyDashboardConfig(msg.dashboardConfig || [], msg.dashboardLayout || dashboardLayout);

  renderSidebar();
  renderAtomTabs();
  renderCommandList();
  renderKeyboardSlots();
  renderModifierKeys();
  updateHudSnapshot(true);
  renderAdminWarning();
  initDashboardDrag();
}

function handleBindingUpdated(msg) {
  const { commandId, ahkKey, displayKey } = msg;

  if (!commandId) return;

  if (msg.deleted) {
    delete state.bindings[commandId];
  } else if (msg.explicitNone) {
    state.bindings[commandId] = { ahkKey: '', displayKey: '', explicitNone: true };
  } else if (ahkKey) {
    state.bindings[commandId] = { ahkKey, displayKey: displayKey || '' };
  } else {
    delete state.bindings[commandId];
  }

  rebuildIndexes();
  renderCommandList();
  renderKeyboardSlots();
  renderModifierKeys();

  if (commandId === state.lastActionId) {
    syncLastActionCurrentKeyFromBindings();
  }

  const recordFlash = state.recording && commandId === state.recording && !msg.deleted && !msg.explicitNone && ahkKey;
  if (recordFlash) {
    const cmdName = state.commands[commandId]?.name || commandId;
    const disp = displayKey || ahkKey;
    flashBindSuccessHud('Recording saved: ' + cmdName + (disp ? ' <- ' + disp : ''));
  } else {
    updateHudSnapshot();
  }
}

function resolveDashboardLayout(layout) {
  if (String(layout) === '1' || Number(layout) === 1) return 1;
  if (String(layout) === '2' || Number(layout) === 2) return 2;
  return 'multi';
}

function slotsForLayout(layout) {
  const resolved = resolveDashboardLayout(layout);
  if (resolved === 'multi') return 60; // 3闂?* 20闂?  if (resolved === 1) return 10;       // 1闂?* 10闂?  if (resolved === 2) return 20;       // 2闂?* 10闂?  return 60;
}

function normalizeDashboardItem(item) {
  if (!item) return null;
  if (typeof item === 'string') {
    return state.commands[item] ? {
      commandId: item,
      sourceAhkKey: '',
      sourceDisplayKey: '',
      customTitle: '',
      customNote: '',
      customShortcut: '',
    } : null;
  }
  const commandId = item.commandId || item.cmdId || '';
  if (!commandId || !state.commands[commandId]) return null;
  return {
    commandId,
    sourceAhkKey: item.sourceAhkKey || item.ahkKey || '',
    sourceDisplayKey: item.sourceDisplayKey || item.displayKey || '',
    customTitle: item.customTitle || item.title || '',
    customNote: item.customNote || item.note || '',
    customShortcut: item.customShortcut || item.shortcut || '',
  };
}

function normalizeDashboardConfig(rawConfig, layoutHint) {
  const layout = resolveDashboardLayout(rawConfig?.layout || rawConfig?.mode || layoutHint);
  const slotCount = slotsForLayout(layout);
  const slots = Array.from({ length: slotCount }, () => null);
  const rawSlots = Array.isArray(rawConfig)
    ? rawConfig
    : (Array.isArray(rawConfig?.slots) ? rawConfig.slots : []);
  rawSlots.slice(0, slotCount).forEach((item, index) => {
    slots[index] = normalizeDashboardItem(item);
  });
  return { layout, slots };
}

function serializeDashboardConfig() {
  return ensureDashboardStateSize().map((item) => {
    if (!item) return null;
    return {
      commandId: item.commandId,
      sourceAhkKey: item.sourceAhkKey || '',
      sourceDisplayKey: item.sourceDisplayKey || '',
      customTitle: item.customTitle || '',
      customNote: item.customNote || '',
      customShortcut: item.customShortcut || '',
    };
  });
}

function ensureDashboardStateSize(layoutHint) {
  const slotCount = slotsForLayout(layoutHint || dashboardLayout);
  if (!Array.isArray(state.dashboardConfig)) state.dashboardConfig = [];
  const next = Array.from({ length: slotCount }, (_, index) => normalizeDashboardItem(state.dashboardConfig[index]));
  state.dashboardConfig = next;
  return next;
}

function applyDashboardConfig(rawConfig, layoutHint) {
  const normalized = normalizeDashboardConfig(rawConfig, layoutHint || dashboardLayout);
  dashboardLayout = normalized.layout;
  state.dashboardConfig = normalized.slots;
  syncDashboardLayoutUI();
  ensureDashboardSlots();
}

function syncDashboardLayoutUI() {
  const grid = document.getElementById('dashboard-grid');
  const container = document.getElementById('dashboard-container');
  if (!grid) return;
  grid.classList.remove('layout-1', 'layout-2', 'layout-multi');
  grid.classList.add(`layout-${dashboardLayout}`);
  if (container) {
    container.classList.remove('layout-1', 'layout-2', 'layout-multi');
    container.classList.add(`layout-${dashboardLayout}`);
  }
  document.querySelectorAll('.dashboard-layout-btn').forEach((btn) => {
    btn.classList.toggle('active', String(btn.dataset.layout) === String(dashboardLayout));
  });
}

function applyDashboardLayout(layout) {
  dashboardLayout = resolveDashboardLayout(layout);
  ensureDashboardStateSize(dashboardLayout);
  syncDashboardLayoutUI();
  ensureDashboardSlots();
  if (dashboardInited) {
    postToAhk(buildDashboardBridgePayload('dashboardConfig'));
  }
}

function getCommandByElement(el) {
  const mappedCmdId = el?.dataset?.mappedCmdId || '';
  if (mappedCmdId) return mappedCmdId;
  const baseKey = el?.dataset?.ahkkey || '';
  if (!baseKey) return '';
  if (isModifierBaseKey(baseKey)) {
    const dbl = modifierToDoubleAhkKey(baseKey);
    return dbl ? (state.ahkKeyIndex[dbl] || '') : '';
  }
  const activeKey = getActivePrefix() + baseKey;
  if (state.ahkKeyIndex[activeKey]) return state.ahkKeyIndex[activeKey];
  if (state.ahkKeyIndex[baseKey]) return state.ahkKeyIndex[baseKey];

  // Fallback: reverse lookup by same base key under any modifiers.
  for (const [cmdId, b] of Object.entries(state.bindings || {})) {
    const ak = b?.ahkKey || '';
    if (!ak || /^(\^\^|\+\+|!!)$/.test(ak)) continue;
    const base = ak.replace(/[\^!+]/g, '');
    if (base === baseKey) return cmdId;
  }
  for (const [cmdId, ak] of Object.entries(state.suggestedBindings || {})) {
    if (!ak || /^(\^\^|\+\+|!!)$/.test(ak)) continue;
    const base = String(ak).replace(/[\^!+]/g, '');
    if (base === baseKey) return cmdId;
  }
  return '';
}

function ahkBaseToDisplay(baseKey) {
  if (!baseKey) return '-';
  if (baseKey.length === 1) return baseKey.toUpperCase();
  const map = {
    Escape: 'Esc',
    Enter: 'Enter',
    Space: 'Space',
    Tab: 'Tab',
    Backspace: 'Bks',
    Delete: 'Del',
    Insert: 'Ins',
    Home: 'Home',
    End: 'End',
    PgUp: 'PgUp',
    PgDn: 'PgDn',
    Up: 'Up',
    Down: 'Down',
    Left: 'Left',
    Right: 'Right',
    LCtrl: 'Ctrl',
    RCtrl: 'Ctrl',
    LAlt: 'Alt',
    RAlt: 'Alt',
    LShift: 'Shift',
    RShift: 'Shift',
  };
  return map[baseKey] || baseKey;
}

function ahkKeyToDisplayString(ahkKey) {
  if (!ahkKey) return '-';
  if (ahkKey === '^^') return 'Double Ctrl';
  if (ahkKey === '++') return 'Double Shift';
  if (ahkKey === '!!') return 'Double Alt';
  let key = ahkKey;
  const parts = [];
  if (key.includes('^')) {
    parts.push('Ctrl');
    key = key.replace(/\^/g, '');
  }
  if (key.includes('!')) {
    parts.push('Alt');
    key = key.replace(/!/g, '');
  }
  if (key.includes('+')) {
    parts.push('Shift');
    key = key.replace(/\+/g, '');
  }
  parts.push(ahkBaseToDisplay(key));
  return parts.join('+');
}

function getCommandMetaByElement(el) {
  const commandId = getCommandByElement(el);
  if (!commandId) return null;
  const baseKey = el?.dataset?.ahkkey || '';
  if (!baseKey) return null;
  let sourceAhkKey = el?.dataset?.mappedAhkKey || '';
  if (!sourceAhkKey) {
    if (isModifierBaseKey(baseKey))
      sourceAhkKey = modifierToDoubleAhkKey(baseKey);
    else {
      const explicit = state.bindings?.[commandId]?.ahkKey || '';
      const suggested = state.suggestedBindings?.[commandId] || '';
      sourceAhkKey = explicit || suggested || (getActivePrefix() + baseKey);
    }
  }
  return {
    commandId,
    sourceAhkKey,
    sourceDisplayKey: ahkKeyToDisplayString(sourceAhkKey),
  };
}

function dashboardItemFromElement(el) {
  return normalizeDashboardItem({
    commandId: el?.dataset?.cmdId || '',
    sourceAhkKey: el?.dataset?.sourceAhkKey || '',
    sourceDisplayKey: el?.dataset?.sourceDisplayKey || '',
    customTitle: el?.dataset?.customTitle || '',
    customNote: el?.dataset?.customNote || '',
    customShortcut: el?.dataset?.customShortcut || '',
  });
}

function buildDashboardGlyph(name) {
  const clean = String(name || '').replace(/\s+/g, '');
  const cn = clean.match(/[\u4e00-\u9fff]/g);
  if (cn && cn.length >= 2) return cn.slice(0, 2).join('');
  if (cn && cn.length === 1) return cn[0];
  const words = clean.match(/[A-Za-z0-9]+/g) || [];
  if (words.length >= 2) return (words[0][0] + words[1][0]).toUpperCase();
  if (words.length === 1) return words[0].slice(0, 2).toUpperCase();
  return clean.slice(0, 2) || 'GO';
}

function decorateDashboardItem(el, itemLike) {
  const item = normalizeDashboardItem(itemLike);
  if (!item) return;
  const cmd = state.commands[item.commandId] || {};
  const baseName = cmd.name || item.commandId;
  const name = item.customTitle || baseName;
  const hint = item.customShortcut || item.sourceDisplayKey || ahkKeyToDisplayString(item.sourceAhkKey) || displayKeyForCmd(item.commandId);
  const note = item.customNote || '';
  el.className = 'dashboard-item';
  el.dataset.cmdId = item.commandId;
  el.dataset.sourceAhkKey = item.sourceAhkKey || '';
  el.dataset.sourceDisplayKey = item.sourceDisplayKey || hint || '';
  el.dataset.customTitle = item.customTitle || '';
  el.dataset.customNote = item.customNote || '';
  el.dataset.customShortcut = item.customShortcut || '';
  el.removeAttribute('data-ahkkey');
  el.removeAttribute('data-hotkey');
  el.removeAttribute('data-key');
  el.innerHTML = '';

  const main = mkEl('div', 'dashboard-item-main');
  const label = mkEl('div', 'dashboard-item-label', name);
  main.append(label);

  const tooltip = mkEl('div', 'dashboard-item-tooltip');
  const tooltipName = mkEl('span', 'dashboard-tooltip-name', name);
  const tooltipHint = mkEl('span', 'dashboard-tooltip-hint', hint || 'No shortcut');
  tooltip.append(tooltipName, tooltipHint);
  if (note) {
    const tooltipNote = mkEl('span', 'dashboard-tooltip-hint', note);
    tooltip.append(tooltipNote);
  }

  el.append(main, tooltip);
  el.title = `${name}${hint ? ` (${hint})` : ''}${note ? ` - ${note}` : ''}`;
}

function slotIndexFromEl(el) {
  const n = Number(el?.dataset?.slotIndex);
  return Number.isFinite(n) ? n : -1;
}

function getDashboardSlotEl(index) {
  return document.querySelector(`.dashboard-slot[data-slot-index="${index}"]`);
}

function renderDashboardSlot(slot, item, index) {
  if (!slot) return;
  slot.dataset.slotIndex = String(index);
  slot.innerHTML = '';
  slot.classList.toggle('is-empty', !item);
  slot.title = item ? '' : '闂傚倸鍊搁崐鎼佸磹閹间礁纾归柟闂寸绾剧懓顪冪€ｎ亝鎹ｉ柣顓炴闇夐柨婵嗙墛椤忕姷绱掗埀顒佺節閸屾鏂€闂佺粯锚瀵爼骞栭幇顔剧＝濞达絽寮跺▍濠冩叏婵犲啯銇濇い銏☆殜閸┾偓妞ゆ帒鍊婚惌鎾绘煟閵忋埄鐒剧痪鎯ь煼閹鏁愭惔鈥茬暗缂備浇顕уΛ婵嬪蓟閺囥垹閱囨繝闈涙搐濞咃綁姊洪崫鍕棞闁挎洦浜璇测槈濮橈絽浜鹃柨婵嗛娴滄繈鎮樿箛锝呭箺闁靛洤瀚伴、鏇㈡晲閸モ晝鏉芥俊鐐€戦崹娲€冮崱娑樼闁告稑鐡ㄩ埛鎰版煙闁箑骞楅柍缁樻礋濮婄粯鎷呯粵瀣濠殿喗锕粻鎾绘晲閻愭潙绶炲┑鐐村浮缂傛氨绮诲☉妯锋婵☆垳鈷堝Σ鐑芥⒒娴ｄ警鏀伴柟娲讳簼娣囧﹪宕惰閺嗐倕銆掑锝呬壕闂佽鍠楅〃濠囧极閹邦厽鍎熼柍鈺佸暟娴滎亞绱撻崒娆掑厡濠殿喖鐏氱换娑欑節閸パ嗘憰闂佺粯鏌ㄩ崥瀣磹闁垮浜滈柟鍝勬娴滄儳顪冮妶鍐ㄥ姢闁稿鍊濆濠氭偄閸涘﹦绉舵俊銈忕到閸燁垶顢撳澶嬧拺闁规儼濮ら弫閬嶆煕閵娿儲鍋ョ€殿喛顕ч埥澶娢熼柨瀣垫綌婵犳鍠楅〃鍛存偋閸℃ê顕遍柟閭﹀枤绾捐棄霉閿濆懐鐣ù婊呭仱閺屾盯骞囬鈧埛鏃堟煕閻愬灚鏆柟顔煎槻椤劑宕橀鐓庡強闂備線娼уΛ妤呭疮椤栨粍宕叉繝闈涱儏閻愬﹪鏌曟径鍫濈仼濞存粍鍎抽湁闁挎繂鐗嗛埀顑跨矙瀵噣宕煎┑鍫濆Е婵＄偑鍊栫敮鎺斺偓姘煎墴閹€愁潨閳ь剟寮婚悢鍛婄秶闁告挆鍛闂備胶绮崝鏇㈡晝閿曞倸绠熸慨婵嗙灱閻も偓闂佸搫娲ㄦ慨鐑界嵁?;
  if (item) {
    const el = document.createElement('div');
    decorateDashboardItem(el, item);
    slot.appendChild(el);
  }
}

function cleanupDashboardDragPreview() {
  if (state.dragPreviewEl?.parentNode) {
    state.dragPreviewEl.parentNode.removeChild(state.dragPreviewEl);
  }
  state.dragPreviewEl = null;
}

function createDashboardDragPreview(itemLike) {
  cleanupDashboardDragPreview();
  const preview = document.createElement('div');
  preview.style.position = 'fixed';
  preview.style.left = '-9999px';
  preview.style.top = '-9999px';
  preview.style.width = dashboardLayout === 'multi' ? '94px' : '118px';
  preview.style.height = dashboardLayout === 'multi' ? '94px' : '118px';
  preview.style.pointerEvents = 'none';
  preview.style.zIndex = '99999';
  preview.className = 'dashboard-slot';
  preview.classList.remove('is-empty');

  const item = document.createElement('div');
  decorateDashboardItem(item, itemLike);
  item.classList.add('dashboard-drag-ghost');
  preview.appendChild(item);

  document.body.appendChild(preview);
  state.dragPreviewEl = preview;
  return preview;
}

function syncKeyboardDraggableState() {
  document.querySelectorAll('.k').forEach((el) => {
    const isDraggable = !!getCommandMetaByElement(el);
    el.draggable = isDraggable;
    if (isDraggable) {
      el.setAttribute('draggable', 'true');
    } else {
      el.removeAttribute('draggable');
    }
  });
}

function applyDashboardItemToSlot(toIndex, itemLike, fromIndex = -1) {
  const item = normalizeDashboardItem(itemLike);
  const cfg = ensureDashboardStateSize();
  if (!item || toIndex < 0 || toIndex >= cfg.length) return false;

  const priorTarget = cfg[toIndex];
  if (fromIndex >= 0 && fromIndex < cfg.length && fromIndex !== toIndex) {
    cfg[fromIndex] = null;
    renderDashboardSlot(getDashboardSlotEl(fromIndex), null, fromIndex);
  }

  cfg[toIndex] = item;
  renderDashboardSlot(getDashboardSlotEl(toIndex), item, toIndex);

  if (fromIndex >= 0 && fromIndex !== toIndex) {
    postDashboardMove(item, fromIndex, toIndex);
  } else {
    if (priorTarget?.commandId && priorTarget.commandId !== item.commandId) {
      postDashboardRemove(priorTarget, toIndex);
    }
    postDashboardAdd(item, toIndex);
  }
  return true;
}

function swapDashboardSlots(fromIndex, toIndex) {
  const cfg = ensureDashboardStateSize();
  if (fromIndex < 0 || toIndex < 0 || fromIndex === toIndex) return false;
  if (fromIndex >= cfg.length || toIndex >= cfg.length) return false;
  const fromItem = normalizeDashboardItem(cfg[fromIndex]);
  const toItem = normalizeDashboardItem(cfg[toIndex]);
  if (!fromItem) return false;

  cfg[toIndex] = fromItem;
  cfg[fromIndex] = toItem || null;
  renderDashboardSlot(getDashboardSlotEl(toIndex), cfg[toIndex], toIndex);
  renderDashboardSlot(getDashboardSlotEl(fromIndex), cfg[fromIndex], fromIndex);
  postDashboardMove(fromItem, fromIndex, toIndex);
  return true;
}

function getDashboardItemAt(index) {
  const cfg = ensureDashboardStateSize();
  if (index < 0 || index >= cfg.length) return null;
  return normalizeDashboardItem(cfg[index]);
}

function closeDashboardContextMenu() {
  const menu = document.getElementById('dashboard-context-menu');
  if (!menu) return;
  menu.classList.remove('open');
  state.dashboardMenuSlotIndex = -1;
}

function openDashboardContextMenu(x, y, slotIndex) {
  const menu = document.getElementById('dashboard-context-menu');
  if (!menu) return;
  state.dashboardMenuSlotIndex = slotIndex;
  const slotItem = getDashboardItemAt(slotIndex);
  const hasItem = !!slotItem;
  const hasClip = !!normalizeDashboardItem(state.dashboardClipboard);
  menu.querySelectorAll('.dashboard-menu-item').forEach((btn) => {
    const action = btn.dataset.menuAction || '';
    btn.disabled = (action !== 'paste') && !hasItem;
    if (action === 'paste') btn.disabled = !hasClip;
  });
  menu.classList.add('open');
  const maxX = window.innerWidth - menu.offsetWidth - 6;
  const maxY = window.innerHeight - menu.offsetHeight - 6;
  menu.style.left = `${Math.max(6, Math.min(x + 6, maxX))}px`;
  menu.style.top = `${Math.max(6, Math.min(y + 6, maxY))}px`;
}

function closeDashboardEditModal(result) {
  const overlay = document.getElementById('dashboard-edit-overlay');
  if (!overlay) return;
  overlay.classList.remove('visible');
  const resolver = state.dashboardEditResolver;
  state.dashboardEditResolver = null;
  if (resolver) resolver(result || null);
}

function openDashboardEditModal(item) {
  const normalized = normalizeDashboardItem(item);
  if (!normalized) return Promise.resolve(null);
  const overlay = document.getElementById('dashboard-edit-overlay');
  const titleInput = document.getElementById('dashboard-edit-title');
  const noteInput = document.getElementById('dashboard-edit-note');
  const shortcutInput = document.getElementById('dashboard-edit-shortcut');
  const cmd = state.commands[normalized.commandId] || {};
  titleInput.value = normalized.customTitle || cmd.name || normalized.commandId;
  noteInput.value = normalized.customNote || '';
  shortcutInput.value = normalized.customShortcut || normalized.sourceDisplayKey || '';
  overlay.classList.add('visible');
  titleInput.focus();
  titleInput.select();
  return new Promise((resolve) => {
    state.dashboardEditResolver = resolve;
  });
}

function patchDashboardItemAt(index, patch, notify = true) {
  const cfg = ensureDashboardStateSize();
  if (index < 0 || index >= cfg.length) return false;
  const existing = normalizeDashboardItem(cfg[index]);
  if (!existing) return false;
  const next = normalizeDashboardItem(Object.assign({}, existing, patch || {}));
  if (!next) return false;
  cfg[index] = next;
  renderDashboardSlot(getDashboardSlotEl(index), next, index);
  if (notify) postToAhk(buildDashboardBridgePayload('dashboardConfig'));
  return true;
}

async function pasteDashboardClipboardToSlot(slotIndex) {
  const clip = normalizeDashboardItem(state.dashboardClipboard);
  if (!clip) return false;
  const existing = getDashboardItemAt(slotIndex);
  if (existing && existing.commandId !== clip.commandId) {
    const confirm = await confirmDashboardOverwrite(existing, clip);
    if (!confirm) return false;
  }
  applyDashboardItemToSlot(slotIndex, clip, -1);
  setHud(`闂傚倸鍊搁崐鎼佸磹瀹勬噴褰掑炊椤掑鏅悷婊冪Ч閿濈偛鈹戠€ｎ偅娅囬梺绋跨焿婵″洨绮欒箛鏃傜瘈闁靛骏绲介悡鎰版煕閺冣偓閻楃姴鐣烽幋锕€围濠㈣泛顑囬崢鎼佹⒑閹肩偛鍔楅柡鍛☉閻剟姊绘担铏瑰笡閻㈩垱甯￠弫鍐Ψ瑜庡畷鍙夌箾閹存瑥鐏╂鐐灪娣囧﹪顢涘┑鎰闂傚倸顦粔鐟邦潖閾忓湱鐭欓柛顭戝櫘閸斿顪冮妶鍐ㄥ婵☆偅鐟х划姘綇閵娧呯槇闂佹悶鍎撮崺鏍疾椤掆偓閳规垿顢欓弬銈勭返闂佸憡鎸诲畝绋跨暦閹伴偊鏁嶉柣鎰嚟閸樹粙鏌熼崗鑲╂殬闁搞劌鍚嬬粩鐔肺熷Ч鍥︾盎濡炪倖鎸鹃崑娑樜ｇ紒妯镐簻闁哄浂浜炵粔顔锯偓瑙勬礀閵堢顕ｉ幘顔藉€烽柛婵嗗閺嗩亜鈹戦悩鍨毄濠电偐鍋撳┑鐐板尃閸忕偓绋戦悾婵嬪礋椤愩値鍞堕梻浣告啞閸旓附绂嶉悙闈涱棜?{state.commands[clip.commandId]?.name || clip.commandId}`);
  return true;
}

function renderDashboardFloatDock() {
  return;
}

function pinDashboardItem(itemLike) {
  const item = normalizeDashboardItem(itemLike);
  if (!item) return;
  postToAhk({
    type: 'dashboardPin',
    commandId: item.commandId,
    sourceAhkKey: item.sourceAhkKey || '',
    sourceDisplayKey: item.sourceDisplayKey || '',
  });
  setHud(`闂傚倸鍊搁崐鎼佸磹瀹勬噴褰掑炊椤掑鏅悷婊冪Ч濠€渚€姊虹紒妯虹伇婵☆偄瀚划濠氭偐缂佹鍘甸梺纭咁潐閸旓箓宕靛▎鎴犵＜闁绘﹢娼ч弸娑欐叏婵犱胶鐭欑€规洖鐖奸、妤呭焵椤掍緡鏀伴梻鍌欑濠€杈ㄦ櫠濡も偓椤灝螣閼测晝鐒奸梺鍛婂姦閸犳鎮￠崘顔界厱婵犻潧妫楅鈺呮煃瑜滈崜娑⑩€﹂崼銉晪闁挎繂顦柨銈嗕繆閵堝嫯顔夐柟鐤缁辨捇宕掑▎鎴濆闂佹寧鑹鹃埞鎴︻敊閸忕厧鏋犻梺鍝勭灱閸犳捇宕版繝鍥х闁绘劖澹嗛弫鏍磽閸屾瑧璐伴柛鐘崇墵閹囧箻瀹曞洦娈鹃梺鍦劋椤ㄥ棝宕愰悜鑺ュ€甸柣銏☆問閻掗箖鎮介娑樺姢闁宠鍨块幃鈺咁敊閼测晙绱樻繝鐢靛仜椤︿即鎯勯鐐茬畺鐟滄柨鐣烽崡鐐╂婵☆垳鈷堝Σ閿嬬節濞堝灝鏋熼拑鍗烆熆瑜嶉柊锝呯暦閹达箑绠婚柡鍌樺劜閻忎線姊洪崜鑼帥闁哥姵顨婇幃姗€宕煎┑鍐╂杸闂佺粯鍔楅崑锝夊焵椤掆偓椤戝洭骞戦姀鐘斀閻庯綆鍓欑粊锕傛⒑閸涘﹤濮﹂柣鎾崇墕椤洭濡搁埡鍌滃帗閻熸粍绮撳畷婊堟偄閼测晛绁﹂梺鍛婂姂閸斿寮告惔銊︾厵闁诡垎鍜冪礊闂佸憡锚閹诧紕鎹㈠☉娆愮秶闁告挆鍐ㄧ厒闂備焦鎮堕崹娲偂闄囧Λ銏犫攽椤旂瓔鐒鹃柛鈺傜墵閸╂盯骞掑Δ浣哄幈闁诲繒鍋涙晶浠嬪箠閸曨厾纾煎ù锝呮惈椤ｅジ鏌曢崶褍顏€殿喗鎸抽幃銏ゅ传閸曘劍瀚查梺璇叉唉椤煤濡崵绠惧┑鐘叉储閳ь兛绀侀～婵堟崉閾忕懓濮︽俊鐐€栧濠氬磻閹剧粯鐓熼柨婵嗘噹濡茬粯銇勯婊冨鐎规洘锕㈤幃娆擃敆閳ь剟宕楁繝鍥ㄢ拺闁告繂瀚峰Σ鎼佹煟濡も偓鐎氭澘鐣峰┑鍡欐殕闁告洦鍓欐禒褎绻涚€电甯堕柣掳鍔戦崺娑㈠箣閻樼數锛濇繛杈剧到椤牠顢旈崨顔煎伎婵犮垼鍩栭崝鏍偂閺囥垹绠归悗娑欘焽閳藉鏌嶈閸撴氨鎹㈤崒鐑嗘晪?{state.commands[item.commandId]?.name || item.commandId}`);
}

function closeDashboardOverwriteModal(result) {
  const overlay = document.getElementById('dashboard-overwrite-overlay');
  if (!overlay) return;
  overlay.classList.remove('visible');
  const resolver = state.dashboardOverwriteResolver;
  state.dashboardOverwriteResolver = null;
  if (resolver) resolver(!!result);
}

