#keyboard-zone {
  flex: 0 0 auto;
  min-height: 0;
  padding: 2px 8px 2px;
  background: var(--bg);
  border-bottom: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
#bottom-zone {
  flex: 1 1 0;
  min-height: 0;
  display: flex;
  overflow: hidden;
}
#sidebar {
  flex-shrink: 0;
  width: 160px;
  min-width: 0;
  background: var(--surface);
  border-right: 1px solid var(--border);
  overflow-y: auto;
  padding: 6px 0;
  font-size: var(--vk-panel-font);
}
#cmd-panel {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: var(--bg);
  font-size: var(--vk-panel-font);
}
