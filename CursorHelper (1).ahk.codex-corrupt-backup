                ; 寮哄埗 ListView 閲嶇粯浠ユ樉绀鸿嚜瀹氫箟楂樹寒鏁堟灉
                DllCall("InvalidateRect", "Ptr", LV_Hwnd, "Ptr", 0, "Int", 1)
                
                ; 銆愬叧閿慨澶嶃€戜笉杩斿洖浠讳綍鍊硷紝璁╃郴缁熺户缁鐞嗗崟鍑诲拰鍙屽嚮浜嬩欢
                ; 杩斿洖1浼氶樆姝㈠弻鍑讳簨浠剁殑瑙﹀彂锛屽鑷寸浜屽垪鍙婁互鍚庣殑鍗曞厓鏍兼棤娉曞弻鍑绘墦寮€缂栬緫绐楀彛
                ; 鍙栨秷閫変腑鐨勬搷浣滃湪ItemSelect浜嬩欢涓欢杩熸墽琛岋紝浠ョ‘淇濆弻鍑讳簨浠惰兘澶熸甯歌Е鍙?
            }
        }
    } catch as e {
        ; 鍑洪敊鏃惰褰曟棩蹇?
        try {
