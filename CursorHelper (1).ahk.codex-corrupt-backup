    ; 妫€鏌ユ槸鍚︽槸鍓创鏉跨鐞嗙獥鍙ｇ殑娑堟伅
    if (!ClipboardManagerHwnd || Hwnd != ClipboardManagerHwnd) {
        return  ; 涓嶆槸鎴戜滑鐨勭獥鍙ｏ紝涓嶅鐞?
    }
    
    ; 妫€鏌ユ槸鍚︽槸鎴戜滑鐨?ListView 鍙戦€佺殑娑堟伅
    if (!ClipboardListViewHwnd || ClipboardListViewHwnd = 0) {
        return  ; 涓嶆槸鎴戜滑鐨?ListView锛屼笉澶勭悊
    }
    
    ; 鍙湪CapsLockC鏍囩鏃跺鐞?
    if (ClipboardCurrentTab != "CapsLockC") {
        return  ; 涓嶅鐞嗭紝璁╃郴缁熺户缁粯璁ゅ鐞?
    }
    
    try {
        ; 璇诲彇 NMHDR 缁撴瀯
        ; NMHDR 缁撴瀯锛?
        ;   hwndFrom: HWND (A_PtrSize 瀛楄妭)
        ;   idFrom: UINT_PTR (A_PtrSize 瀛楄妭)
        ;   code: UINT (4瀛楄妭)
        ;   瀵归綈濉厖 (64浣嶇郴缁熼渶瑕?瀛楄妭濉厖鍒?瀛楄妭杈圭晫)
        ; 鎬昏锛?4瀛楄妭锛?4浣嶏級鎴?12瀛楄妭锛?2浣嶏級
        HwndFrom := NumGet(lParam, 0, "Ptr")
        
        ; 妫€鏌ユ槸鍚︽槸鎴戜滑鐨?ListView
        if (HwndFrom != ClipboardListViewHwnd) {
            return  ; 涓嶆槸鎴戜滑鐨?ListView锛屼笉澶勭悊
        }
        
        ; 璇诲彇 code 瀛楁
        CodeOffset := A_PtrSize * 2  ; hwndFrom + idFrom
        Code := NumGet(lParam, CodeOffset, "Int")
        
        ; NM_CUSTOMDRAW = -12 (鑷畾涔夌粯鍒?
        if (Code = -12) {
            return HandleClipboardListViewCustomDraw(lParam)
        }
        
        ; NM_DBLCLICK = -3 (鐢ㄦ埛鍙屽嚮浜?ListView)
        if (Code = -3) {
            return HandleClipboardListViewDoubleClick(lParam)
        }
        
        ; NM_CLICK = -2 (鐢ㄦ埛鐐瑰嚮浜?ListView)
        if (Code = -2) {
            ; 銆愬叧閿慨澶嶃€戜娇鐢?LVM_SUBITEMHITTEST 绮剧‘鑾峰彇鐐瑰嚮鐨勫崟鍏冩牸浣嶇疆
            ; 鍥犱负 NMITEMACTIVATE 鐨?iSubItem 瀛楁鍙兘涓嶅彲闈狅紙鏌愪簺鎯呭喌涓嬫€绘槸0锛?
            ; LVM_SUBITEMHITTEST = 0x1039
            
            ; 鑾峰彇褰撳墠榧犳爣浣嶇疆锛堝睆骞曞潗鏍囷級
            POINT := Buffer(8, 0)
            DllCall("GetCursorPos", "Ptr", POINT.Ptr)
            MouseX := NumGet(POINT, 0, "Int")
            MouseY := NumGet(POINT, 4, "Int")
            
            ; 灏嗗睆骞曞潗鏍囪浆鎹负ListView瀹㈡埛绔潗鏍?
            LV_Hwnd := ClipboardListViewHwnd
            DllCall("ScreenToClient", "Ptr", LV_Hwnd, "Ptr", POINT.Ptr)
            ClientX := NumGet(POINT, 0, "Int")
            ClientY := NumGet(POINT, 4, "Int")
            
            ; 鍑嗗 LVHITTESTINFO 缁撴瀯
            ; LVHITTESTINFO (64浣?锛?
            ;   POINT pt (8瀛楄妭)
            ;   UINT flags (4瀛楄妭)
            ;   int iItem (4瀛楄妭)
            ;   int iSubItem (4瀛楄妭) - 杩欐槸鎴戜滑闇€瑕佺殑锛?
            ;   int iGroup (4瀛楄妭)
            ; 鎬昏锛?4瀛楄妭
            LVHITTESTINFO := Buffer(24, 0)
            NumPut("Int", ClientX, LVHITTESTINFO, 0)   ; pt.x
            NumPut("Int", ClientY, LVHITTESTINFO, 4)   ; pt.y
            
            ; 璋冪敤 LVM_SUBITEMHITTEST 鑾峰彇绮剧‘鐨勮鍜屽垪绱㈠紩
            Result := DllCall("SendMessage", "Ptr", LV_Hwnd, "UInt", 0x1039, "Ptr", 0, "Ptr", LVHITTESTINFO.Ptr, "Int")
            
            ; 璇诲彇缁撴灉锛堟敞鎰忥細iItem 鍜?iSubItem 閮芥槸浠?0 寮€濮嬬殑锛?
            flags := NumGet(LVHITTESTINFO, 8, "UInt")       ; 鍛戒腑娴嬭瘯鏍囧織
            iItem := NumGet(LVHITTESTINFO, 12, "Int")       ; 琛岀储寮曪紙浠?寮€濮嬶級
            iSubItem := NumGet(LVHITTESTINFO, 16, "Int")    ; 鍒楃储寮曪紙浠?寮€濮嬶級
            
            ; 銆愯皟璇曟棩蹇椼€戣褰曠偣鍑讳綅缃拰璇︾粏淇℃伅
            try {
                FileAppend("[" . FormatTime(, "yyyy-MM-dd HH:mm:ss") . "] Click: ClientX=" . ClientX . ", ClientY=" . ClientY . ", Result=" . Result . ", flags=0x" . Format("{:X}", flags) . ", iItem=" . iItem . ", iSubItem=" . iSubItem . "`n", A_ScriptDir "\clipboard_debug.log")
            } catch as err {
            }
            
            ; 杞崲涓轰粠1寮€濮嬬殑绱㈠紩
            RowIndex := iItem + 1
            ColIndex := iSubItem + 1
            
            ; 濡傛灉鐐瑰嚮浜嗘湁鏁堢殑鍗曞厓鏍硷紙iItem >= 0 琛ㄧず鐐瑰嚮浜嗘湁鏁堣锛宨SubItem >= 0 琛ㄧず鐐瑰嚮浜嗘湁鏁堝垪锛?
            if (iItem >= 0 && iSubItem >= 0) {
                ; 閿€姣佽鐩栧眰锛堜笉鍐嶄娇鐢級
                DestroyClipboardHighlightOverlay()
                
                ; 鏇存柊楂樹寒浣嶇疆
                ClipboardListViewHighlightedRow := RowIndex
