; URL 缂栫爜杈呭姪鍑芥暟
EncodeURIComponent(Str) {
    ; 浣跨敤 COM 瀵硅薄杩涜 URL 缂栫爜锛堟洿鍙潬锛?
    try {
        ; 鍒涘缓 ScriptControl 瀵硅薄杩涜缂栫爜
        Encoded := ""
        Loop Parse, Str {
            Char := A_LoopField
            ; ASCII 瀛楃鐩存帴浣跨敤
            if (Ord(Char) < 128 && RegExMatch(Char, "[A-Za-z0-9\-_.!~*'()]")) {
                Encoded .= Char
            } else {
                ; 闈?ASCII 瀛楃杩涜 URL 缂栫爜
                ; 浣跨敤 StrPut 鑾峰彇 UTF-8 瀛楄妭
                UTF8Buf := Buffer(StrPut(Char, "UTF-8"))
                StrPut(Char, UTF8Buf, "UTF-8")
                Loop UTF8Buf.Size {
                    Byte := NumGet(UTF8Buf, A_Index - 1, "UChar")
                    Encoded .= "%" . Format("{:02X}", Byte)
                }
            }
        }
        return Encoded
    } catch as err {
        ; 濡傛灉缂栫爜澶辫触锛岃繑鍥炲師濮嬪瓧绗︿覆锛堟祻瑙堝櫒閫氬父鑳藉鐞嗭級
        return Str
    }
}

