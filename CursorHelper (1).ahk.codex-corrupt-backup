; 鎸夐挳鎮仠鍔ㄧ敾锛堝钩婊戣繃娓★級
AnimateButtonHover(Ctrl, NormalColor, HoverColor, IsEntering) {
    ; 濡傛灉姝ｅ湪鍔ㄧ敾涓紝璺宠繃
    try {
        if (Ctrl.HasProp("IsAnimating") && Ctrl.IsAnimating) {
            return
        }
    } catch as err {
    }
    
    try {
        Ctrl.IsAnimating := true
    } catch as err {
        ; 濡傛灉鏃犳硶璁剧疆灞炴€э紝鐩存帴璁剧疆棰滆壊
        try {
            if (IsEntering) {
                Ctrl.BackColor := HoverColor
            } else {
                Ctrl.BackColor := NormalColor
            }
        } catch as err {
        }
        return
    }
    
    ; 浣跨敤棰滆壊娣峰悎瀹炵幇骞虫粦杩囨浮锛?甯у姩鐢伙級
    AnimationSteps := 5
    Loop AnimationSteps {
        Step := A_Index
        Ratio := Step / AnimationSteps
        
        ; 璁＄畻涓棿棰滆壊
        if (IsEntering) {
            CurrentColor := BlendColor(NormalColor, HoverColor, Ratio)
        } else {
            CurrentColor := BlendColor(HoverColor, NormalColor, Ratio)
        }
        
        try {
            Ctrl.BackColor := CurrentColor
        } catch as err {
            ; 蹇界暐閿欒
        }
        
        Sleep(10)  ; 姣忓抚10ms锛屾€诲叡50ms鐨勫姩鐢?
    }
    
    ; 璁剧疆鏈€缁堥鑹?
    try {
        if (IsEntering) {
            Ctrl.BackColor := HoverColor
        } else {
            Ctrl.BackColor := NormalColor
        }
    } catch as err {
    }
    
    try {
        Ctrl.IsAnimating := false
    } catch as err {
    }
}

; 鎸夐挳鐐瑰嚮鍔ㄧ敾锛堟寜涓嬫晥鏋滐級
AnimateButtonClick(Ctrl) {
    if (!Ctrl.HasProp("HoverColor")) {
        return
    }
    
    try {
        OriginalColor := Ctrl.BackColor
        ClickColor := BlendColor(Ctrl.HoverColor, "000000", 0.3)  ; 鍙樻殫30%妯℃嫙鎸変笅鏁堟灉
        
        ; 蹇€熷彉鏆楋紙浣跨敤瀹氭椂鍣ㄩ伩鍏嶉樆濉烇級
        Ctrl.BackColor := ClickColor
        ; 浣跨敤瀹氭椂鍣ㄦ仮澶嶉鑹诧紙閫氳繃闂寘鎹曡幏鍙橀噺锛?
        RestoreColorFunc := RestoreButtonColor.Bind(Ctrl, OriginalColor)
        SetTimer(RestoreColorFunc, -50)  ; 50ms鍚庢仮澶?
    } catch as err {
        ; 蹇界暐閿欒
    }
}

; 鎭㈠鎸夐挳棰滆壊鐨勮緟鍔╁嚱鏁?
