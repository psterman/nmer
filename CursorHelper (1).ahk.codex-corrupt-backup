    p := StrReplace(p, "/", "\")
    if (RegExMatch(p, "^\\\\[^\\]+\\[^\\]+")) {
        p := "\\" . RegExReplace(SubStr(p, 3), "\\{2,}", "\")
    } else {
        p := RegExReplace(p, "\\{2,}", "\")
    }
    return p
}

