                    A_Clipboard := Content
                    TrayTip("宸插鍒跺埌鍓创鏉?, Item.Title, "Iconi 1")
                    CloseCursorPanel()
            }
        } else {
            ; 濡傛灉娌℃湁 Action锛岄粯璁ゅ鍒跺埌鍓创鏉垮苟绮樿创鍒?Cursor
            global CursorPath, AISleepTime
            try {
                if (!WinExist("ahk_exe Cursor.exe")) {
