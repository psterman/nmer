; ===================== 鍏ㄥ眬鎼滅储寮曟搸绫?=====================
/**
 * 鍏ㄥ眬鎼滅储寮曟搸绫?
 * 褰诲簳瑙ｅ喅鍙ユ焺娉勯湶鍜?Database Locked 闂
 * 寮曞叆鐔旀柇鏈哄埗銆乀ry-Finally 淇濇姢銆佸苟鍙戝悓姝?
 */
class GlobalSearchEngine {
    /**
     * 鐔旀柇鏈哄埗锛氬湪鎵ц Prepare 涔嬪墠寮哄埗閲婃斁鏃х殑 Statement 鍙ユ焺
     */
    static ReleaseOldStatement() {
        global GlobalSearchStatement
        try {
            if (IsObject(GlobalSearchStatement) && GlobalSearchStatement != 0) {
                GlobalSearchStatement.Free()
                GlobalSearchStatement := 0
            }
        } catch as e {
            OutputDebug("閲婃斁鏃?Statement 澶辫触: " . e.Message)
            GlobalSearchStatement := 0
        }
    }
    
    static PerformSearch(Keyword, MaxResults := 100) {
        global ClipboardDB, GlobalSearchStatement, global_ST
        Results := []
        ST := 0  ; 灞€閮?Statement 鍙ユ焺
        
        ; 妫€鏌ユ暟鎹簱鏄惁宸插垵濮嬪寲
        if (!IsObject(ClipboardDB) || ClipboardDB = 0) {
            return Results
        }
        
        ; 銆愬叆鍙ｇ啍鏂€戝湪鎵ц浠讳綍 Prepare 涔嬪墠锛屽繀椤诲厛妫€鏌ュ苟閲婃斁鏃у彞鏌?
        if (IsObject(global_ST) && global_ST.HasProp("Free")) {
            try {
                global_ST.Free()
            } catch as err {
            }
            global_ST := 0
        }
        
        ; 銆愮啍鏂満鍒躲€戝湪鎵ц浠讳綍 Prepare 涔嬪墠锛屽己鍒堕噴鏀炬棫鐨?Statement
        GlobalSearchEngine.ReleaseOldStatement()
        
        ; 鏋勫缓妯＄硦鍖归厤妯″紡
        SearchPattern := "%" . Keyword . "%"
        
        try {
            ; 浣跨敤 UNION ALL 涓€娆℃€ф煡璇㈡彁绀鸿瘝鍜屽壀璐存澘
            SQL := "
            (
                SELECT Name AS Title, Content, '鎻愮ず璇? AS Source, CreateTime, rowid AS ID 
                FROM Prompts 
                WHERE Name LIKE ? OR Content LIKE ?
                UNION ALL
                SELECT SUBSTR(Content, 1, 50) AS Title, Content, '鍓创鏉? AS Source, CreateTime, rowid AS ID 
                FROM ClipboardHistory 
                WHERE Content LIKE ?
                ORDER BY CreateTime DESC 
                LIMIT " . MaxResults . "
            )"
            
            ; 鍑嗗璇彞
            if !ClipboardDB.Prepare(SQL, &ST) {
                return Results
            }
            
            ; 鏇存柊鍏ㄥ眬 Statement锛堢敤浜庣啍鏂満鍒讹級
            GlobalSearchStatement := ST
            global_ST := ST  ; 鍚屾椂鏇存柊 global_ST

            ; 缁戝畾鍙傛暟锛堥槻姝?SQL 娉ㄥ叆骞舵彁楂樻€ц兘锛?
            ST.Bind(1, SearchPattern)
            ST.Bind(2, SearchPattern)
            ST.Bind(3, SearchPattern)

            ; 銆怲ry-Finally 淇濇姢銆戝皢 Step() 寰幆鍖呰９鍦?try-finally 涓?
            try {
                ; 杩唬缁撴灉闆?
                while (ST.Step() = 100) { ; 100 浠ｈ〃 SQLITE_ROW
                    Results.Push({
                        Title: ST.ColumnText(0),
                        Content: ST.ColumnText(1),
                        Source: ST.ColumnText(2),
                        Time: ST.ColumnText(3),
                        ID: ST.ColumnInt(4)
                    })
                }
            } catch as e {
                OutputDebug("鎼滅储 Step() 寰幆鍑洪敊: " . e.Message)
            } finally {
                ; 銆愯繃绋嬩繚搴曘€戞棤璁烘煡璇㈡垚鍔熻繕鏄姤閿欙紝閮藉湪 finally 鍧椾腑閲婃斁鍙ユ焺
                try {
                    if (IsObject(global_ST) && global_ST.HasProp("Free")) {
                        global_ST.Free()
                    }
                    global_ST := 0
                } catch as err {
                }
                ; 娓呯┖鍏ㄥ眬 Statement
                if (GlobalSearchStatement = ST) {
                    GlobalSearchStatement := 0
                }
            }
        } catch as e {
            OutputDebug("鎼滅储鍑洪敊: " . e.Message)
            ; 銆愯繃绋嬩繚搴曘€戠‘淇濆紓甯告椂涔熼噴鏀惧彞鏌?
            try {
                if (IsObject(global_ST) && global_ST.HasProp("Free")) {
                    global_ST.Free()
                }
                global_ST := 0
            } catch as err {
            }
            ; 娉ㄦ剰锛歡lobal_ST 宸插湪涓婇潰閲婃斁锛岃繖閲屽彧娓呯悊 GlobalSearchStatement
            if (GlobalSearchStatement = ST) {
                GlobalSearchStatement := 0
            }
        }
        
        return Results
    }
}

