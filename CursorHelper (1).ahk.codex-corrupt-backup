            ClipboardDB := 0
            return
        }
        
        ; 7. 鍒涘缓绱㈠紩浠ユ彁鍗囨煡璇㈡€ц兘
        SQL := "CREATE INDEX IF NOT EXISTS idx_clipboard_timestamp ON ClipboardHistory(Timestamp DESC)"
