; ===================== 鎵ц鎻愮ず璇嶅嚱鏁?=====================
ExecutePrompt(Type, TemplateID := "") {
    global Prompt_Explain, Prompt_Refactor, Prompt_Optimize, CursorPath, AISleepTime, IsCommandMode, CapsLock2, ClipboardHistory
    global DefaultTemplateIDs, PromptTemplates
    
    ; 娓呴櫎鏍囪锛岃〃绀轰娇鐢ㄤ簡鍔熻兘
    CapsLock2 := false
    ; 鏍囪鍛戒护妯″紡缁撴潫锛岄伩鍏?CapsLock 閲婃斁鍚庡啀娆￠殣钘忛潰鏉?
    IsCommandMode := false
    
    HideCursorPanel()
    
    ; 鏍规嵁绫诲瀷閫夋嫨鎻愮ず璇嶏紙浼樺厛浣跨敤妯℃澘绯荤粺锛?
    Prompt := ""
    
    ; 濡傛灉鎻愪緵浜員emplateID锛岀洿鎺ヤ娇鐢ㄦā鏉?
    if (TemplateID != "") {
        Template := GetTemplateByID(TemplateID)
        if (Template) {
            Prompt := Template.Content
        }
    }
    
    ; 濡傛灉娌℃湁TemplateID鎴栨ā鏉挎湭鎵惧埌锛屼娇鐢ㄩ粯璁ゆā鏉挎垨浼犵粺鏂瑰紡
    if (Prompt = "") {
        ; 灏濊瘯浠庨粯璁ゆā鏉挎槧灏勮幏鍙?
        if (DefaultTemplateIDs.Has(Type)) {
            TemplateID := DefaultTemplateIDs[Type]
            Template := GetTemplateByID(TemplateID)
            if (Template) {
                Prompt := Template.Content
            }
        }
        
        ; 濡傛灉妯℃澘绯荤粺鏈壘鍒帮紝鍥為€€鍒颁紶缁熸柟寮?
        if (Prompt = "") {
            switch Type {
                case "Explain":
                    Prompt := Prompt_Explain
                case "Refactor":
                    Prompt := Prompt_Refactor
                case "Optimize":
                    Prompt := Prompt_Optimize
                case "BatchExplain":
                    Prompt := Prompt_Explain
                case "BatchRefactor":
                    Prompt := Prompt_Refactor
                case "BatchOptimize":
                    Prompt := Prompt_Optimize
            }
        }
    }
    
    if (Prompt = "") {
        return
    }
    
    ; 鍦ㄥ垏鎹㈢獥鍙ｄ箣鍓嶏紝鍏堜繚瀛樺綋鍓嶅壀璐存澘鍐呭骞跺皾璇曞鍒堕€変腑鏂囨湰
    ; 杩欐牱鍙互纭繚鍗充娇鍒囨崲绐楀彛鍚庡け鍘婚€変腑鐘舵€侊紝涔熻兘鑾峰彇鍒颁箣鍓嶉€変腑鐨勬枃鏈?
    ; 鍦ㄥ垏鎹㈢獥鍙ｄ箣鍓嶏紝鍏堜繚瀛樺綋鍓嶅壀璐存澘鍐呭
    OldClipboard := A_Clipboard
    
    ; 1. 淇濆瓨褰撳墠鍓创鏉垮埌鍘嗗彶璁板綍锛堣В鍐虫薄鏌撻棶棰橈紝闃叉鐢ㄦ埛鏁版嵁涓㈠け锛?
    if (OldClipboard != "") {
        ClipboardHistory.Push(OldClipboard)
    }
    
    SelectedCode := ""
    
    ; 灏濊瘯浠庡綋鍓嶆椿鍔ㄧ獥鍙ｅ鍒堕€変腑鏂囨湰
    if WinActive("ahk_exe Cursor.exe") {
        Send("{Esc}")
        Sleep(50)
        A_Clipboard := "" ; 娓呯┖鍓创鏉夸互閫氳繃 ClipWait 妫€娴?
        Send("^c")
        if ClipWait(0.5) { ; 鏅鸿兘绛夊緟澶嶅埗瀹屾垚
            SelectedCode := A_Clipboard
        }
        ; 鎭㈠鍓创鏉匡紝閬垮厤褰卞搷鍚庣画鍒ゆ柇
        A_Clipboard := OldClipboard
    } else {
        CurrentActiveWindow := WinGetID("A")
        A_Clipboard := ""
        Send("^c")
        if ClipWait(0.5) {
            SelectedCode := A_Clipboard
        }
        A_Clipboard := OldClipboard
    }
    
    ; 婵€娲?Cursor 绐楀彛
    try {
        if WinExist("ahk_exe Cursor.exe") {
            WinActivate("ahk_exe Cursor.exe")
            WinWaitActive("ahk_exe Cursor.exe", , 1)
            Sleep(200)
            
            ; 濡傛灉涔嬪墠娌℃湁鑾峰彇鍒伴€変腑鏂囨湰锛屽啀娆″皾璇曞湪 Cursor 鍐呭鍒?
            if (SelectedCode = "" && WinActive("ahk_exe Cursor.exe")) {
                Send("{Esc}")
                Sleep(50)
                A_Clipboard := ""
                Send("^c")
                if ClipWait(0.5) {
                    SelectedCode := A_Clipboard
                }
                A_Clipboard := OldClipboard
            }
            
            ; 鏋勫缓瀹屾暣鐨勬彁绀鸿瘝
            CodeBlockStart := "``````"
            CodeBlockEnd := "``````"
            if (SelectedCode != "") {
                FullPrompt := Prompt . "`n`n浠ヤ笅鏄€変腑鐨勪唬鐮侊細`n" . CodeBlockStart . "`n" . SelectedCode . "`n" . CodeBlockEnd
            } else {
                FullPrompt := Prompt
            }
            
            ; 澶嶅埗瀹屾暣鎻愮ず璇嶅埌鍓创鏉?
            A_Clipboard := FullPrompt
            if !ClipWait(1) {
                Sleep(100)
            }
            
            if !WinActive("ahk_exe Cursor.exe") {
                WinActivate("ahk_exe Cursor.exe")
                Sleep(200)
            }
            
            Send("{Esc}")
            Sleep(100)
            
            ; 鎵撳紑鑱婂ぉ闈㈡澘
            Send("^l")
            Sleep(400)
            
            if !WinActive("ahk_exe Cursor.exe") {
                WinActivate("ahk_exe Cursor.exe")
                Sleep(200)
            }
            
            ; 绮樿创鎻愮ず璇?
            Send("^v")
            Sleep(300) ; 绛夊緟绮樿创瀹屾垚
            
            ; 鎻愪氦
            Send("{Enter}")
            
            ; 2. 鎭㈠鐢ㄦ埛鐨勫師濮嬪壀璐存澘锛堣В鍐虫薄鏌撻棶棰橈級
            Sleep(200)
            A_Clipboard := OldClipboard
        } else {

            ; 濡傛灉 Cursor 鏈繍琛岋紝灏濊瘯鍚姩
            if (CursorPath != "" && FileExist(CursorPath)) {
                Run(CursorPath)
                Sleep(AISleepTime)
                
                ; 鏋勫缓鎻愮ず璇嶏紙濡傛灉鏈夐€変腑鏂囨湰锛?
                if (SelectedCode != "" && SelectedCode != OldClipboard && StrLen(SelectedCode) > 0) {
                    CodeBlockStart := "``````"
                    CodeBlockEnd := "``````"
                    FullPrompt := Prompt . "`n`n浠ヤ笅鏄€変腑鐨勪唬鐮侊細`n" . CodeBlockStart . "`n" . SelectedCode . "`n" . CodeBlockEnd
                } else {
                    FullPrompt := Prompt
                }
                
                ; 澶嶅埗鎻愮ず璇嶅埌鍓创鏉?
                A_Clipboard := FullPrompt
                Sleep(100)
                Send("^l")
                Sleep(200)
                Send("^v")
                Sleep(100)
                Send("{Enter}")
            }
        }
    } catch as e {
        MsgBox("鎵ц澶辫触: " . e.Message)
    }
}

