; 澶勭悊鍓创鏉胯彍鍗曢敭鐩樻秷鎭?
HandleClipboardMenuKeyMessage(wParam, lParam, msg, hwnd) {
    global GuiID_ClipboardSmartMenu
    if (GuiID_ClipboardSmartMenu = 0 || hwnd != GuiID_ClipboardSmartMenu.Hwnd) {
        return
    }
    
    ; wParam 鏄櫄鎷熼敭鐮?
    KeyCode := wParam
    
    ; 涓婃柟鍚戦敭 (VK_UP = 0x26)
    if (KeyCode = 0x26) {
        HandleClipboardMenuUp()
        return 1  ; 闃绘榛樿琛屼负
    }
    
    ; 涓嬫柟鍚戦敭 (VK_DOWN = 0x28)
    if (KeyCode = 0x28) {
        HandleClipboardMenuDown()
        return 1  ; 闃绘榛樿琛屼负
    }
    
    ; 鍥炶溅閿?(VK_RETURN = 0x0D)
    if (KeyCode = 0x0D) {
        HandleClipboardMenuEnter()
        return 1  ; 闃绘榛樿琛屼负
    }
    
    return 0  ; 鍏佽榛樿琛屼负
