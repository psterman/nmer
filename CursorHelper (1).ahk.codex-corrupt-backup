; 鍙戦€佽闊宠緭鍏ュ唴瀹瑰埌 Cursor
SendVoiceInputToCursor(Content) {
    global CursorPath, AISleepTime
    
    try {
        if !WinActive("ahk_exe Cursor.exe") {
            WinActivate("ahk_exe Cursor.exe")
            WinWaitActive("ahk_exe Cursor.exe", , 1)
            Sleep(200)
        }
        
        if !WinActive("ahk_exe Cursor.exe") {
            WinActivate("ahk_exe Cursor.exe")
            Sleep(200)
        }
        
        if (Content != "" && StrLen(Content) > 0) {
            ; 纭繚杈撳叆妗嗗凡鎵撳紑
            Send("^l")
            Sleep(300)
            
            ; 娓呯┖杈撳叆妗?
            Send("^a")
            Sleep(100)
            Send("{Delete}")
            Sleep(100)
            
            ; 杈撳叆鍐呭
            A_Clipboard := Content
            Sleep(100)
            Send("^v")
            Sleep(200)
            
            ; 鍙戦€?
            Send("{Enter}")
            Sleep(300)
            ; 涓嶆樉绀哄彂閫佹垚鍔熺殑鎻愮ず锛岄伩鍏嶅脊绐楀共鎵?
        }
    } catch as e {
        TrayTip(GetText("voice_input_failed") . ": " . e.Message, GetText("error"), "Iconx 2")
    }
}

