        Sleep(200)
        
        ; 鎵撳紑鑱婂ぉ闈㈡澘
        Send("^l")
        Sleep(300)
        
        ; 鍙戦€佹ā鏉垮唴瀹?
        Send("^v")
        Sleep(100)
        
        ; 濡傛灉鍓创鏉垮唴瀹逛笉鏄ā鏉垮唴瀹癸紝鐩存帴杈撳叆
        if (A_Clipboard != Content) {
