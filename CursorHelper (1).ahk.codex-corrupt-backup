        } else {
            ; 鍏朵粬蹇嵎閿搷浣滈兘搴旇闅愯棌闈㈡澘
            if (PanelVisible) {
                HideCursorPanel()
            }
        }
        
        switch ActionType {
            case "ESC":
                CapsLock2 := false
            case "C":
                ; 銆愬叧閿慨澶嶃€戞鏌ユ槸鍚﹀湪鏍囩鍒囨崲鏈熼棿锛屽鏋滄槸鍒欎笉鎵ц澶嶅埗
                global CapsLockCopyInProgress, CapsLockCopyEndTime, GuiID_ClipboardManager
                
                ; 鍙岄噸妫€鏌ワ細1. 妫€鏌ユ槸鍚︽槸鏍囩鍒囨崲鏈熼棿
