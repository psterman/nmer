    GuiID_VoiceInput.Show("w" . PanelWidth . " h" . PanelHeight . " x" . Pos.X . " y" . Pos.Y . " NoActivate")
    WinSetAlwaysOnTop(1, GuiID_VoiceInput.Hwnd)
    
    ; 鏍囪鐣岄潰宸叉樉绀?
    global VoiceInputActionSelectionVisible
    VoiceInputActionSelectionVisible := true
    
