    SetTimer(MonitorSelectedTextForVoiceInput, 0)
    
    ; 濡傛灉鑷姩鍔犺浇寮€鍏冲凡寮€鍚紝鍚姩鐩戝惉锛涘惁鍒欑‘淇濈洃鍚凡鍋滄
