        Send("{Enter}")
        TrayTip("宸插彂閫佸埌Cursor", "鎻愮ず", "Iconi 1")
    } catch as e {
        TrayTip("鍙戦€佸け璐? " . e.Message, "閿欒", "Iconx 2")
