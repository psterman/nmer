        ; 澶勭悊璇诲彇鍒扮殑鍐呭
        if (CurrentContent != "" && StrLen(CurrentContent) > 0) {
            ; 妫€鏌ュ唴瀹规槸鍚︾湅璧锋潵鍍忚闊宠緭鍏ョ殑鍐呭
            if (CurrentInputValue = "" && (InStr(CurrentContent, "\") || InStr(CurrentContent, ".lnk") || InStr(CurrentContent, "蹇嵎鏂瑰紡"))) {
                ; 蹇界暐鐪嬭捣鏉ュ儚鏂囦欢璺緞鎴栧揩鎹锋柟寮忕殑鍐呭
                A_Clipboard := OldClipboard
                return
            }
            
            ; 濡傛灉鍐呭鏈夊彉鍖栦笖鏂板唴瀹规洿闀匡紝鏇存柊杈撳叆妗?
            if (CurrentContent != CurrentInputValue && StrLen(CurrentContent) >= StrLen(CurrentInputValue)) {
