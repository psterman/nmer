                    ; 澶嶅埗鍒板壀璐存澘骞剁矘璐达紙閫氱敤澶勭悊锛?
                    global CursorPath, AISleepTime
                    try {
                        ; 妫€鏌?Cursor 鏄惁杩愯
                        if (!WinExist("ahk_exe Cursor.exe")) {
                            if (CursorPath != "" && FileExist(CursorPath)) {
                                Run(CursorPath)
                                Sleep(AISleepTime)
                            } else {
                                TrayTip("Cursor鏈繍琛?, "閿欒", "Iconx 2")
                                return
                            }
                        }
                        
                        ; 婵€娲?Cursor 绐楀彛
                        WinActivate("ahk_exe Cursor.exe")
                        Sleep(200)
                        
                        ; 鎵撳紑鑱婂ぉ闈㈡澘
                        Send("^l")
                        Sleep(400)
                        
                        ; 澶嶅埗鍐呭鍒板壀璐存澘
                        OldClipboard := A_Clipboard
                        A_Clipboard := Content
                        
                        ; 绮樿创
                        Send("^v")
                        Sleep(300)
                        
                        ; 鎻愪氦
                        Send("{Enter}")
                        
                        ; 鎭㈠鍓创鏉?
                        Sleep(200)
                        A_Clipboard := OldClipboard
                        
                        ; 鍏抽棴闈㈡澘
                        CloseCursorPanel()
                    } catch as e {
                        TrayTip("鍙戦€佸け璐? " . e.Message, "閿欒", "Iconx 2")
                    }
                case "open_file":
                    ; 鏂囦欢绫诲瀷锛氭墦寮€鏂囦欢
                    if (Item.HasProp("ActionParams") && Item.ActionParams.Has("FilePath")) {
