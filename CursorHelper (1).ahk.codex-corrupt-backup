        ; 鍔犺浇DLL鍒拌繘绋嬬┖闂?
        hModule := DllCall("LoadLibrary", "Str", evDll, "Ptr")
        if (!hModule) {
            OutputDebug("AHK_DEBUG: 鏃犳硶鍔犺浇 everything64.dll")
            EverythingUserTipOnce("鏃犳硶鍔犺浇 lib\everything64.dll锛堜綅鏁版垨渚濊禆鏄惁涓庣郴缁熶竴鑷达紵锛夈€?)
            return []
        }
        isInitialized := true
        OutputDebug("AHK_DEBUG: Everything DLL 鍔犺浇鎴愬姛")
    }

    ; 3. 妫€鏌?Everything 瀹㈡埛绔槸鍚﹀湪杩愯锛堥€氳繃鑾峰彇鐗堟湰鍙峰垽鏂璉PC杩炴帴锛?
    majorVer := DllCall(evDll "\Everything_GetMajorVersion", "UInt")
    if (majorVer = 0) {
        errCode := DllCall(evDll "\Everything_GetLastError", "UInt")
        OutputDebug("AHK_DEBUG: Everything IPC 杩炴帴澶辫触锛岄敊璇爜: " . errCode . " (2=鏈繍琛?")
        ; 灏濊瘯鍚姩 Everything锛堜紭鍏?64 浣嶏級
        runningName := ""
        require64 := (A_PtrSize = 8)
        if (!GetEverythingPID(&runningName, require64)) {
            startedFrom := ""
            if (!TryStartEverything(&startedFrom)) {
                OutputDebug("AHK_DEBUG: 鏃犳硶鍚姩 Everything, 鏉ユ簮: " . startedFrom)
                EverythingUserTipOnce("鏃犳硶鍚姩 Everything銆傝纭鏍圭洰褰曞瓨鍦?Everything64.exe锛?4浣嶏級骞朵娇鐢ㄤ笌鑴氭湰鍚岀瓑鏉冮檺杩愯銆?)
                return []
            }
            majorVer := DllCall(evDll "\Everything_GetMajorVersion", "UInt")
            if (majorVer = 0) {
                errCode := DllCall(evDll "\Everything_GetLastError", "UInt")
                OutputDebug("AHK_DEBUG: Everything 鍚姩鍚?IPC 浠嶅け璐? 閿欒鐮? " . errCode)
                EverythingUserTipOnce("Everything 宸插惎鍔ㄤ絾 IPC 浠嶅け璐ャ€傝纭 Everything 涓庤剼鏈潈闄愪竴鑷达紝涓斿凡鍚敤 SDK IPC銆?)
                return []
            }
        } else {
            ; Everything 杩涚▼瀛樺湪浣咺PC杩炴帴澶辫触锛岀瓑寰呴噸璇?
            Sleep(1000)
            majorVer := DllCall(evDll "\Everything_GetMajorVersion", "UInt")
            if (majorVer = 0) {
                OutputDebug("AHK_DEBUG: Everything 杩涚▼瀛樺湪浣咺PC杩炴帴澶辫触")
                EverythingUserTipOnce("Everything 杩涚▼鍦ㄨ繍琛屼絾 IPC 杩炴帴澶辫触銆傝纭繚 Everything 涓庤剼鏈潈闄愪竴鑷达紙閮芥櫘閫氭垨閮界鐞嗗憳锛夛紝骞舵鏌ユ槸鍚︾鐢ㄤ簡 SDK IPC銆?)
                return []
            }
        }
    }
    OutputDebug("AHK_DEBUG: Everything 鐗堟湰: " . majorVer)

    ; 4. 銆愬叧閿€戞竻鐞嗕笂涓€娆＄殑鎼滅储鐘舵€侊紝闃叉杩囨护鍣ㄦ畫鐣?
    DllCall(evDll "\Everything_CleanUp")

    ; 5. 璁剧疆鎼滅储鍙傛暟
    DllCall(evDll "\Everything_SetSearchW", "WStr", keyword)
    DllCall(evDll "\Everything_SetMax", "UInt", maxResults)

    ; 6. 銆愭墿灞曘€戣姹傛洿澶氫俊鎭細瀹屾暣璺緞銆佹枃浠跺悕銆佸ぇ灏忋€佷慨鏀规棩鏈熴€佸睘鎬х瓑
    ; 0x00000004 = EVERYTHING_REQUEST_FULL_PATH_AND_FILE_NAME
    ; 0x00000020 = EVERYTHING_REQUEST_SIZE
    ; 0x00000080 = EVERYTHING_REQUEST_DATE_MODIFIED
    ; 0x00000200 = EVERYTHING_REQUEST_ATTRIBUTES
    requestFlags := 0x00000004 | 0x00000020 | 0x00000080 | 0x00000200
    DllCall(evDll "\Everything_SetRequestFlags", "UInt", requestFlags)

    ; 7. 鎵ц鏌ヨ (1 = 闃诲绛夊緟鐩村埌缁撴灉鍑嗗濂?
    isSuccess := DllCall(evDll "\Everything_QueryW", "Int", 1)

    ; 8. 閿欒璇婃柇
    if (!isSuccess) {
        errCode := DllCall(evDll "\Everything_GetLastError", "UInt")
        OutputDebug("AHK_DEBUG: Everything 鏌ヨ鎸囦护鍙戦€佸け璐ワ紝閿欒鐮? " . errCode)
        ; 閿欒鐮佽鏄? 0=OK, 1=鍐呭瓨閿欒, 2=IPC閿欒, 3=娉ㄥ唽绫诲け璐? 4=鍒涘缓绐楀彛澶辫触, 5=鍒涘缓绾跨▼澶辫触, 6=鎼滅储璇嶆棤鏁? 7=鍙栨秷
        EverythingUserTipOnce("Everything 鏌ヨ澶辫触锛岄敊璇爜: " . errCode . "锛? 澶氫负 IPC/鏈繍琛岋級銆?)
        return []
    }

    ; 9. 鑾峰彇缁撴灉
    count := DllCall(evDll "\Everything_GetNumResults", "UInt")
    OutputDebug("AHK_DEBUG: Everything DLL 杩斿洖鏁伴噺: " . count . " (鍏抽敭璇? " . keyword . ")")

    ; 濡傛灉杩斿洖0锛屾鏌ユ槸鍚︽湁閿欒
    if (count = 0) {
        errCode := DllCall(evDll "\Everything_GetLastError", "UInt")
        if (errCode != 0) {
            OutputDebug("AHK_DEBUG: Everything 鏌ヨ鍚庨敊璇爜: " . errCode)
        }
    }

    ; 10. 鑾峰彇缁撴灉锛堣繑鍥濵ap瀵硅薄鏁扮粍锛屽寘鍚矾寰勩€佺被鍨嬨€佸ぇ灏忕瓑淇℃伅锛?
    results := []
    Loop Min(count, maxResults) {
        index := A_Index - 1
        
        ; 鑾峰彇鏂囦欢灞炴€т互鍒ゆ柇鏄枃浠惰繕鏄枃浠跺す
        attributes := DllCall(evDll "\Everything_GetResultAttributes", "UInt", index, "UInt")
        isDirectory := (attributes & 0x10) != 0  ; FILE_ATTRIBUTE_DIRECTORY = 0x10
        
        ; 濡傛灉璁剧疆浜嗕笉鍖呭惈鏂囦欢澶癸紝鍒欒烦杩囨枃浠跺す
        if (!includeFolders && isDirectory) {
            continue
        }
        
        ; 鑾峰彇瀹屾暣璺緞
        buf := Buffer(4096, 0)
        DllCall(evDll "\Everything_GetResultFullPathNameW", "UInt", index, "Ptr", buf.Ptr, "UInt", 2048)
        fullPath := StrGet(buf.Ptr, "UTF-16")
        
        if (fullPath = "") {
            continue
        }
        
        ; 鑾峰彇鏂囦欢澶у皬
        fileSize := DllCall(evDll "\Everything_GetResultSize", "UInt", index, "Int64")
        
        ; 鑾峰彇淇敼鏃ユ湡
        fileTime := DllCall(evDll "\Everything_GetResultDateModified", "UInt", index, "Int64")
        
        ; 鍒涘缓缁撴灉瀵硅薄
        result := Map()
        result["Path"] := fullPath
        result["IsDirectory"] := isDirectory
        result["Type"] := isDirectory ? "folder" : "file"
        result["Size"] := fileSize
        result["DateModified"] := fileTime
        result["Attributes"] := attributes
        
        results.Push(result)
    }

    ; 涓轰簡鍚戝悗鍏煎锛屽鏋滃彧闇€瑕佽矾寰勬暟缁勶紝鍙互杩斿洖绠€鍖栨牸寮?
    ; 浣嗚繖閲岃繑鍥炲畬鏁翠俊鎭紝璋冪敤鏂瑰彲浠ユ牴鎹渶瑕佹彁鍙栬矾寰?
    return results
}

