        TrayTip(GetText("install_cursor_chinese_complete"), GetText("install_cursor_chinese"), "Iconi 5")
        
    } catch as e {
        TrayTip("瀹夎娴佺▼鎵ц澶辫触: " . e.Message, GetText("error"), "Iconx 2")
