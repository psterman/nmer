; URL缂栫爜鍑芥暟锛堜娇鐢?UTF-8 缂栫爜锛屾纭鐞嗕腑鏂囷級
UriEncode(Uri) {
    try {
        ; 鏂规硶1锛氫娇鐢?JavaScript encodeURIComponent锛堝鏋滃彲鐢級
        try {
            js := ComObject("MSScriptControl.ScriptControl")
            js.Language := "JScript"
            ; 杞箟鍗曞紩鍙凤紝闃叉 JavaScript 閿欒
            EscapedUri := StrReplace(Uri, "\", "\\")
            EscapedUri := StrReplace(EscapedUri, "'", "\'")
            EscapedUri := StrReplace(EscapedUri, "`n", "\n")
            EscapedUri := StrReplace(EscapedUri, "`r", "\r")
            Encoded := js.Eval("encodeURIComponent('" . EscapedUri . "')")
            return Encoded
        } catch as err {
            ; 鏂规硶2锛氭墜鍔?UTF-8 缂栫爜锛堟洿鍙潬鐨勫鐢ㄦ柟妗堬級
            Encoded := ""
            ; 灏嗗瓧绗︿覆杞崲涓?UTF-8 瀛楄妭鏁扮粍
            UTF8Size := StrPut(Uri, "UTF-8")
            UTF8Bytes := Buffer(UTF8Size)
            StrPut(Uri, UTF8Bytes, "UTF-8")
            
            ; 閬嶅巻姣忎釜瀛楄妭杩涜缂栫爜
            Loop UTF8Size - 1 {  ; -1 鍥犱负 StrPut 杩斿洖鐨勫ぇ灏忓寘鎷?null 缁堟绗?
                Byte := NumGet(UTF8Bytes, A_Index - 1, "UChar")
                ; 淇濈暀瀛楃锛氬瓧姣嶃€佹暟瀛椼€?銆乢銆?銆亊锛堟牴鎹?RFC 3986锛?
                if ((Byte >= 48 && Byte <= 57) || (Byte >= 65 && Byte <= 90) || (Byte >= 97 && Byte <= 122) || Byte = 45 || Byte = 95 || Byte = 46 || Byte = 126) {
                    Encoded .= Chr(Byte)
                } else if (Byte = 32) {
                    ; 绌烘牸缂栫爜涓?+
                    Encoded .= "+"
                } else {
                    ; URL缂栫爜锛?XX锛堝ぇ鍐欙級
                    Encoded .= "%" . Format("{:02X}", Byte)
                }
            }
            return Encoded
        }
    } catch as err {
        ; 濡傛灉缂栫爜澶辫触锛岃繑鍥炲師濮嬪瓧绗︿覆
        return Uri
    }
}

