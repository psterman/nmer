InitClipboardDB() {
    global ClipboardDB, ClipboardDBPath
    
    ; 1. 鑷姩鍒涘缓鐩綍
    if !DirExist(A_ScriptDir "\Data") {
        DirCreate(A_ScriptDir "\Data")
    }
    
    ; 璁剧疆鏁版嵁搴撴枃浠惰矾寰勶紙浣跨敤 CursorData.db 纭繚鐗╃悊淇濆瓨锛?
    ClipboardDBPath := A_ScriptDir "\Data\CursorData.db"
    
    ; 2. 妫€鏌?sqlite3.dll 鏄惁瀛樺湪
    DllPath := A_ScriptDir "\sqlite3.dll"
    if (!FileExist(DllPath)) {
        MsgBox("sqlite3.dll 鏈壘鍒般€俙n璇风‘淇?sqlite3.dll 涓庤剼鏈綅浜庡悓涓€鐩綍銆?, "鏁版嵁搴撳垵濮嬪寲閿欒", "IconX")
        ClipboardDB := 0
        return
    }
    
    ; 3. 鍒涘缓 SQLiteDB 瀹炰緥骞舵墦寮€鏁版嵁搴?
    try {
        ClipboardDB := SQLiteDB()
        if (!ClipboardDB.OpenDB(ClipboardDBPath)) {
            MsgBox("鏃犳硶鎵撳紑鏁版嵁搴? " . ClipboardDBPath . "`n閿欒: " . ClipboardDB.ErrorMsg, "鏁版嵁搴撳垵濮嬪寲閿欒", "IconX")
            ClipboardDB := 0
            return
        }
        
        ; 4. 閲嶅啓寤鸿〃閫昏緫锛氬交搴曟竻闄ゆ棫缁撴瀯
        SQL := "DROP TABLE IF EXISTS ClipboardHistory;"
        if (!ClipboardDB.Exec(SQL)) {
            MsgBox("鍒犻櫎鏃ц〃澶辫触: " . ClipboardDB.ErrorMsg, "鏁版嵁搴撳垵濮嬪寲閿欒", "IconX")
            ClipboardDB.CloseDB()
            ClipboardDB := 0
            return
        }
        
        ; 5. 鍒涘缓鍏ㄦ柊鐨?ClipboardHistory 琛紙11瀛楁鏋舵瀯锛屽簾寮?SessionID 鍜?ItemIndex锛?
        ; Content: 鏂囨湰銆佷唬鐮佹垨鏈湴鏂囦欢璺緞
        ; DataType: 鍒嗙被: Text, Code, Link, Image, File, Email
        ; SourceApp: 绋嬪簭鍚?(chrome.exe)
        ; SourceTitle: 绐楀彛鏍囬
        ; SourcePath: 绋嬪簭瀹屾暣璺緞 (鐢ㄤ簬鎻愬彇鍥炬爣)
        ; CharCount: 瀛楃鏁?
        ; WordCount: 璇嶆暟
        ; Timestamp: 鏃堕棿鎴?
        ; MetaData: JSON 鏍煎紡鎵╁睍鏁版嵁
        ; IsPinned: 鏀惰棌/缃《
        SQL := "CREATE TABLE ClipboardHistory (" .
               "ID INTEGER PRIMARY KEY AUTOINCREMENT, " .
               "Timestamp DATETIME DEFAULT (datetime('now', 'localtime')), " .
               "Content TEXT, " .
               "DataType TEXT, " .
