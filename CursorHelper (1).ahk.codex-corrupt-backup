        }
        ; 浣跨敤寤惰繜淇濆瓨锛岄伩鍏嶉绻両O
        QueueWindowPositionSave(WindowName, WinX, WinY, WinW, WinH)
    } catch as err {
        ; 蹇界暐閿欒
    }
}

