    ; 鍥剧墖鍖哄煙浠庨《閮ㄥ紑濮嬶紝灞呬腑鏄剧ず锛堝幓鎺夋爣棰橈紝鐩存帴鏄剧ず鍥剧墖锛?
    AnimX := X + 30  ; 浠庡乏渚ц竟璺濆紑濮?
    AnimY := Y + 20  ; 浠庨《閮ㄥ紑濮嬶紝鍘绘帀鏍囬
    AnimWidth := W - 60  ; 鍗犳嵁鏁翠釜瀹藉害锛堝噺鍘诲乏鍙宠竟璺濓級
    ; 璁＄畻鍙敤楂樺害锛氬弬鑰冨睆骞曢珮搴︼紝纭繚鍥剧墖涓嶄細澶珮锛岀暀鍑轰笅鏂圭┖闂?
    ; 浣跨敤灞忓箷楂樺害鐨?0%浣滀负鏈€澶у浘鐗囧鍣ㄩ珮搴︼紝纭繚涓嬫柟鏈夎冻澶熺┖闂?
    global ConfigHeight
    MaxImageHeight := Round(ConfigHeight * 0.7)  ; 灞忓箷楂樺害鐨?0%
    AvailableHeight := H - (AnimY - Y) - 150  ; 棰勭暀150px缁欏簳閮ㄧ┖闂达紙鎸夐挳绛夛級
    ; 鍙栦袱鑰呬腑鐨勮緝灏忓€硷紝纭繚鍥剧墖涓嶄細澶珮
    AnimHeight := Min(AvailableHeight, MaxImageHeight)
    
    ; 鍥剧墖鏄剧ず鍖哄煙锛堜繚鎸佹瘮渚嬶紝涓嶆媺浼革級
    ImagePath := GetHotkeyImagePath(Item.Key)
    
    ; 鍒涘缓涓€涓鍣ㄨ儗鏅紙濮嬬粓鍒涘缓锛岀敤浜庢樉绀哄浘鐗囨垨鎻愮ず锛?
    PictureBg := ConfigGUI.Add("Text", "x" . AnimX . " y" . AnimY . " w" . AnimWidth . " h" . AnimHeight . " Background" . UI_Colors.InputBg . " vHotkeyPicBg" . Item.Key, "")
    HotkeySubTabControls[Item.Key].Push(PictureBg)
    
    if (FileExist(ImagePath)) {
        ; 鑾峰彇鍥剧墖瀹為檯灏哄
        ImageSize := GetImageSize(ImagePath)
        
        ; 璁＄畻淇濇寔姣斾緥鐨勬樉绀哄昂瀵?
