                    Sleep(50)
                }
            }
        }
        
        ; 灏濊瘯鐩存帴璇诲彇杈撳叆妗嗗唴瀹?
        OldClipboard := A_Clipboard
        CurrentContent := ""
        CurrentInputValue := ""
        
        try {
            CurrentInputValue := VoiceSearchInputEdit.Value
            CurrentContent := CurrentInputValue
        } catch as err {
            ; 濡傛灉鐩存帴璇诲彇澶辫触锛屼娇鐢ㄥ壀璐存澘鏂瑰紡
