        if (TemplateIndexByTitle.Has(Key)) {
            TargetTemplate := TemplateIndexByTitle[Key]
            ; 鑾峰彇鏁扮粍绱㈠紩
            if (TemplateIndexByArrayIndex.Has(TargetTemplate.ID)) {
                TemplateIndex := TemplateIndexByArrayIndex[TargetTemplate.ID]
            } else {
