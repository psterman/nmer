CapsLockPaste() {
    global CapsLock2, ClipboardHistory_CapsLockC, CursorPath, AISleepTime, ClipboardDB
    global CapsLockCCount, CapsLockCItems
    
    CapsLock2 := false  ; 娓呴櫎鏍囪锛岃〃绀轰娇鐢ㄤ簡鍔熻兘
    
    ; 銆愭柊閫昏緫銆戜粠 CapsLockCItems 鏁扮粍鑾峰彇褰撳墠闃舵鐨勬暟鎹繘琛岀矘璐?
    CurrentHistory := []
    
    ; 浣跨敤鍏ㄥ眬鏁扮粍 CapsLockCItems锛堝瓨鍌ㄥ綋鍓嶉樁娈电殑鎵€鏈?CapsLock+C 澶嶅埗鍐呭锛?
    if (IsSet(CapsLockCItems) && IsObject(CapsLockCItems) && CapsLockCItems.Length > 0) {
        CurrentHistory := CapsLockCItems
    } else {
        ; 濡傛灉鏁扮粍涓虹┖锛屽洖閫€鍒版棫鏁扮粍锛堝吋瀹规€э級
        if (!IsSet(ClipboardHistory_CapsLockC) || !IsObject(ClipboardHistory_CapsLockC)) {
            global ClipboardHistory_CapsLockC := []
        }
        CurrentHistory := ClipboardHistory_CapsLockC
    }
    
    ; 濡傛灉娌℃湁澶嶅埗浠讳綍鍐呭锛屾彁绀虹敤鎴?
    if (CurrentHistory.Length = 0) {
        TrayTip("銆愯鍛娿€戝綋鍓嶉樁娈垫病鏈夊唴瀹筦n璇峰厛浣跨敤 CapsLock+C 澶嶅埗鍐呭", GetText("tip"), "Iconi 2")
        return
    }
    
    ; 鍚堝苟鎵€鏈夊鍒剁殑鍐呭锛堢敤绌烘牸鍒嗛殧锛屽洜涓虹幇鍦ㄦ槸妯悜鎷兼帴锛?
    MergedContent := ""
    for Index, Content in CurrentHistory {
        if (Index > 1) {
            MergedContent .= " "  ; 鐢ㄧ┖鏍煎垎闅斾笉鍚屽唴瀹?
        }
        MergedContent .= Content
    }
    
    ; 銆愰噸缃鏁般€戠矘璐村悗閲嶇疆 CapsLock+C 璁℃暟鍜屾暟缁?
    CapsLockCCount := 0
    CapsLockCItems := []
    HideCapsLockCCountTooltip()
    
    ; 銆愬簾寮?SessionID 妯″紡銆戜笉鍐嶉渶瑕侀樁娈靛垏鎹㈤€昏緫
    
    ; 鍒锋柊鍒楄〃鏄剧ず锛堝鏋滈潰鏉垮凡鎵撳紑锛?
    global GuiID_ClipboardManager
    if (GuiID_ClipboardManager != 0) {
        SetTimer(RefreshClipboardListDelayed, -200)
    }
    
    ; 婵€娲?Cursor 绐楀彛
    try {
        if WinExist("ahk_exe Cursor.exe") {
            ; 鍏堟縺娲荤獥鍙ｏ紝绛夊緟绐楀彛瀹屽叏婵€娲?
            WinActivate("ahk_exe Cursor.exe")
            WinWaitActive("ahk_exe Cursor.exe", , 1)  ; 绛夊緟绐楀彛婵€娲伙紝鏈€澶氱瓑寰?绉?
            Sleep(200)  ; 棰濆绛夊緟锛岀‘淇濈獥鍙ｅ畬鍏ㄥ氨缁?
            
            ; 纭繚 Cursor 绐楀彛浠嶇劧婵€娲?
            if !WinActive("ahk_exe Cursor.exe") {
                WinActivate("ahk_exe Cursor.exe")
                Sleep(200)
            }
            
            ; 鍏堟寜 ESC 鍏抽棴鍙兘宸叉墦寮€鐨勮緭鍏ユ锛岄伩鍏嶅啿绐?
            Send("{Esc}")
            Sleep(100)
            
            ; 灏濊瘯鎵撳紑 Cursor 鐨?AI 鑱婂ぉ闈㈡澘锛堥€氬父鏄?Ctrl+L锛?
            Send("^l")
            Sleep(400)  ; 澧炲姞绛夊緟鏃堕棿锛岀‘淇濊亰澶╅潰鏉垮畬鍏ㄦ墦寮€
            
            ; 鍐嶆纭繚绐楀彛婵€娲伙紙闃叉鍦ㄧ瓑寰呮湡闂寸獥鍙ｅけ鍘荤劍鐐癸級
            if !WinActive("ahk_exe Cursor.exe") {
                WinActivate("ahk_exe Cursor.exe")
                Sleep(200)
            }
            
            ; 淇濆瓨褰撳墠鍓创鏉垮唴瀹癸紙鐢ㄤ簬鎭㈠锛?
            OldClipboardForPaste := A_Clipboard
            
            ; 灏嗗悎骞剁殑鍐呭澶嶅埗鍒板壀璐存澘
            A_Clipboard := MergedContent
            ; 绛夊緟鍓创鏉垮噯澶囧ソ
            if !ClipWait(1.0) {
                ; 濡傛灉鍓创鏉胯缃け璐ワ紝鎭㈠鏃у壀璐存澘
                A_Clipboard := OldClipboardForPaste
                TrayTip("銆愭晠闅溿€戣缃壀璐存澘澶辫触锛屾棤娉曠矘璐?, GetText("tip"), "Iconx 2")
                return
            }
            Sleep(100)
            
            ; 绮樿创鍚堝苟鐨勫唴瀹?
            Send("^v")
            Sleep(300)  ; 澧炲姞绛夊緟鏃堕棿锛岀‘淇濈矘璐村畬鎴?
            
            ; 鑷姩鍏抽棴鍓创鏉跨鐞嗛潰鏉?
            global GuiID_ClipboardManager
            if (GuiID_ClipboardManager != 0) {
                CloseClipboardManager()
            }
            
            ; 鎭㈠鍘熷鍓创鏉垮唴瀹癸紙鍙€夛紝淇濇寔鍚堝苟鍐呭鍦ㄥ壀璐存澘涓級
            ; A_Clipboard := OldClipboardForPaste
            
            TrayTip("銆愭垚鍔熴€戝凡绮樿创骞朵繚瀛樺埌鏁版嵁搴?, GetText("tip"), "Iconi 1")
        } else {
            ; 濡傛灉 Cursor 鏈繍琛岋紝灏濊瘯鍚姩
            if (CursorPath != "" && FileExist(CursorPath)) {
                Run(CursorPath)
                Sleep(AISleepTime)
                
                ; 淇濆瓨褰撳墠鍓创鏉垮唴瀹癸紙鐢ㄤ簬鎭㈠锛?
                OldClipboardForPaste := A_Clipboard
                
                ; 灏嗗悎骞剁殑鍐呭澶嶅埗鍒板壀璐存澘
                A_Clipboard := MergedContent
                ; 绛夊緟鍓创鏉垮噯澶囧ソ
                if !ClipWait(1.0) {
                    ; 濡傛灉鍓创鏉胯缃け璐ワ紝鎭㈠鏃у壀璐存澘
                    A_Clipboard := OldClipboardForPaste
                    TrayTip("銆愭晠闅溿€戣缃壀璐存澘澶辫触锛屾棤娉曠矘璐?, GetText("tip"), "Iconx 2")
                    return
                }
                Sleep(100)
                
                Send("^l")
                Sleep(400)
                Send("^v")
                Sleep(300)  ; 澧炲姞绛夊緟鏃堕棿锛岀‘淇濈矘璐村畬鎴?
                
                ; 绮樿创鍚庢竻绌哄巻鍙茶褰曪紙鍙竻绌?CapsLock+C 鐨勮褰曪級
                global ClipboardHistory_CapsLockC
                ItemCount := ClipboardHistory_CapsLockC.Length
                ClipboardHistory_CapsLockC := []
                
                ; 鑷姩鍏抽棴鍓创鏉跨鐞嗛潰鏉?
                global GuiID_ClipboardManager
                if (GuiID_ClipboardManager != 0) {
                    CloseClipboardManager()
                }
                
                ; 鎭㈠鍘熷鍓创鏉垮唴瀹癸紙鍙€夛紝淇濇寔鍚堝苟鍐呭鍦ㄥ壀璐存澘涓級
                ; A_Clipboard := OldClipboardForPaste
                
                TrayTip("銆愭垚鍔熴€戝凡绮樿创 " . ItemCount . " 椤瑰唴瀹瑰埌 Cursor", GetText("tip"), "Iconi 1")
            } else {
                TrayTip(GetText("cursor_not_running_error"), GetText("error"), "Iconx 2")
