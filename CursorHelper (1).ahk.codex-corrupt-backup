        ; 鏇存柊鍚勪釜鏍囩椤电殑鍐呭鍖哄煙澶у皬
        TabPanels := ["GeneralTabPanel", "AppearanceTabPanel", "PromptsTabPanel", "HotkeysTabPanel", "AdvancedTabPanel"]
        for Index, PanelName in TabPanels {
            try {
                TabPanel := GuiID_ConfigGUI[PanelName]
