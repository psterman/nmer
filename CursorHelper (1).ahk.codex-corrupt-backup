        } catch as err {
        }
    }
    
    return  ; 涓嶅鐞嗭紝璁╃郴缁熺户缁粯璁ゅ鐞?
}

; ===================== 鎼滅储涓績 ListView锛氳矾寰勫垪锛堝壇鏍囬锛夌伆鑹叉枃瀛?=====================
SearchCenterListViewCustomDraw(lParam) {
    global UI_Colors, ThemeMode
    try {
        if (A_PtrSize = 8) {
            dwDrawStageOffset := 24
            NMCUSTOMDRAWSize := 80
        } else {
            dwDrawStageOffset := 12
            NMCUSTOMDRAWSize := 48
        }
        clrTextOffset := NMCUSTOMDRAWSize
        clrTextBkOffset := NMCUSTOMDRAWSize + 4
        iSubItemOffset := NMCUSTOMDRAWSize + 8
        dwDrawStage := NumGet(lParam, dwDrawStageOffset, "UInt")
        CDDS_PREPAINT := 0x00000001
        CDDS_ITEMPREPAINT := 0x00010001
        CDDS_SUBITEMPREPAINT := 0x00030001
        CDRF_DODEFAULT := 0x00000000
        ; WinUser.h: NOTIFYITEMDRAW=0x40锛堥缁樺悗鎺ユ敹琛岋級, NOTIFYSUBITEMDRAW=0x20锛堣缁樺悗鎺ユ敹鍒楋級锛涘嬁鐢?0x04锛圕DRF_SKIPDEFAULT 浼氳烦杩囬粯璁ょ粯鍒跺鑷村垪琛ㄧ┖鐧斤級
        CDRF_NOTIFYITEMDRAW := 0x00000040
        CDRF_NOTIFYSUBITEMDRAW := 0x00000020
        CDRF_NEWFONT := 0x00000002
        if (dwDrawStage = CDDS_PREPAINT)
            return CDRF_NOTIFYITEMDRAW
        if (dwDrawStage = CDDS_ITEMPREPAINT)
            return CDRF_NOTIFYSUBITEMDRAW
        if (dwDrawStage = CDDS_SUBITEMPREPAINT) {
            iSubItem := NumGet(lParam, iSubItemOffset, "Int")
            ; 绗?3 鍒楋紙绱㈠紩 2锛夛細璺緞/鍓爣棰?鈥?鐏拌壊
            if (iSubItem = 2) {
                NumPut("UInt", 0x00808080, lParam, clrTextOffset)
                return CDRF_NEWFONT
            }
            try {
                TextColorStr := UI_Colors.Text
                R := Integer("0x" . SubStr(TextColorStr, 1, 2))
                G := Integer("0x" . SubStr(TextColorStr, 3, 2))
                B := Integer("0x" . SubStr(TextColorStr, 5, 2))
                DefaultTextColor := (B << 16) | (G << 8) | R
            } catch {
                DefaultTextColor := (ThemeMode = "dark") ? 0x00FFFFFF : 0x00000000
            }
            NumPut("UInt", DefaultTextColor, lParam, clrTextOffset)
            return CDRF_NEWFONT
        }
        return CDRF_DODEFAULT
    } catch {
        return ""
    }
}

; ===================== 澶勭悊 ListView 鑷畾涔夌粯鍒讹紙NM_CUSTOMDRAW锛?=====================
; 鐢ㄤ簬瀹炵幇鍗曞厓鏍肩骇鍒殑楂樹寒鏁堟灉
HandleClipboardListViewCustomDraw(lParam) {
    global ClipboardListViewHighlightedRow, ClipboardListViewHighlightedCol
    global ThemeMode, UI_Colors
    
    try {
        ; NMLVCUSTOMDRAW 缁撴瀯锛堢敤浜?ListView 鐨勮嚜瀹氫箟缁樺埗锛?
        ; 
        ; 棣栧厛鏄?NMCUSTOMDRAW 鍩虹缁撴瀯锛?
        ; - NMHDR hdr
        ;     - hwndFrom: HWND (A_PtrSize)
        ;     - idFrom: UINT_PTR (A_PtrSize)
        ;     - code: UINT (4瀛楄妭)
        ;     - 64浣嶇郴缁焢adding (4瀛楄妭)
        ; - dwDrawStage: DWORD (4瀛楄妭)
        ; - 64浣嶇郴缁焢adding (4瀛楄妭)
        ; - hdc: HDC (A_PtrSize)
        ; - rc: RECT (16瀛楄妭)
        ; - dwItemSpec: DWORD_PTR (A_PtrSize)
        ; - uItemState: UINT (4瀛楄妭)
        ; - 64浣嶇郴缁焢adding (4瀛楄妭)
        ; - lItemlParam: LPARAM (A_PtrSize)
        ;
        ; 鐒跺悗鏄?NMLVCUSTOMDRAW 鎵╁睍锛?
        ; - clrText: COLORREF (4瀛楄妭)
        ; - clrTextBk: COLORREF (4瀛楄妭)
        ; - iSubItem: int (4瀛楄妭)
        
        ; 璁＄畻鍚勫瓧娈靛亸绉婚噺
        if (A_PtrSize = 8) {
            ; 64浣嶇郴缁?
            NMHDRSize := 24  ; 8 + 8 + 4 + 4(padding)
            dwDrawStageOffset := 24
            hdcOffset := 32  ; 24 + 4 + 4(padding)
            rcOffset := 40   ; 32 + 8
            dwItemSpecOffset := 56  ; 40 + 16
            uItemStateOffset := 64  ; 56 + 8
            lItemlParamOffset := 72  ; 64 + 4 + 4(padding)
            ; NMCUSTOMDRAW 缁撴潫浣嶇疆: 80 (72 + 8)
            NMCUSTOMDRAWSize := 80
        } else {
            ; 32浣嶇郴缁?
            NMHDRSize := 12  ; 4 + 4 + 4
            dwDrawStageOffset := 12
            hdcOffset := 16  ; 12 + 4
            rcOffset := 20   ; 16 + 4
            dwItemSpecOffset := 36  ; 20 + 16
            uItemStateOffset := 40  ; 36 + 4
            lItemlParamOffset := 44 ; 40 + 4
            ; NMCUSTOMDRAW 缁撴潫浣嶇疆: 48 (44 + 4)
            NMCUSTOMDRAWSize := 48
        }
        
        ; NMLVCUSTOMDRAW 鎵╁睍瀛楁鍋忕Щ
        clrTextOffset := NMCUSTOMDRAWSize
        clrTextBkOffset := NMCUSTOMDRAWSize + 4
        iSubItemOffset := NMCUSTOMDRAWSize + 8
        
        ; 璇诲彇 dwDrawStage
        dwDrawStage := NumGet(lParam, dwDrawStageOffset, "UInt")
        
        ; 瀹氫箟甯搁噺
        CDDS_PREPAINT := 0x00000001
        CDDS_ITEMPREPAINT := 0x00010001
        CDDS_SUBITEMPREPAINT := 0x00030001
        CDRF_DODEFAULT := 0x00000000
        CDRF_NOTIFYITEMDRAW := 0x00000020
        CDRF_NEWFONT := 0x00000002
        
        ; 鏁翠釜鎺т欢寮€濮嬬粯鍒?- 璇锋眰鎺ユ敹椤圭洰缁樺埗閫氱煡
        if (dwDrawStage = CDDS_PREPAINT) {
            return CDRF_NOTIFYITEMDRAW
        }
        
        ; 椤圭洰寮€濮嬬粯鍒?- 璇锋眰鎺ユ敹瀛愰」鐩粯鍒堕€氱煡
        if (dwDrawStage = CDDS_ITEMPREPAINT) {
            return CDRF_NOTIFYITEMDRAW
        }
        
        ; 瀛愰」鐩紑濮嬬粯鍒?- 杩欓噷璁剧疆楂樹寒棰滆壊
        if (dwDrawStage = CDDS_SUBITEMPREPAINT) {
            ; 璇诲彇褰撳墠缁樺埗鐨勮绱㈠紩
            iItem := NumGet(lParam, dwItemSpecOffset, "UPtr")
            ; 璇诲彇褰撳墠缁樺埗鐨勫垪绱㈠紩
            iSubItem := NumGet(lParam, iSubItemOffset, "Int")
            
            ; 杞崲涓轰粠1寮€濮嬬殑绱㈠紩
            RowIndex := iItem + 1
            ColIndex := iSubItem + 1
            
            ; 銆愬叧閿慨澶嶃€戝繀椤诲缁堣缃鑹诧紝鍚﹀垯浼氱户鎵夸箣鍓嶇殑棰滆壊
            ; 浠?UI_Colors 鑾峰彇榛樿棰滆壊锛屽苟杞崲涓?BGR 鏍煎紡
            ; UI_Colors.InputBg 鏄?RGB 鍗佸叚杩涘埗瀛楃涓诧紝濡?"2B2B2B"
            ; 闇€瑕佽浆鎹负 BGR 鏁存暟
            try {
                ; 鑾峰彇鑳屾櫙鑹诧紙RGB瀛楃涓诧級
                BgColorStr := UI_Colors.InputBg
                ; 杞崲 RGB 瀛楃涓蹭负 BGR 鏁存暟
                ; 渚嬪 "2B2B2B" -> 0x002B2B2B (鎭板ソ BGR 鍜?RGB 鐩稿悓鍥犱负 R=G=B)
                R := Integer("0x" . SubStr(BgColorStr, 1, 2))
                G := Integer("0x" . SubStr(BgColorStr, 3, 2))
                B := Integer("0x" . SubStr(BgColorStr, 5, 2))
                DefaultBgColor := (B << 16) | (G << 8) | R  ; BGR 鏍煎紡
                
                ; 鑾峰彇鏂囧瓧鑹?
                TextColorStr := UI_Colors.Text
                R := Integer("0x" . SubStr(TextColorStr, 1, 2))
                G := Integer("0x" . SubStr(TextColorStr, 3, 2))
                B := Integer("0x" . SubStr(TextColorStr, 5, 2))
                DefaultTextColor := (B << 16) | (G << 8) | R  ; BGR 鏍煎紡
            } catch as err {
                ; 濡傛灉鑾峰彇澶辫触锛屼娇鐢ㄧ‖缂栫爜鐨勯粯璁ゅ€?
                if (ThemeMode = "dark") {
                    DefaultBgColor := 0x002B2B2B   ; 鏆楄壊鑳屾櫙 BGR
                    DefaultTextColor := 0x00FFFFFF ; 鐧借壊鏂囧瓧 BGR
                } else {
                    DefaultBgColor := 0x00FFFFFF   ; 鐧借壊鑳屾櫙 BGR
                    DefaultTextColor := 0x00000000 ; 榛戣壊鏂囧瓧 BGR
                }
            }
            
            ; 妫€鏌ユ槸鍚︽槸鎴戜滑閫変腑鐨勫崟鍏冩牸
            if (RowIndex = ClipboardListViewHighlightedRow && ColIndex = ClipboardListViewHighlightedCol) {
                ; 璁剧疆楂樹寒鑳屾櫙鑹诧紙浣跨敤 BGR 鏍煎紡锛?
                if (ThemeMode = "dark") {
                    ; 鏆楄壊涓婚锛氫娇鐢ㄨ摑鑹查珮浜?
                    ; RGB 0078D4 -> BGR D47800
                    HighlightBgColor := 0x00D47800
                    HighlightTextColor := 0x00FFFFFF
                } else {
                    ; 浜壊涓婚锛氫娇鐢ㄦ祬钃濊壊楂樹寒
                    ; RGB CCE8FF -> BGR FFE8CC
                    HighlightBgColor := 0x00FFE8CC
                    HighlightTextColor := 0x00000000
                }
                
                ; 鍐欏叆棰滆壊鍒?NMLVCUSTOMDRAW 缁撴瀯
                NumPut("UInt", HighlightTextColor, lParam, clrTextOffset)
                NumPut("UInt", HighlightBgColor, lParam, clrTextBkOffset)
                
                ; 杩斿洖 CDRF_NEWFONT 鍛婅瘔绯荤粺浣跨敤鎴戜滑璁剧疆鐨勯鑹?
                return CDRF_NEWFONT
            } else {
                ; 銆愬叧閿€戦潪閫変腑鍗曞厓鏍硷細閲嶇疆涓洪粯璁ら鑹诧紝闃叉缁ф壙楂樹寒棰滆壊
                NumPut("UInt", DefaultTextColor, lParam, clrTextOffset)
                NumPut("UInt", DefaultBgColor, lParam, clrTextBkOffset)
                
                ; 杩斿洖 CDRF_NEWFONT 浣跨敤鎴戜滑璁剧疆鐨勯粯璁ら鑹?
                return CDRF_NEWFONT
            }
        }
        
        return CDRF_DODEFAULT
        
    } catch as e {
        try {
            FileAppend("[" . FormatTime(, "yyyy-MM-dd HH:mm:ss") . "] HandleClipboardListViewCustomDraw Error: " . e.Message . "`n", A_ScriptDir "\clipboard_debug.log")
        } catch as err {
        }
        return 0
    }
}

; ===================== 鍙栨秷 ListView 鎵€鏈夎鐨勯€変腑鐘舵€?=====================
; 浣跨敤API鐩存帴璁剧疆锛岄伩鍏嶈Е鍙慖temSelect浜嬩欢锛岀‘淇濈珛鍗崇敓鏁?
UnselectAllListViewRows() {
    global ClipboardListView, ClipboardListViewHwnd
    
    try {
        if (!ClipboardListView || !IsObject(ClipboardListView) || !ClipboardListViewHwnd) {
            return
        }
        
        LV_Hwnd := ClipboardListViewHwnd
        if (!LV_Hwnd) {
            return
        }
        
        ; 鑾峰彇褰撳墠閫変腑鐨勮鏁?
        RowCount := ClipboardListView.GetCount()
        if (RowCount < 1) {
            return
        }
        
        ; 銆愬叧閿紭鍖栥€戜娇鐢↙VM_SETITEMSTATE API鎵归噺鍙栨秷鎵€鏈夎鐨勯€変腑鐘舵€?
        ; LVM_SETITEMSTATE = 0x102B
        ; 浣跨敤鏇撮珮鏁堢殑鏂瑰紡锛氫竴娆℃€у鐞嗘墍鏈夎
        Loop RowCount {
            LVITEM := Buffer(A_PtrSize = 8 ? 80 : 60, 0)
            NumPut("UInt", 0x8, LVITEM, 0)  ; mask = LVIF_STATE
            NumPut("Int", A_Index - 1, LVITEM, A_PtrSize = 8 ? 8 : 4)  ; iItem锛堜粠0寮€濮嬶級
            NumPut("UInt", 0, LVITEM, A_PtrSize = 8 ? 16 : 12)  ; state = 0锛堝彇娑堥€変腑锛?
            NumPut("UInt", 0x2, LVITEM, A_PtrSize = 8 ? 20 : 16)  ; stateMask = LVIS_SELECTED (0x2)
            DllCall("SendMessage", "Ptr", LV_Hwnd, "UInt", 0x102B, "Ptr", A_Index - 1, "Ptr", LVITEM.Ptr, "Int")
        }
        
        ; 銆愬叧閿€戠珛鍗冲己鍒堕噸缁楲istView锛岀‘淇濊瑙変笂绔嬪嵆鍙栨秷閫変腑
        ; 浣跨敤InvalidateRect寮哄埗閲嶇粯
        DllCall("InvalidateRect", "Ptr", LV_Hwnd, "Ptr", 0, "Int", 1)  ; 1 = TRUE锛岀珛鍗抽噸缁?
        DllCall("UpdateWindow", "Ptr", LV_Hwnd)
    } catch as err {
        ; 濡傛灉API璋冪敤澶辫触锛屽皾璇曚娇鐢∕odify鏂规硶锛堝彲鑳借緝鎱絾鏇村吋瀹癸級
        try {
            if (ClipboardListView && IsObject(ClipboardListView)) {
                RowCount := ClipboardListView.GetCount()
                Loop RowCount {
                    ClipboardListView.Modify(A_Index, "-Select")
                }
                ClipboardListView.Redraw()
            }
        } catch as err {
            ; 蹇界暐閿欒
        }
    }
}

