    ; 娓呴櫎CapsLock2鏍囪锛岄槻姝㈤潰鏉胯婵€娲?
    CapsLock2 := false
    
    ; 灏嗘寜閿浆鎹负灏忓啓杩涜姣旇緝锛圗SC鐗规畩澶勭悊锛?
    KeyLower := StrLower(PressedKey)
