; 璁板綍 CapsLock 鎸変笅鏃堕棿
global CapsLockPressTime := 0

; 閲囩敤 CapsLock+ 鏂规锛氫娇鐢?~ 鍓嶇紑淇濈暀鍘熷鍔熻兘锛岄€氳繃鏍囪鍙橀噺鎺у埗琛屼负
~CapsLock:: {
    global CapsLock, CapsLock2, IsCommandMode, PanelVisible, VoiceInputActive, VoiceSearchActive, VoiceInputMethod, VoiceInputPaused, CapsLockHoldTimeSeconds
    global VKHoldVisible, CapsLockHoldVkEnabled
    
    ; 纭繚鍏ㄥ眬鍙橀噺宸插垵濮嬪寲
    if (!IsSet(PanelVisible)) {
        PanelVisible := false
    }
    if (!IsSet(VoiceInputActive)) {
        VoiceInputActive := false
    }
    if (!IsSet(VoiceSearchActive)) {
        VoiceSearchActive := false
    }
    if (!IsSet(CapsLockHoldTimeSeconds) || CapsLockHoldTimeSeconds = "") {
        CapsLockHoldTimeSeconds := 0.5
    }
    
    ; 銆愬叧閿慨澶嶃€戣褰曞垵濮嬬姸鎬侊紝蹇呴』鍦ㄦ寜涓嬫椂绔嬪嵆璁板綍锛岀敤浜庢渶鍚庣殑鎭㈠/鍒囨崲閫昏緫
    ; 蹇呴』鍦ㄤ换浣曞彲鑳芥敼鍙楥APSLOCK鐘舵€佺殑鎿嶄綔涔嬪墠璁板綍
    local InitialCapsLockState := GetKeyState("CapsLock", "T")
    
    ; 涓嶅湪鎸変笅鏃跺己鍒舵敼鍐欑姸鎬侊紝淇濈暀绯荤粺鍘熺敓鍒囨崲鏃跺簭
    ; 鍗曞嚮鐢卞師鐢熻涓?+ 閲婃斁鍒嗘敮鍏卞悓淇濊瘉锛岀粍鍚堥敭鍒嗘敮浠嶆寜 CapsLock2 鍥炴粴鐘舵€?
    
    ; 鏍囪 CapsLock 宸叉寜涓?
    CapsLock := true
    CapsLock2 := true  ; 鍒濆鍖栦负 true锛屽鏋滀娇鐢ㄤ簡鍔熻兘浼氳娓呴櫎
    IsCommandMode := false
    
    ; 璁板綍鎸変笅鏃堕棿
    CapsLockPressTime := A_TickCount
    ; 鍙屽嚮鍒ゅ畾锛氫袱娆?CapsLock 瑙﹀彂闂撮殧鍦?300ms 鍐?
    IsCapsDoubleClick := (InStr(A_PriorHotkey, "CapsLock") && A_TimeSincePriorHotkey > 0 && A_TimeSincePriorHotkey <= 300)
    
    ; 濡傛灉姝ｅ湪璇煶杈撳叆鎴栬闊虫悳绱紝澶勭悊鏆傚仠/鎭㈠閫昏緫
    global VoiceInputActive, VoiceSearchActive
    if (VoiceInputActive || VoiceSearchActive) {
        ; 璁剧疆瀹氭椂鍣細300ms 鍚庢竻闄?CapsLock2锛堢敤浜庢娴嬫槸鍚︽寜浜嗗叾浠栭敭锛?
        SetTimer(ClearCapsLock2Timer, -300)
        
        ; 濡傛灉鏈殏鍋滐紝鍒欐殏鍋滆闊宠緭鍏?
        if (!VoiceInputPaused) {
            VoiceInputPaused := true
            UpdateVoiceInputPausedState(true)
            
            ; 浣跨敤 Cursor 鐨勫揩鎹烽敭 Ctrl+Shift+Space 鏆傚仠璇煶杈撳叆
            if (VoiceInputActive) {
                Send("^+{Space}")
                Sleep(200)
            }
        }
        
        ; 绛夊緟 CapsLock 閲婃斁
        KeyWait("CapsLock")
        
        ; 鍋滄瀹氭椂鍣?
        SetTimer(ClearCapsLock2Timer, 0)
        
        ; 璁＄畻鎸変笅鏃堕暱
        PressDuration := A_TickCount - CapsLockPressTime
        
        ; 濡傛灉鎸変簡鍏朵粬閿紙濡俍鎴朏锛夛紝CapsLock2浼氳娓呴櫎锛屼笉鎭㈠璇煶
        ; 濡傛灉鍙寜浜咰apsLock锛圕apsLock2浠嶇劧涓簍rue锛夛紝涓旀槸鐭寜锛屽垯鎭㈠璇煶杈撳叆鎴栨悳绱?
        if (CapsLock2 && PressDuration < 1500) {
            ; 鍙寜浜咰apsLock锛屾病鏈夋寜鍏朵粬閿紝鎭㈠璇煶杈撳叆鎴栨悳绱?
            if (VoiceInputPaused) {
                VoiceInputPaused := false
                if (VoiceInputActive) {
                    UpdateVoiceInputPausedState(false)  ; 鏇存柊鍔ㄧ敾鐘舵€侊紝鏄剧ず鎭㈠
                } else if (VoiceSearchActive) {
                    ; 璇煶鎼滅储鐨勬仮澶嶉€昏緫锛堝鏋滈渶瑕佺殑璇濓級
                }
                
                ; 浣跨敤 Cursor 鐨勫揩鎹烽敭 Ctrl+Shift+Space 鎭㈠璇煶杈撳叆
                if (VoiceInputActive) {
                    Send("^+{Space}")
                    Sleep(200)
                }
            }
        }
        
        ; 銆愬叧閿慨澶嶃€戞仮澶岰APSLOCK鐘舵€佸埌鎸変笅鍓嶇殑鐘舵€侊紝纭繚杈撳叆娉曞彲浠ユ甯稿垏鎹?
        SetCapsLockState(InitialCapsLockState)
        CapsLock := false
        CapsLock2 := false
        return
    }
    
    ; 濡傛灉鏈湪璇煶杈撳叆锛屾墽琛屾甯哥殑 CapsLock+ 閫昏緫
    ; 銆愬叧閿慨澶嶃€戜笉鍐嶈缃瓹learCapsLock2Timer瀹氭椂鍣ㄨ嚜鍔ㄦ竻闄apsLock2
    ; 鍥犱负濡傛灉鑷姩娓呴櫎锛岄暱鎸塁apsLock鏄剧ず闈㈡澘鏃讹紝CapsLock2浼氳鎻愬墠娓呴櫎锛屽鑷撮潰鏉挎棤娉曟樉绀?
    ; CapsLock2鍙簲璇ュ湪浠ヤ笅鎯呭喌琚竻闄わ細
    ; 1. 鐢ㄦ埛鎸変簡缁勫悎閿紙濡侰apsLock+C锛夛紝鐢辩粍鍚堥敭澶勭悊鍑芥暟娓呴櫎
    ; 2. CapsLock閲婃斁鍚庯紝鐢遍噴鏀鹃€昏緫娓呴櫎
    ; SetTimer(ClearCapsLock2Timer, -300)  ; 宸茬Щ闄?

    ; 闀挎寜杈惧埌 CapsLockHoldTimeSeconds 鍚庣敱 ShowPanelTimer 鏄剧ず VK KeyBinder锛堝彲璁剧疆涓績鍏抽棴锛?
    if (CapsLockHoldVkEnabled) {
        HoldTimeMs := Round(CapsLockHoldTimeSeconds * 1000)
        if (HoldTimeMs < 50)
            HoldTimeMs := 50
        SetTimer(ShowPanelTimer, -HoldTimeMs)
    }

    ; 绛夊緟 CapsLock 閲婃斁
    KeyWait("CapsLock")
    SetTimer(ShowPanelTimer, 0)  ; 鍙栨秷鏈Е鍙戠殑闀挎寜妫€娴?
    if (VKHoldVisible) {
        try VK_Hide()
        VKHoldVisible := false
    }
    
    ; 鍙屽嚮 CapsLock锛氬揩鎹烽潰鏉垮紑鍏筹紙宸插紑鍒欏叧锛屽凡鍏冲垯寮€锛夛紝骞舵挙閿€绗竴娆″崟鍑诲澶у皬鍐欑姸鎬佺殑鍒囨崲
    if (CapsLock2 && IsCapsDoubleClick) {
        if (PanelVisible) {
            HideCursorPanel()
        } else {
            ShowCursorPanel()
        }
        ; 鍙屽嚮鏃朵繚鎸佺郴缁熷師鐢?CapsLock 鐘舵€佹祦杞紝涓嶉澶栨敼鍐欏ぇ灏忓啓鐘舵€?
        ; 寤惰繜娓呴櫎 CapsLock 鍙橀噺锛岀粰蹇嵎閿鐞嗗嚱鏁拌冻澶熺殑鏃堕棿
        SetTimer(ClearCapsLockTimer, -100)
        CapsLock2 := false
