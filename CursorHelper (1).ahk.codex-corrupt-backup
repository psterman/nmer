OnPromptManagerDelete() {
    global PromptManagerListView, CurrentPromptFolder, PromptTemplates, SavePromptTemplates, DefaultTemplateIDs
    
    SelectedRow := PromptManagerListView.GetNext()
    if (SelectedRow = 0) {
        return
    }
    
    try {
