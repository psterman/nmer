    }
    
    ExistingWindow := FindCLIAgentWindow(Engine)
    if (ExistingWindow) {
        try {
            WinActivate("ahk_id " . ExistingWindow)
            WinWaitActive("ahk_id " . ExistingWindow, , 3)
        } catch {
