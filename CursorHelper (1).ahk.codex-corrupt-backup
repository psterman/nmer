            QueueWindowPositionSave(WindowName, WinX, WinY, Width, Height)
        } catch as err {
        }
        
        ; 瑙ｉ攣绐楀彛鏇存柊
        DllCall("user32.dll\LockWindowUpdate", "Ptr", 0)
        
