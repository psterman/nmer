        ; 鏇存柊渚ц竟鏍忛珮搴?
        try {
            SidebarBg := GuiID_ConfigGUI["SidebarBg"]
            if (SidebarBg) {
                SidebarBg.Move(, , , Height)
            }
        } catch as err {
