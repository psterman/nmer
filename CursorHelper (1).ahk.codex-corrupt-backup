; 鍒濆鍖?GDI+
; 鍒濆鍖?GDI+
InitGDI() {
    static GdiplusToken := 0
    if (GdiplusToken = 0) {
        ; 纭繚 gdiplus.dll 宸插姞杞?
        if (!DllCall("GetModuleHandle", "Str", "gdiplus", "Ptr")) {
            DllCall("LoadLibrary", "Str", "gdiplus")
        }
        
        ; GdiplusStartupInput 缁撴瀯浣?
        ; 32浣? 4瀛楄妭 (UInt GdiplusVersion) + 4瀛楄妭 (Void* DebugEventCallback) + 4瀛楄妭 (Bool SuppressBackgroundThread) + 4瀛楄妭 (Bool SuppressExternalCodecs) = 16瀛楄妭
        ; 64浣? 4瀛楄妭 (UInt GdiplusVersion) + 8瀛楄妭 (Void* DebugEventCallback) + 4瀛楄妭 (Bool SuppressBackgroundThread) + 4瀛楄妭 (Bool SuppressExternalCodecs) = 20瀛楄妭锛堝榻愬埌24瀛楄妭锛?
        Input := Buffer(A_PtrSize = 8 ? 24 : 16, 0)
        NumPut("UInt", 1, Input, 0)  ; GdiplusVersion = 1
        ; 鍏朵粬瀛楁榛樿涓?0
        
        ; 璋冪敤 GdipStartup锛堜笌浠ｇ爜搴撲腑鍏朵粬 GDI+ 鍑芥暟淇濇寔涓€鑷达紝浣跨敤 Gdip* 鍓嶇紑锛?
        ; GdipStartup(token, input, output)
        ; token: ULONG_PTR* (杈撳嚭鍙傛暟)
        ; input: GdiplusStartupInput* (杈撳叆缁撴瀯)
        ; output: GdiplusStartupOutput* (杈撳嚭缁撴瀯锛屽彲浠ヤ负 NULL)
        ; 杩斿洖鍊硷細Status (UInt)锛? 琛ㄧず鎴愬姛
        ; 娉ㄦ剰锛氬弬鑰冪9474琛岀殑璋冪敤鏂瑰紡锛屼娇鐢?"gdiplus.dll\GdipStartup"
        try {
            Status := DllCall("gdiplus.dll\GdipStartup", "Ptr*", &GdiplusToken := 0, "Ptr", Input, "Ptr", 0, "Int")
            if (Status != 0) {
                OutputDebug("GDI+ 鍒濆鍖栧け璐ワ紝鐘舵€佺爜: " . Status)
                GdiplusToken := 0
            }
        } catch as e {
            OutputDebug("GDI+ 鍒濆鍖栧け璐? " . e.Message)
            GdiplusToken := 0
        }
    }
}

