            TabBtn.SetFont("s10 c" . SelectedText . " Bold", "Segoe UI")
            TabBtn.Redraw()
        } else {
            ; 鏈€変腑鐘舵€?
            TabBtn.Opt("+Background" . UI_Colors.Sidebar)
            TabBtn.SetFont("s10 c" . UI_Colors.Text . " Norm", "Segoe UI")
            TabBtn.Redraw()
