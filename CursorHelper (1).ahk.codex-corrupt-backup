            }
        } else {
            return
        }
        
        ; 妫€鏌ユ槸鍚︽槸榛樿妯℃澘
        IsDefault := false
        for Key, DefaultID in DefaultTemplateIDs {
            if (DefaultID = TargetTemplate.ID) {
                IsDefault := true
                break
            }
        }
        
        if (IsDefault) {
            MsgBox("鏃犳硶鍒犻櫎榛樿妯℃澘", "鎻愮ず", "Icon!")
            return
        }
        
        ; 纭鍒犻櫎
        Quote := Chr(34)
