        }
        
        ; 9. 鍒涘缓缁熶竴鎼滅储瑙嗗浘 v_GlobalSearch
        ClipboardDB.Exec("DROP VIEW IF EXISTS v_GlobalSearch")
        SQL := "CREATE VIEW v_GlobalSearch AS " .
               "SELECT " .
               "  Title, " .
               "  Content, " .
               "  'prompt' AS Source, " .
               "  Timestamp, " .
               "  ID AS OriginalID " .
               "FROM Prompts " .
               "UNION ALL " .
               "SELECT " .
               "  SUBSTR(Content, 1, 100) AS Title, " .
               "  Content, " .
