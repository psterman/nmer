        ; 妫€鏌ュ瓧娈垫槸鍚﹀瓨鍦紝鍔ㄦ€佹瀯寤烘煡璇?
        SQL := "PRAGMA table_info(ClipMain)"
        tableInfo := ""
        hasLastCopyTime := false
