    global GuiID_ConfigGUI, CursorPath, AISleepTime
    
    try {
        ; 鐩存帴浣跨敤妯℃澘鍐呭锛屼笉闇€瑕佷粠缂栬緫妗嗚幏鍙栵紙鍥犱负鏂扮晫闈㈡病鏈夌紪杈戞锛?
        Content := Template.Content
        
        ; 妫€鏌?Cursor 鏄惁杩愯
        if (!WinExist("ahk_exe Cursor.exe")) {
            if (CursorPath != "" && FileExist(CursorPath)) {
                Run(CursorPath)
                Sleep(AISleepTime)
            } else {
                TrayTip("Cursor鏈繍琛?, "閿欒", "Iconx 2")
                return
            }
        }
        
        ; 婵€娲?Cursor 绐楀彛
