    FunctionCategories["Refactor"] := {Name: IsZh ? "閲嶆瀯" : "Refactor", SortWeight: 2}
    FunctionCategories["Optimize"] := {Name: IsZh ? "浼樺寲" : "Optimize", SortWeight: 3}
    
    ; 妯℃澘绯诲垪瀹氫箟锛堜簩绾у垎绫伙級
    SeriesCategories := Map()
    SeriesCategories["Basic"] := {Name: IsZh ? "鍩虹" : "Basic", SortWeight: 1}
    SeriesCategories["Professional"] := {Name: IsZh ? "涓撲笟" : "Professional", SortWeight: 2}
