    } catch as e {
        ; 濡傛灉鍒涘缓澶辫触锛屾樉绀洪敊璇俊鎭?
        TrayTip("鍒涘缓鎮诞闈㈡澘澶辫触: " . e.Message, GetText("error"), "Iconx 2")
