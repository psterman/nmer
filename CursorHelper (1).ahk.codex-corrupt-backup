        }
        
        ; 鏇存柊搴曢儴鎸夐挳浣嶇疆
        try {
            ButtonAreaY := Height - 70
            BtnWidth := 80
            BtnSpacing := 10
            BtnStartX := Width - (BtnWidth * 2 + BtnSpacing) - 20
            
            SaveBtn := GuiID_ConfigGUI["SaveBtn"]
            if (SaveBtn) {
                SaveBtn.Move(BtnStartX, ButtonAreaY + 10)
