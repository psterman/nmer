CreateRadioClickHandler(Index, Desc, TypeIndex, RadioControls) {
    ; 杩斿洖涓€涓嚱鏁帮紝璇ュ嚱鏁颁細鎵嬪姩绠＄悊浜掓枼骞舵洿鏂拌鏄庢枃瀛?
