                    ; 鍦ㄦ爣绛惧垏鎹㈡湡闂达紝涓嶆墽琛屽鍒舵搷浣?
                    return true  ; 宸插鐞嗭紙闃绘澶嶅埗锛?
                }
                
                ; 鍙岄噸妫€鏌ワ細2. 濡傛灉鍓创鏉跨鐞嗛潰鏉垮凡鎵撳紑锛岄澶栨鏌ユ槸鍚︽槸鏍囩鐐瑰嚮鏈熼棿
                ; 杩欎釜妫€鏌ユ槸涓轰簡闃叉鍦ㄧ偣鍑绘爣绛炬椂锛孋apsLock 閿繕澶勪簬鎸変笅鐘舵€佸鑷寸殑鎰忓瑙﹀彂
                if (GuiID_ClipboardManager != 0 && CapsLockCopyInProgress && CapsLockCopyEndTime > A_TickCount) {
                    ; 鍦ㄦ爣绛剧偣鍑绘湡闂翠笖鍓创鏉跨鐞嗛潰鏉挎墦寮€鏃讹紝涓嶆墽琛屽鍒舵搷浣?
                    return true  ; 宸插鐞嗭紙闃绘澶嶅埗锛?
                }
                
                ; 纭繚 CapsLock 鍙橀噺淇濇寔涓?true锛岀洿鍒板鍒跺畬鎴?
                global CapsLock
                CapsLock := true
                ; 璋冪敤澶嶅埗鍑芥暟
                CapsLockCopy()
            case "V":
                CapsLockPaste()
            case "X":
                CapsLock2 := false
                CP_Show()
            case "E":
