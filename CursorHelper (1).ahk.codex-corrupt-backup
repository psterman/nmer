                } else {
                    ; 濡傛灉鏈湪璇煶杈撳叆锛屽紑濮嬭闊宠緭鍏?
                    StartVoiceInput()
                }
            case "F":
                CapsLock2 := false
                global VoiceSearchActive
                ; 銆愬叧閿慨澶嶃€戠‘淇濆彉閲忓凡鍒濆鍖?
                if (!IsSet(VoiceSearchPanelVisible)) {
                    VoiceSearchPanelVisible := false
                }
                if (!IsSet(VoiceSearchActive)) {
