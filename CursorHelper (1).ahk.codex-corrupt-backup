    lenT := StrLen(tL)
    pos := []
    start := 1
    Loop lenQ {
        ch := SubStr(qL, A_Index, 1)
        found := InStr(tL, ch, false, start)
        if (!found)
            return -100
        pos.Push(found)
        start := found + 1
    }
    slashCount := 0
    Loop lenT {
        if (SubStr(target, A_Index, 1) = "\")
            slashCount += 1
    }
    score := 0.0
    ; 绮惧噯锛氭暣娈靛叧閿瘝鍦ㄨ矾寰勪腑杩炵画鍑虹幇锛堟瘮瀛愬簭鍒楁洿璐磋繎銆屾墦浠€涔堟悳浠€涔堛€嶏級
    if (InStr(tL, qL))
        score += 480.0
    ; 绮惧噯锛氳矾寰勪互鍏抽敭璇嶅紑澶达紙鍓嶇紑鍖归厤锛?
    if (StrLen(qL) <= lenT && SubStr(tL, 1, lenQ) = qL)
        score += 220.0
    ; 绮惧噯锛氫粎鐪嬫渶鍚庝竴娈垫枃浠跺悕锛堢敤鎴峰鎼滄枃浠跺悕鑰岄潪鐩樼璺緞锛?
    fnSeg := target
    Loop {
        p := InStr(fnSeg, "\")
        if (!p)
            break
        fnSeg := SubStr(fnSeg, p + 1)
    }
    fnL := StrLower(fnSeg)
    if (fnL = qL)
        score += 420.0
    else if (StrLen(qL) <= StrLen(fnL) && SubStr(fnL, 1, lenQ) = qL)
        score += 260.0
    else if (InStr(fnL, qL))
        score += 140.0
    ; 棣栧瓧锛氱涓€娆″懡涓湪 target 绗?1 浣?
    if (pos[1] = 1)
        score += 100
    for k, p in pos {
        curCh := SubStr(target, p, 1)
        if (p > 1) {
            prevCh := SubStr(target, p - 1, 1)
            oPrev := Ord(prevCh)
            ; 璇嶉/杈圭晫锛氬垎闅旂鍚庡尮閰?
            if (prevCh = "\" || prevCh = "/" || prevCh = "_" || prevCh = "-" || prevCh = "." || prevCh = " ")
                score += 80
            ; CamelCase锛氬皬鍐欏悗璺熷ぇ鍐?
            oCur := Ord(curCh)
            if (oCur >= 65 && oCur <= 90 && oPrev >= 97 && oPrev <= 122)
                score += 60
        }
        if (k > 1) {
            prevP := pos[k - 1]
            gap := p - prevP - 1
            score -= 2 * gap
            ; 杩炵画鎬э細涓庡墠涓€娆″懡涓浉閭?
            if (p = prevP + 1)
                score += 50
        }
    }
    ; 璺緞娣卞害锛氭€婚暱涓庡弽鏂滄潬瓒婂鐣ユ墸鍒嗭紝娴呭眰璺緞浼樺厛
    score -= StrLen(target) * 0.02
    score -= slashCount * 1.0
    return score
}

ComputeSearchItemFinalScore(Item, Keyword, path) {
