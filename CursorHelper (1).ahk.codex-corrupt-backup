                } else {
                    TrayTip("鍥剧墖鏂囦欢涓嶅瓨鍦?, Content, "Iconx 2")
                }
            } catch as err {
                TrayTip("鎵撳紑鍥剧墖澶辫触", err.Message, "Iconx 2")
            }
        } else {
            ; 鍏朵粬绫诲瀷锛氬鍒跺唴瀹瑰埌鍓创鏉垮苟绮樿创
            A_Clipboard := Content
