                    path := result
                    SplitPath(path, &FileName, &DirPath, &Ext, &NameNoExt)
                    
                    ResultItem := {
                        DataType: "file",
                        DataTypeName: "鏂囦欢",
                        ID: path,
                        Title: FileName,
                        SubTitle: DirPath . " 路 " . (Ext ? Ext : "鏂囦欢"),
                        Content: path,
                        Preview: path,
                        Source: "鏂囦欢",
                        Metadata: Map(
                            "FilePath", path,
                            "FileName", FileName,
                            "DirPath", DirPath,
                            "Ext", Ext ? Ext : "",
                            "Timestamp", ""
                        ),
                        Action: "open_file",
                        ActionParams: Map("FilePath", path)
                    }
                }
                
                Results.Push(ResultItem)
            }
    } catch as err {
        ; 濡傛灉Everything鎼滅储澶辫触锛岀户缁娇鐢ㄦ暟鎹簱鎼滅储浣滀负鍥為€€
        OutputDebug("AHK_DEBUG: Everything DLL 鎼滅储澶辫触: " . err.Message)
        EverythingUserTipOnce("鏂囦欢鎼滅储寮傚父: " . err.Message)
    }
    
    ; 濡傛灉Everything鎼滅储缁撴灉宸叉弧瓒抽渶姹傦紝鐩存帴杩斿洖
    if (Results.Length >= MaxResults) {
        FinalizeSearchFilePathsResults(&Results, Keyword)
        return Results
    }
    
    ; 鍥為€€鍒版暟鎹簱鎼滅储锛氫粠鍓创鏉垮巻鍙蹭腑鎻愬彇鏂囦欢璺緞锛堜綔涓鸿ˉ鍏咃級
    if (!ClipboardDB || ClipboardDB = 0) {
        FinalizeSearchFilePathsResults(&Results, Keyword)
        return Results
    }
    
    ; 銆愬叆鍙ｇ啍鏂€戝湪鎵ц Prepare 涔嬪墠锛屽繀椤诲厛妫€鏌ュ苟閲婃斁鏃у彞鏌?
    if (IsObject(global_ST) && global_ST.HasProp("Free")) {
        try {
            global_ST.Free()
        } catch as err {
        }
        global_ST := 0
    }
    
    KeywordLower := StrLower(Keyword)
    Count := Results.Length  ; 浠庡凡鏈夌粨鏋滄暟閲忓紑濮嬭鏁?
    
    ; 浠庡壀璐存澘鍘嗗彶涓彁鍙栨枃浠惰矾寰?
    ; 浣跨敤LOWER()鍑芥暟杩涜澶у皬鍐欎笉鏁忔劅鐨勬悳绱?
    SQL := "SELECT DISTINCT Content, Timestamp FROM ClipboardHistory WHERE (LOWER(Content) LIKE ? OR LOWER(Content) LIKE ?) ORDER BY Timestamp DESC LIMIT ?"
    ST := ""
    try {
        if (!ClipboardDB.Prepare(SQL, &ST)) {
            FinalizeSearchFilePathsResults(&Results, Keyword)
            return Results
        }
        
        ; 鏇存柊鍏ㄥ眬鍙ユ焺
        global_ST := ST
        
        ; 妫€鏌T鏄惁鏄湁鏁堢殑Statement瀵硅薄
        if (!IsObject(ST) || !ST.HasProp("Bind")) {
            FinalizeSearchFilePathsResults(&Results, Keyword)
            return Results
        }
        
        ; 鎼滅储璺緞鏍煎紡锛圵indows璺緞銆乁RL绛夛級锛屼娇鐢ㄥ皬鍐欏叧閿瘝
        ; 闄愬埗鏁伴噺涓哄墿浣欓渶瑕佺殑鏁伴噺
        RemainingCount := MaxResults - Count
        if (RemainingCount <= 0) {
            FinalizeSearchFilePathsResults(&Results, Keyword)
            return Results
        }
        
        if (!ST.Bind(1, "Text", "%" . KeywordLower . "%")) {
            FinalizeSearchFilePathsResults(&Results, Keyword)
            return Results
        }
        if (!ST.Bind(2, "Text", "file://%" . KeywordLower . "%")) {
            FinalizeSearchFilePathsResults(&Results, Keyword)
            return Results
        }
        if (!ST.Bind(3, "Int", RemainingCount * 2)) {
            FinalizeSearchFilePathsResults(&Results, Keyword)
            return Results
        }
        
        while (ST.Step() && Count < MaxResults) {
            Content := ST.Column(0)
            Timestamp := ST.Column(1)
            
            ; 妫€鏌ユ槸鍚︿负鏂囦欢璺緞
            if (IsFilePath(Content)) {
                SplitPath(Content, &FileName, &DirPath, &Ext, &NameNoExt)
                
                ; 妫€鏌ユ枃浠跺悕鎴栬矾寰勬槸鍚﹀尮閰嶅叧閿瘝
                if (InStr(StrLower(FileName), KeywordLower) || InStr(StrLower(Content), KeywordLower)) {
                    ; 妫€鏌ユ槸鍚﹀凡瀛樺湪锛堥伩鍏嶉噸澶嶏級
                    IsDuplicate := false
                    for Index, ExistingItem in Results {
                        if (ExistingItem.Content = Content) {
                            IsDuplicate := true
                            break
                        }
                    }
                    
                    if (!IsDuplicate) {
                        ResultItem := {
                            DataType: "file",
                            DataTypeName: "鏂囦欢璺緞",
                            ID: Content,
                            Title: FileName,
                            SubTitle: DirPath . " 路 " . (Ext ? Ext : "鏂囦欢"),
                            Content: Content,
                            Preview: Content,
                            Source: "鏂囦欢璺緞",
                            Metadata: Map(
                                "FilePath", Content,
                                "FileName", FileName,
                                "DirPath", DirPath,
                                "Ext", Ext ? Ext : "",
                                "Timestamp", Timestamp
                            ),
                            Action: "open_file",
                            ActionParams: Map("FilePath", Content)
                        }
                        
                        Results.Push(ResultItem)
                        Count++
                    }
                }
            }
        }
    } catch as e {
        ; 閿欒澶勭悊
    } finally {
        ; 銆愯繃绋嬩繚搴曘€戞棤璁烘煡璇㈡垚鍔熻繕鏄姤閿欙紝閮藉湪 finally 鍧椾腑寮哄埗鎵ц global_ST.Free()
        try {
            if (IsObject(global_ST) && global_ST.HasProp("Free")) {
                global_ST.Free()
            }
            global_ST := 0
        } catch as err {
        }
    }
    
    FinalizeSearchFilePathsResults(&Results, Keyword)
    return Results
}

