                }
                if (VoiceSearchPanelVisible) {
                    ; 闈㈡澘宸叉樉绀?
                    if (VoiceSearchActive) {
                        ; 姝ｅ湪璇煶杈撳叆锛屽仠姝㈠苟鎵ц鎼滅储
