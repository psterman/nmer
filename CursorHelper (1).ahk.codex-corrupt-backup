; ===================== 鍒犻櫎妯℃澘 =====================
DeleteTemplateFromEdit(TemplateKey, Template) {
    global GuiID_ConfigGUI, PromptTemplates, DefaultTemplateIDs, SavePromptTemplates, ExpandedTemplateKey
    
    ; 妫€鏌ユ槸鍚︽槸榛樿妯℃澘
    IsDefault := false
    for Type, TemplateID in DefaultTemplateIDs {
        if (TemplateID = Template.ID) {
            IsDefault := true
            break
        }
    }
    
    if (IsDefault) {
        TrayTip("鏃犳硶鍒犻櫎榛樿妯℃澘锛岃鍏堝彇娑堥粯璁よ缃?, "鎻愮ず", "Icon! 2")
        return
    }
    
    ; 纭鍒犻櫎
    Quote := Chr(34)
    Result := MsgBox("纭畾瑕佸垹闄ゆā鏉?" . Quote . Template.Title . Quote . " 鍚楋紵", "纭鍒犻櫎", "YesNo Icon?")
    if (Result != "Yes") {
        return
    }
    
    try {
        ; 浠庢暟缁勪腑鍒犻櫎
        for Index, T in PromptTemplates {
            if (T.ID = Template.ID) {
                PromptTemplates.RemoveAt(Index)
                break
            }
        }
        
        ; 濡傛灉褰撳墠灞曞紑鐨勬槸琚垹闄ょ殑妯℃澘锛屾姌鍙犲畠
        if (ExpandedTemplateKey = TemplateKey) {
            ExpandedTemplateKey := ""
        }
        
        ; 淇濆瓨閰嶇疆
        SavePromptTemplates()
        
        ; 鍒锋柊UI锛堥噸鏂板垱寤烘ā鏉跨鐞嗘爣绛鹃〉锛?
        RefreshPromptsManageTab()
        
        TrayTip("妯℃澘宸插垹闄?, "鎻愮ず", "Iconi 1")
    } catch as e {
        TrayTip("鍒犻櫎澶辫触: " . e.Message, "閿欒", "Iconx 2")
    }
}

