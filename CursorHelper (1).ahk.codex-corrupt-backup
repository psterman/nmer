            }
            if (StrLower(btnHotkey) = KeyLower) {
                ; 鍖归厤鍒板揩鎹锋搷浣滄寜閽紙CapsLock2宸插湪涓婇潰娓呴櫎锛?
                ; 绔嬪嵆闅愯棌闈㈡澘
                if (PanelVisible) {
                    HideCursorPanel()
