                A_AppData . "\npm\codex.cmd",
                LocalAppDataDir . "\npm\codex.cmd",
                LocalAppDataDir . "\npm-global\codex.cmd",
                "codex.cmd"
            ]
        case "gemini_cli":
            Candidates := [
                A_AppData . "\npm\gemini.cmd",
                A_AppData . "\npm-global\gemini.cmd",
                "gemini.cmd"
            ]
        case "openclaw_cli":
            Candidates := [
