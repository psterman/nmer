<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>鎼滅储涓績</title>
<link rel="stylesheet" href="https://app.local/assets/vendor/prism/prism-tomorrow.min.css">
<style>
:root {
  --bg: #111315;
  --panel: #171a1e;
  --panel-2: #1f2429;
  --border: #313941;
  --glass-edge: rgba(255,255,255,.28);
  --glass-edge-soft: rgba(255,255,255,.08);
  --glass-warm: rgba(255,171,92,.2);
  --text: #e7ebef;
  --muted: #93a0ad;
  --accent: #ff8d2a;
  --accent-2: #ffb347;
  --shadow: 0 18px 42px rgba(0, 0, 0, 0.35);
  --font-ui: "Segoe UI", "Microsoft YaHei UI", sans-serif;
  --font-mono: Consolas, "Cascadia Mono", monospace;
}
* { box-sizing: border-box; }
html, body {
  margin: 0;
  width: 100%;
  height: 100%;
  min-height: 0;
  background: radial-gradient(circle at top right, rgba(255,141,42,.08), transparent 26%), linear-gradient(180deg, #0f1113 0%, #15181c 100%);
  color: var(--text);
  font-family: var(--font-ui);
  overflow: hidden;
}
button, input, select, textarea { font: inherit; }
#app {
  display: grid;
  grid-template-rows: auto auto auto 1fr auto;
  width: 100%;
  height: 100%;
  min-height: 0;
  gap: 12px;
  padding: 14px 26px 18px;
}
/* 椤绘樉绀烘爣棰樻爮锛氭瀬閫?鏍囧噯 涓庣獥鍙ｆ帶鍒跺湪姝わ紱鍕?display:none锛堜細闅愯棌寮曟搸鍒囨崲锛?*/
#chrome-header {
  display: flex;
}
.chrome-header {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 36px;
  margin: -6px -10px 2px;
  padding: 6px 12px;
  border-radius: 12px;
  background: linear-gradient(180deg, rgba(255,255,255,.09), rgba(255,255,255,.01)), rgba(26,31,38,.45);
  border: 1px solid rgba(255,255,255,.14);
  box-shadow: inset 0 1px 0 rgba(255,255,255,.22);
  user-select: none;
  -webkit-user-select: none;
  cursor: grab;
}
.chrome-header:active { cursor: grabbing; }
.chrome-drag {
  flex: 1;
  text-align: center;
  font-size: 13px;
  font-weight: 600;
  color: var(--muted);
  letter-spacing: 0.02em;
  cursor: grab;
  padding: 4px 8px;
  border-radius: 8px;
}
.chrome-drag:active { cursor: grabbing; }
.chrome-controls {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  flex-shrink: 0;
}
.chrome-btn {
  flex-shrink: 0;
  width: 26px;
  height: 26px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: 1px solid var(--border);
  border-radius: 8px;
  background: var(--panel-2);
  color: var(--text);
  cursor: pointer;
  font-size: 14px;
  line-height: 1;
}
.chrome-btn:hover {
  border-color: rgba(255,179,71,.5);
  background: linear-gradient(180deg, rgba(255,179,71,.16), rgba(255,141,42,.12));
  color: #fff;
}
.chrome-btn.active {
  border-color: rgba(255,179,71,.72);
  background: linear-gradient(180deg, rgba(255,179,71,.24), rgba(255,141,42,.2));
  color: #fff;
}
#chrome-topmost {
  width: auto;
  min-width: 44px;
  padding: 0 8px;
  font-size: 12px;
  font-weight: 600;
}
#btn-ft-settings-top {
  width: auto;
  min-width: 72px;
  padding: 0 8px;
  font-size: 12px;
  gap: 4px;
}
#btn-ft-settings-top .icon {
  font-size: 13px;
  opacity: .95;
}
.chrome-engine-btn {
  flex-shrink: 0;
  height: 26px;
  padding: 0 8px;
  min-width: 44px;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.02em;
  border: 1px solid rgba(255,179,71,.35);
  border-radius: 8px;
  background: linear-gradient(180deg, rgba(255,179,71,.14), rgba(255,141,42,.08));
  color: var(--text);
  cursor: pointer;
}
.chrome-engine-btn:hover {
  border-color: rgba(255,179,71,.55);
  background: linear-gradient(180deg, rgba(255,179,71,.22), rgba(255,141,42,.14));
}
.chrome-engine-btn.ahk-mode {
  border-color: var(--border);
  background: var(--panel-2);
}
#search-bar .chrome-engine-btn {
  min-height: 40px;
  align-self: center;
}

/* ClipboardPanel 椋庢牸锛氬紩鎿庡垎娈垫寜閽紙鏋侀€?鏍囧噯锛?*/
.engine-mode-group {
  display: inline-flex;
  border: 1px solid var(--border);
  border-radius: 9px;
  overflow: hidden;
  flex-shrink: 0;
}
.engine-mode-btn {
  height: 26px;
  padding: 0 10px;
  border: none;
  background: var(--panel-2);
  color: var(--muted);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.02em;
  cursor: pointer;
  white-space: nowrap;
}
#search-bar .engine-mode-btn { min-height: 40px; }
.engine-mode-btn:hover {
  color: var(--text);
  background: #262c33;
}
.engine-mode-btn.active {
  background: linear-gradient(180deg, rgba(255,179,71,.22), rgba(255,141,42,.14));
  color: #fff;
  box-shadow: inset 0 0 0 1px rgba(255,179,71,.35);
}
.engine-mode-btn + .engine-mode-btn {
  border-left: 1px solid var(--border);
}
.bar {
  display: flex;
  align-items: center;
  gap: 10px;
  min-width: 0;
}
.card {
  position: relative;
  overflow: hidden;
  background: linear-gradient(180deg, rgba(255,255,255,.02), rgba(255,255,255,0)), var(--panel);
  border: 1px solid rgba(255,255,255,.12);
  border-radius: 16px;
  box-shadow: var(--shadow), inset 0 1px 0 rgba(255,255,255,.12);
}
.card::after,
.chrome-header::after {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: inherit;
  padding: 1px;
  background: linear-gradient(135deg, var(--glass-edge), var(--glass-edge-soft) 45%, var(--glass-warm));
  -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  pointer-events: none;
  opacity: 0.72;
}
#search-bar {
  position: relative;
  flex-shrink: 0;
  display: flex;
  align-items: flex-start;
  gap: 8px;
  padding: 14px 18px;
  border: 1px solid rgba(255,255,255,.12);
  border-radius: 16px;
  background: linear-gradient(180deg, rgba(255,255,255,.02), rgba(255,255,255,0)), var(--panel);
  box-shadow: var(--shadow), inset 0 1px 0 rgba(255,255,255,.12);
}
#search-icon-inline {
  color: var(--accent);
  font-size: 16px;
  flex-shrink: 0;
}
#search {
  width: 100%;
  display: block;
  min-width: 0;
  height: 44px;
  background: var(--panel-2);
  border: 1px solid var(--border);
  border-radius: 12px;
  color: var(--text);
  padding: 0 14px;
  outline: none;
  caret-color: var(--accent);
  user-select: text;
  -webkit-user-select: text;
}
#search::placeholder { color: #6f7d8b; }
#search:focus, #limit:focus { border-color: var(--accent); }
.search-input-wrap {
  flex: 1 1 auto;
  width: 100%;
  min-width: 0;
}
.search-status-inline {
  margin-top: 6px;
  padding-left: 2px;
  font-size: 11px;
  color: #7f8a95;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.fulltext-inline {
  margin-top: 4px;
  display: flex;
  align-items: center;
  gap: 6px;
  min-height: 14px;
  color: #8ea0ad;
  font-size: 10px;
  white-space: nowrap;
  overflow: hidden;
}
.ft-mini-light {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #3f3f3f;
  opacity: .75;
  flex: 0 0 auto;
  transform: scale(1);
  transition: background-color .24s ease, box-shadow .24s ease, opacity .24s ease, transform .24s ease;
  will-change: transform, opacity;
}
.ft-mini-light.active {
  background: #22d3ee;
  box-shadow: 0 0 8px rgba(34,211,238,.9);
  animation: ft-mini-breath 1.35s cubic-bezier(.4,0,.2,1) infinite both;
}
.ft-mini-light.ready {
  background: #4ade80;
  box-shadow: 0 0 8px rgba(74,222,128,.9);
  opacity: .95;
  transform: scale(1);
}
.ft-mini-light.warn {
  background: #f97316;
  box-shadow: 0 0 8px rgba(249,115,22,.95);
  animation: ft-mini-breath .95s cubic-bezier(.4,0,.2,1) infinite both;
}
#ftl1.active, #ftl1.warn { animation-delay: 0ms; }
#ftl2.active, #ftl2.warn { animation-delay: 110ms; }
#ftl3.active, #ftl3.warn { animation-delay: 220ms; }
#ftl4.active, #ftl4.warn { animation-delay: 330ms; }
.ft-mini-file {
  overflow: hidden;
  text-overflow: ellipsis;
}
.ft-scan-badge {
  font-size: 9px;
  padding: 1px 6px;
  border-radius: 6px;
  background: var(--panel-2);
  border: 1px solid var(--border);
  color: #8eb9ff;
  flex: 0 0 auto;
  letter-spacing: 0.02em;
}
.ft-scheme-panel {
  margin-top: 6px;
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: wrap;
  font-size: 11px;
}
.ft-advanced-wrap {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  flex-wrap: wrap;
}
.ft-advanced-wrap.hidden {
  display: none;
}
.ft-scheme-panel .mini-select {
  height: 24px;
  border: 1px solid var(--border);
  border-radius: 8px;
  background: var(--panel-2);
  color: var(--text);
  padding: 0 8px;
  min-width: 118px;
}
.ft-scheme-panel .mini-btn {
  height: 24px;
  padding: 0 10px;
  border-radius: 8px;
  border: 1px solid var(--border);
  background: var(--panel-2);
  color: var(--text);
  cursor: pointer;
}
.ft-scheme-panel .mini-btn:hover {
  border-color: rgba(255,179,71,.5);
}
.ft-scheme-panel .mini-check {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  color: #9eb0bd;
}
.ft-probe-summary {
  color: #9eb0bd;
}
.ft-probe-list {
  margin-top: 4px;
  display: grid;
  gap: 4px;
  max-height: 120px;
  overflow: auto;
  font-size: 10px;
  color: #9eb0bd;
}
.ft-probe-item {
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 4px 8px;
  background: rgba(255,255,255,.02);
}
.ft-probe-ok {
  color: #4ade80;
}
.ft-probe-bad {
  color: #f97316;
}
.hit-context-wrap {
  margin-top: 5px;
  width: 100%;
  min-width: 0;
}
.hit-ctx-btn {
  font-size: 10px;
  padding: 2px 8px;
  border-radius: 8px;
  border: 1px solid var(--border);
  background: var(--panel-2);
  color: var(--text);
  cursor: pointer;
}
.hit-ctx-body {
  margin-top: 5px;
  font-size: 11px;
  line-height: 1.4;
  color: #9fb0bd;
  white-space: normal;
  max-height: 140px;
  overflow: auto;
  border-left: 2px solid rgba(34, 211, 238, 0.35);
  padding-left: 8px;
}
.hit-ctx-body.hidden {
  display: none;
}
@keyframes ft-mini-breath {
  0%, 100% { opacity: .58; transform: scale(.92); }
  35% { opacity: 1; transform: scale(1.14); }
  70% { opacity: .74; transform: scale(1.01); }
}
.search-actions {
  display: flex;
  align-items: center;
  flex-wrap: nowrap;
  gap: 6px 8px;
  flex: 0 0 auto;
  margin-left: auto;
}
#limit {
  width: 122px;
  height: 36px;
  border: 1px solid var(--border);
  border-radius: 12px;
  background: var(--panel-2);
  color: var(--text);
  padding: 0 10px;
  outline: none;
}
.search-actions .btn {
  height: 36px;
  padding: 0 12px;
}
#results-head {
  flex-shrink: 0;
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: center;
  gap: 10px;
}
#head-filters {
  min-width: 0;
  position: relative;
  z-index: 1;
}
#filters {
  display: flex;
  gap: 8px;
  overflow: auto hidden;
  padding: 2px 0;
}
#categories,
#engines {
  display: flex;
  gap: 10px;
  overflow: auto hidden;
  padding: 8px 10px;
}
#categories::-webkit-scrollbar,
#engines::-webkit-scrollbar,
#filters::-webkit-scrollbar,
#result-list::-webkit-scrollbar,
#preview-web-scroll::-webkit-scrollbar {
  height: 8px;
  width: 8px;
}
#categories::-webkit-scrollbar-thumb,
#engines::-webkit-scrollbar-thumb,
#filters::-webkit-scrollbar-thumb,
#result-list::-webkit-scrollbar-thumb,
#preview-web-scroll::-webkit-scrollbar-thumb {
  background: #3a434d;
  border-radius: 999px;
}
#category-card, #engine-card, #filter-card { padding: 10px 12px; }
#tag-card {
  padding: 10px 12px;
  display: grid;
  grid-template-rows: auto auto;
  gap: 10px;
}
.chip, .engine-chip, .filter-chip {
  border: 1px solid var(--border);
  background: var(--panel-2);
  color: var(--muted);
  border-radius: 999px;
  cursor: pointer;
  transition: .16s ease;
}
.chip {
  padding: 10px 14px;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  white-space: nowrap;
}
.chip .chip-main {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 3px;
  min-width: 0;
}
.chip .chip-title {
  line-height: 1.05;
}
.chip.active, .filter-chip.active, .engine-chip.active {
  background: linear-gradient(180deg, rgba(255,179,71,.16), rgba(255,141,42,.12));
  border-color: rgba(255,179,71,.5);
  color: #fff;
}
.chip .count {
  min-width: 22px;
  padding: 2px 7px;
  border-radius: 999px;
  background: rgba(255,255,255,.06);
  color: inherit;
  font-size: 11px;
  text-align: center;
}
.engine-chip {
  min-width: 64px;
  max-width: 92px;
  padding: 10px 8px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  gap: 8px;
  border-radius: 14px;
}
.engine-chip .engine-icon-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
}
.engine-chip img, .engine-fallback {
  width: 32px;
  height: 32px;
  border-radius: 10px;
  flex: 0 0 auto;
  display: block;
}
.engine-fallback {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #303842;
  color: #fff;
  font-size: 13px;
  font-weight: 700;
}
.engine-chip .label {
  width: 100%;
  text-align: center;
  font-size: 11px;
  line-height: 1.25;
  color: var(--muted);
  white-space: normal;
  word-break: break-all;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.engine-chip.active .label { color: #fff; }
.filter-chip {
  padding: 5px 10px;
  font-size: 11px;
  display: inline-flex;
  align-items: center;
  gap: 7px;
  white-space: nowrap;
}
.filter-chip .filter-label { line-height: 1; }
.hotkey-hint {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 14px;
  padding: 0 6px;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,.08);
  background: rgba(255,255,255,.03);
  color: #7f8a95;
  font-size: 10px;
  line-height: 1.2;
  letter-spacing: .02em;
}
.hotkey-hint.unbound {
  border-style: dashed;
  opacity: .72;
}
.engine-chip .hotkey-hint {
  margin-top: 1px;
}
.caps-hotkey-ready {
  border-color: rgba(255,179,71,.45) !important;
  box-shadow: 0 0 0 1px rgba(255,179,71,.16) inset;
}
.caps-hotkey-hit {
  border-color: rgba(255,179,71,.82) !important;
  box-shadow: 0 0 0 1px rgba(255,179,71,.42) inset, 0 0 18px rgba(255,141,42,.28);
  transform: translateY(-1px);
}
.caps-hotkey-hit .hotkey-hint {
  color: #fff;
  border-color: rgba(255,200,120,.72);
  background: rgba(255,141,42,.24);
}
#layout {
  display: grid;
  grid-template-columns: minmax(380px, 1.1fr) minmax(320px, .9fr);
  gap: 16px;
  min-height: 0;
}
#results-card, #preview-card {
  min-height: 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}
#results-head {
  flex-shrink: 0;
  display: grid;
  grid-template-columns: auto minmax(0, 1fr) auto;
  align-items: center;
  gap: 12px;
  padding: 14px 18px;
  border-bottom: 1px solid var(--border);
  background: rgba(255,255,255,.02);
}
#preview-head {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 14px 18px;
  border-bottom: 1px solid var(--border);
  background: rgba(255,255,255,.02);
}
#results-head .head-sub {
  justify-self: end;
  pointer-events: none;
}
.head-title {
  font-size: 14px;
  font-weight: 700;
}
.head-sub {
  font-size: 12px;
  color: var(--muted);
}
#result-list {
  flex: 1 1 auto;
  min-height: 0;
  overflow: auto;
  padding: 10px 12px 12px;
  display: flex;
  flex-direction: column;
}
.result-item {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 8px;
  padding: 9px 10px;
  border: 1px solid transparent;
  border-radius: 10px;
  cursor: pointer;
  transition: .14s ease;
}
.result-item + .result-item { margin-top: 5px; }
.result-item:hover {
  background: rgba(255,255,255,.03);
  border-color: rgba(255,255,255,.05);
}
.result-item.active {
  background: linear-gradient(180deg, rgba(255,141,42,.16), rgba(255,141,42,.06));
  border-color: rgba(255,179,71,.45);
}
.result-title {
  font-size: 13px;
  font-weight: 600;
  color: #fff;
}
.pin-ico {
  display: inline-block;
  margin-right: 5px;
  font-size: 12px;
  vertical-align: middle;
  opacity: 0.95;
  user-select: none;
}
.result-sub {
  margin-top: 3px;
  font-size: 11px;
  color: var(--muted);
}
.result-preview {
  margin-top: 4px;
  color: #ccd5dd;
  font-size: 11px;
  line-height: 1.35;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.result-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8px;
  min-width: 92px;
}
.pill {
  padding: 3px 7px;
  border-radius: 999px;
  background: #2a3239;
  color: #d7dee6;
  font-size: 10px;
}
.time {
  font-size: 10px;
  color: var(--muted);
  text-align: right;
}
#preview-panel {
  flex: 1 1 auto;
  min-height: 0;
  display: flex;
  flex-direction: column;
  position: relative;
}
#preview-main {
  flex: 1 1 auto;
  min-height: 0;
  display: flex;
  flex-direction: column;
  position: relative;
}
#preview-web-scroll {
  flex: 1 1 auto;
  min-height: 0;
  overflow: auto;
  padding: 16px 18px 18px;
  white-space: pre-wrap;
  word-break: break-word;
  font-family: var(--font-mono);
  line-height: 1.65;
  font-size: 12px;
  color: #d6dde5;
}
.pdfjs-viewport {
  width: 100%;
  min-height: 200px;
  max-height: min(78vh, 920px);
  overflow: auto;
  background: #262a2f;
  padding: 10px 8px 16px;
  border-radius: 8px;
  box-sizing: border-box;
  white-space: normal;
  font-family: var(--font-ui);
}
.pdfjs-page-wrap {
  margin: 0 auto 14px;
  text-align: center;
}
.pdfjs-page-wrap canvas {
  max-width: 100%;
  height: auto;
  display: block;
  margin: 0 auto;
  box-shadow: 0 4px 24px rgba(0, 0, 0, 0.45);
}
.pdfjs-page-ph {
  padding: 20px;
  color: var(--muted);
  font-size: 12px;
}
#preview-web-scroll.mode-hidden {
  display: none !important;
}
#preview-host {
  flex: 1 1 auto;
  min-height: 120px;
  display: none;
  margin: 0 12px 8px;
  border-radius: 10px;
  border: 1px dashed rgba(255,255,255,.12);
  background: rgba(0,0,0,.12);
  box-sizing: border-box;
}
#preview-host.mode-native {
  display: block;
}
#preview-ql-hint {
  flex-shrink: 0;
  padding: 8px 14px 12px;
  font-size: 11px;
  color: #7f8a95;
  border-top: 1px solid rgba(255,255,255,.06);
  background: rgba(0,0,0,.12);
  overflow: visible;
}
#preview-ql-hint.hidden {
  display: none;
}
#preview-ql-hint .ql-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 10px;
  flex-wrap: wrap;
}
#preview-ql-hint .ql-text {
  flex: 1 1 120px;
  min-width: 0;
  line-height: 1.4;
}
#preview-ql-hint .ql-btns {
  display: inline-flex;
  flex-wrap: wrap;
  gap: 8px;
  justify-content: flex-end;
  align-items: center;
  flex: 0 1 auto;
  max-width: 100%;
}
#preview-ql-btn, .preview-ctrl-btn {
  flex-shrink: 0;
  height: 28px;
  padding: 0 12px;
  border-radius: 8px;
  border: 1px solid rgba(255,179,71,.25);
  background: rgba(255,255,255,.05);
  color: #fff;
  font-size: 11px;
  cursor: pointer;
  transition: all 0.2s ease;
}
#preview-ql-btn:hover, .preview-ctrl-btn:hover {
  background: rgba(255,255,255,.1);
  border-color: rgba(255,179,71,.45);
}
#preview-ql-btn.btn-highlight, .preview-ctrl-btn.btn-highlight {
  background: rgba(255,141,42,.22);
  border-color: rgba(255,141,42,.7);
  box-shadow: 0 0 8px rgba(255,141,42,0.15);
  font-weight: bold;
}
#preview-ql-btn.btn-highlight:hover {
  background: rgba(255,141,42,.35);
}
#preview-ql-btn:disabled, .preview-ctrl-btn:disabled {
  opacity: 0.3;
  cursor: default;
}
#preview-web-scroll pre[class*="language-"] {
  margin: 0;
  padding: 12px;
  border-radius: 10px;
  background: rgba(0,0,0,.35) !important;
  overflow: auto;
  max-height: none;
}
#preview-web-scroll img.preview-img {
  max-width: 100%;
  height: auto;
  display: block;
  margin: 0 auto;
  border-radius: 8px;
}
.preview-plain {
  margin: 0;
  white-space: pre-wrap;
  word-break: break-word;
  font-family: var(--font-mono);
  line-height: 1.65;
  font-size: 12px;
}
.preview-truncate-note {
  margin-bottom: 10px;
  padding: 8px 10px;
  border-radius: 8px;
  background: rgba(255,141,42,.12);
  border: 1px solid rgba(255,179,71,.28);
  color: #e7c4a0;
  font-size: 11px;
}
.preview-media {
  width: 100%;
  max-height: 100%;
  display: block;
  border-radius: 12px;
  background: #0f1115;
}
.preview-audio {
  min-height: 80px;
}
.preview-video {
  min-height: 240px;
}
.media-card {
  display: grid;
  gap: 10px;
}
.media-player {
  display: grid;
  gap: 10px;
  padding: 12px;
  border-radius: 14px;
  border: 1px solid rgba(255,255,255,.06);
  background: rgba(255,255,255,.03);
}
.media-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  flex-wrap: wrap;
}
.media-title-wrap {
  min-width: 0;
}
.media-title {
  font-size: 14px;
  font-weight: 700;
  color: #f4f7fb;
  word-break: break-word;
}
.media-subtitle {
  margin-top: 3px;
  font-size: 11px;
  color: rgba(220,228,236,.72);
}
.media-toolbar {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
}
.media-chips {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}
.media-chip {
  padding: 5px 10px;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,.10);
  background: rgba(255,255,255,.04);
  color: #dfe7ef;
  font-size: 11px;
}
.media-actions {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  padding-top: 2px;
}
.media-btn {
  height: 30px;
  padding: 0 12px;
  border-radius: 999px;
  border: 1px solid rgba(255,179,71,.22);
  background: rgba(255,255,255,.04);
  color: #f7f7f7;
  font-size: 11px;
  cursor: pointer;
}
.media-btn:hover {
  background: rgba(255,255,255,.09);
}
.media-btn.active {
  background: rgba(255,141,42,.22);
  border-color: rgba(255,141,42,.65);
  color: #fff3e4;
}
.media-status {
  display: flex;
  justify-content: space-between;
  gap: 10px;
  flex-wrap: wrap;
  font-size: 11px;
  color: #a8b3bf;
}
.media-status strong {
  color: #f0f4f8;
  font-weight: 600;
}
.media-info-panel {
  display: none;
  padding: 10px 12px;
  border-radius: 12px;
  border: 1px solid rgba(255,255,255,.06);
  background: rgba(0,0,0,.18);
  font-size: 11px;
  color: #d9e2ea;
}
.media-info-panel.open {
  display: grid;
  gap: 6px;
}
.media-info-row {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}
.media-info-key {
  color: #f0b46a;
}
.media-info-val {
  color: #dfe7ef;
}
.preview-meta-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
  gap: 8px 16px;
  margin-top: 4px;
}
.preview-meta-item {
  display: flex;
  align-items: center;
  font-size: 11px;
  color: #7f8a95;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.preview-meta-key {
  color: #555;
  margin-right: 6px;
  flex-shrink: 0;
}
.preview-meta-val {
  color: #aaa;
  overflow: hidden;
  text-overflow: ellipsis;
}
#footer {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 8px;
  padding: 4px 4px 0;
  font-size: 12px;
  color: var(--muted);
}
.footer-row-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  flex-wrap: wrap;
}
.footer-inline-btns {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  flex-shrink: 0;
}
.footer-inline-btns .btn {
  height: 32px;
  padding: 0 12px;
  font-size: 12px;
}
.recycle-badge {
  display: inline-block;
  min-width: 18px;
  margin-left: 4px;
  padding: 0 6px;
  border-radius: 999px;
  background: rgba(255,141,42,.25);
  color: #fff;
  font-size: 11px;
  font-weight: 700;
}
.recycle-badge:empty,
.recycle-badge.muted {
  background: rgba(255,255,255,.08);
  color: var(--muted);
  font-weight: 600;
}
.recycle-overlay {
  position: fixed;
  inset: 0;
  z-index: 5000;
  display: none;
  align-items: center;
  justify-content: center;
  background: rgba(0,0,0,.55);
  padding: 20px;
}
.recycle-overlay.open {
  display: flex;
}
.recycle-dialog {
  width: min(520px, 96vw);
  max-height: min(72vh, 560px);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  padding: 0;
}
.recycle-dialog-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  border-bottom: 1px solid var(--border);
  font-weight: 700;
  font-size: 14px;
}
.recycle-list {
  flex: 1 1 auto;
  min-height: 120px;
  max-height: 44vh;
  overflow: auto;
  padding: 10px 12px;
}
.recycle-row {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 10px;
  align-items: start;
  padding: 10px;
  border-radius: 10px;
  border: 1px solid rgba(255,255,255,.08);
  background: rgba(255,255,255,.03);
  margin-bottom: 8px;
}
.recycle-row .t {
  font-size: 13px;
  font-weight: 600;
  color: #fff;
}
.recycle-row .p {
  margin-top: 4px;
  font-size: 11px;
  color: var(--muted);
  line-height: 1.4;
  word-break: break-all;
}
.recycle-dialog-foot {
  padding: 10px 12px;
  border-top: 1px solid var(--border);
  display: flex;
  justify-content: flex-end;
  gap: 8px;
}
.btn {
  height: 40px;
  padding: 0 16px;
  border-radius: 12px;
  border: 1px solid var(--border);
  background: var(--panel-2);
  color: var(--text);
  cursor: pointer;
  transition: .16s ease;
}
.btn:hover { border-color: rgba(255,179,71,.45); }
.btn.primary {
  background: linear-gradient(180deg, #ff9b38, #e5791e);
  color: #101214;
  border-color: rgba(255,179,71,.7);
  font-weight: 700;
}
.btn.ghost { background: transparent; }
.empty {
  padding: 22px;
  color: var(--muted);
  line-height: 1.7;
  min-height: 72px;
}
.skeleton-list {
  display: flex;
  flex-direction: column;
  gap: 5px;
  flex: 1 1 auto;
}
.skeleton-item {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 8px;
  padding: 9px 10px;
  border-radius: 10px;
  border: 1px solid rgba(255,255,255,.04);
  background: rgba(255,255,255,.015);
}
.sk-line {
  height: 9px;
  border-radius: 6px;
  background: linear-gradient(90deg, rgba(255,255,255,.06), rgba(255,255,255,.12), rgba(255,255,255,.06));
  background-size: 220% 100%;
  animation: sk-shimmer 1.3s linear infinite;
}
.sk-line + .sk-line { margin-top: 5px; }
.sk-line.w1 { width: 64%; }
.sk-line.w2 { width: 44%; }
.sk-line.w3 { width: 78%; }
.sk-meta {
  width: 64px;
  height: 32px;
  border-radius: 8px;
  background: linear-gradient(90deg, rgba(255,255,255,.06), rgba(255,255,255,.12), rgba(255,255,255,.06));
  background-size: 220% 100%;
  animation: sk-shimmer 1.3s linear infinite;
}
.preview-empty {
  min-height: 100%;
}
@keyframes sk-shimmer {
  0% { background-position: 100% 0; }
  100% { background-position: -100% 0; }
}
mark {
  background: rgba(255,179,71,.9);
  color: #111;
  padding: 0 2px;
  border-radius: 3px;
}
@media (max-width: 980px) {
  #layout { grid-template-columns: 1fr; }
  #preview-card { min-height: 240px; }
}
</style>
<script src="https://app.local/assets/js/BasePanel.js"></script>
<script src="https://app.local/assets/vendor/prism/prism-core.min.js"></script>
