const PDF_JS_ASSET_BASE = "https://app.local/assets/pdfjs/";

const postToAhk = (obj) => BasePanel.postToAhk(obj);

function syncEngineModeButton() {
  const isGo = state.engineMode === "go";
  const ids = [
    ["engine-mode-go", "go"],
    ["engine-mode-ahk", "ahk"],
    ["engine-mode-go-inline", "go"],
    ["engine-mode-ahk-inline", "ahk"]
  ];
  ids.forEach(([id, mode]) => {
    const el = document.getElementById(id);
    if (!el) return;
    el.classList.toggle("active", (mode === "go") === isGo);
    if (mode === "go") {
      el.title = isGo ? "褰撳墠锛氭瀬閫燂紙Go锛夈€傜偣鍑讳繚鎸? : "鍒囨崲涓猴細鏋侀€燂紙Go锛?;
    } else {
      el.title = !isGo ? "褰撳墠锛氭爣鍑嗭紙AHK锛夈€傜偣鍑讳繚鎸? : "鍒囨崲涓猴細鏍囧噯锛圓HK锛?;
    }
  });
}

/** 涓?Go /search 鐨?type= 瀵归綈锛氶潪鍓创鏉跨瓫閫夋椂 Go 杩斿洖绌哄壀璐存澘椤癸紝鐢?AHK 鍚堝苟鍏跺畠婧?*/
function mapFilterToGoSearchType() {
  const f = state.filterType || "";
  if (f === "clipboard") return "clipboard";
  if (f === "fulltext") return "fulltext";
  return "all";
}

function effectiveSearchLimit() {
  let lim = Number(state.limit) || 30;
  if (lim > 500) lim = 500;
  return lim;
}

/** 鏋侀€熸ā寮忥細鐢?AHK WinHttp 璇锋眰鏈満 Go锛堥伩鍏?https://app.local 椤甸潰 fetch http 琚贩鍚堝唴瀹规嫤鎴級 */
function runSearchGoPipeline(offset) {
  postToAhk({
    type: "searchGoRequest",
    keyword: state.keyword,
    offset: offset || 0,
    limit: effectiveSearchLimit(),
    goType: mapFilterToGoSearchType()
  });
}

function fallbackToAhkSearch() {
  postToAhk({ type: "search", keyword: state.keyword });
}

const PREVIEW_DEBOUNCE_MS = 150;
const PREVIEW_TEXT_EXT = new Set(["txt", "ahk", "py", "js", "md", "json", "log"]);
const PREVIEW_IMAGE_EXT = new Set(["png", "jpg", "jpeg", "gif", "svg"]);
const PREVIEW_AUDIO_EXT = new Set(["mp3", "wav", "flac", "m4a", "aac", "ogg", "opus", "wma"]);
const PREVIEW_VIDEO_EXT = new Set(["mp4", "m4v", "mov", "webm", "mkv", "avi"]);
const PREVIEW_PDF_EXT = new Set(["pdf"]);
const PREVIEW_ARCHIVE_EXT = new Set(["zip", "7z", "rar", "tar", "gz", "tgz", "bz2", "xz", "cab", "iso"]);
const PDF_MODE_OPTIONS_BASE = ["auto", "pdfjs", "web", "pdfium", "ipreview"];
const ONE_MB = 1048576;
const HOTKEY_HINT_MAP = Object.freeze({
  category: Object.freeze({
    ai: "q",
    cli: "w",
    academic: "e",
    baidu: "r"
  }),
  engine: Object.freeze({
    deepseek: "a",
    yuanbao: "s",
    doubao: "d"
  }),
  filter: Object.freeze({
    File: "z",
    clipboard: "x",
    template: "c",
    config: "v",
    pinned: "p"
  })
});
let capsHoldTimer = 0;
let capsFlashTimer = 0;

function escapeHtml(text) {
  if (text === null || text === undefined) return "";
  return String(text)
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;");
}

function saveMediaPref(key, value) {
  state.mediaPrefs[key] = !!value;
  try {
    localStorage.setItem("sc_media_" + key, value ? "1" : "0");
  } catch {}
}

function formatDuration(totalSeconds) {
  const n = Number(totalSeconds);
  if (!Number.isFinite(n) || n < 0) return "--:--";
  const s = Math.floor(n % 60);
  const m = Math.floor((n / 60) % 60);
  const h = Math.floor(n / 3600);
  const pad = (v) => String(v).padStart(2, "0");
  return h > 0 ? `${h}:${pad(m)}:${pad(s)}` : `${m}:${pad(s)}`;
}

function mediaGlyphForExt(ext) {
  if (PREVIEW_AUDIO_EXT.has(ext)) return "AUDIO";
  if (PREVIEW_VIDEO_EXT.has(ext)) return "VIDEO";
  return "MEDIA";
}

function mediaResumeKey(path) {
  return "sc_media_resume::" + String(path || "");
}

function loadMediaResume(path) {
  try {
    const raw = localStorage.getItem(mediaResumeKey(path));
    const n = Number(raw);
    return Number.isFinite(n) && n > 0 ? n : 0;
  } catch {
    return 0;
  }
}

function saveMediaResume(path, timeSec) {
  if (!path) return;
  const n = Number(timeSec);
  if (!Number.isFinite(n) || n < 0) return;
  try {
    localStorage.setItem(mediaResumeKey(path), String(n));
  } catch {}
}

function highlight(text, keyword) {
  const safe = escapeHtml(text);
  if (!keyword) return safe;
  try {
    const escaped = keyword.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
    const re = new RegExp("(" + escaped + ")", "ig");
    return safe.replace(re, "<mark>$1</mark>");
  } catch {
    return safe;
  }
}

function getHintHotkey(group, value) {
  if (!group || !value) return "";
  const src = HOTKEY_HINT_MAP[group];
  if (!src) return "";
  return src[value] || "";
}

function normalizeHintKey(key) {
  const k = String(key || "").trim().toLowerCase();
  return /^[a-z0-9]$/.test(k) ? k : "";
}

function hotkeyHintHtml(hotkey) {
  if (hotkey) {
    return "<span class=\"hotkey-hint\">Caps+" + escapeHtml(String(hotkey).toUpperCase()) + "</span>";
  }
  return "<span class=\"hotkey-hint unbound\">鍙粦瀹?/span>";
}

function getFooterHintText() {
  return state.isCliCategory
    ? "CLI 鍒嗙被锛氳緭鍏ュ唴瀹瑰悗鍙洿鎺ュ彂閫佸埌閫変腑鐨勭粓绔?
    : "缃戠粶鍒嗙被锛氳緭鍏ュ唴瀹瑰悗浼氬苟鍙戞墦寮€閫変腑鐨勬悳绱㈠紩鎿?;
}

function syncFooterHint() {
  const footer = document.getElementById("footer-hint");
  if (!footer) return;
  if (state.capsHintActive) {
    footer.textContent = "CapsLock 鐑敭鎻愮ず涓細鎸夊搴斿瓧姣嶅彲蹇€熷畾浣?;
    return;
  }
  footer.textContent = getFooterHintText();
}

function normalizeFulltextPayload(payload) {
  const src = payload && typeof payload === "object" ? payload : {};
  const rootsCount = Array.isArray(src.roots)
    ? src.roots.length
    : (Number.isFinite(Number(src.rootsCount)) ? Number(src.rootsCount) : 0);
  return {
    running: !!src.running,
    ready: !!src.ready,
    progress: Number.isFinite(Number(src.progress)) ? Number(src.progress) : 0,
    progressText: String(src.progressText || "0.0%"),
    progressDetail: String(src.progressDetail || ""),
    efficiencyText: String(src.efficiencyText || ""),
    scanPhase: String(src.scanPhase || ""),
    indexing_file: String(src.indexing_file || ""),
    discoveredFiles: Number.isFinite(Number(src.discoveredFiles)) ? Number(src.discoveredFiles) : 0,
    processedFiles: Number.isFinite(Number(src.processedFiles)) ? Number(src.processedFiles) : 0,
    pendingTasks: Number.isFinite(Number(src.pendingTasks)) ? Number(src.pendingTasks) : 0,
    rootsCount,
    filesPerSec: Number.isFinite(Number(src.filesPerSec)) ? Number(src.filesPerSec) : 0,
    etaSeconds: Number.isFinite(Number(src.etaSeconds)) ? Number(src.etaSeconds) : 0,
    engine_lights: Array.isArray(src.engine_lights) && src.engine_lights.length === 4
      ? src.engine_lights.map((v) => String(v || "off"))
      : ["off", "off", "off", "off"],
    scan_mode: String(src.scan_mode || ""),
    indexEpoch: Number.isFinite(Number(src.indexEpoch)) ? Number(src.indexEpoch) : 0
  };
}

function formatScanModeBadge(mode) {
  const m = String(mode || "").toLowerCase();
  if (!m) return "";
  if (m.includes("mft")) {
    return (m.includes("usn") ? "鈿FT路馃攣USN" : "鈿FT");
  }
  if (m.includes("walk")) {
    return (m.includes("usn") ? "馃悽Walk路馃攣USN" : "馃悽Walk");
  }
  if (m.includes("usn")) return "馃攣USN";
  return String(mode || "");
}

function getHitContextList(item) {
  const md = item && item.metadata;
  if (!md || typeof md !== "object") return null;
  const ctx = md.hitContext;
  return Array.isArray(ctx) && ctx.length ? ctx : null;
}

function startFulltextProgressStream() {
  if (typeof EventSource === "undefined") {
    if (!fulltextPollTimer) {
      fulltextPollTimer = setInterval(() => requestFulltextStatus(), 2500);
    }
    return;
  }
  if (fulltextProgressES) {
    try {
      fulltextProgressES.close();
    } catch (e) {}
    fulltextProgressES = null;
  }
  let es;
  try {
    es = new EventSource(SEARCH_CORE_ORIGIN + "/v1/fulltext/progress/stream");
  } catch (e) {
    if (!fulltextPollTimer) {
      fulltextPollTimer = setInterval(() => requestFulltextStatus(), 2500);
    }
    return;
  }
  fulltextProgressES = es;
  es.addEventListener("open", () => {
    fulltextEsBackoffMs = 2000;
    if (fulltextPollTimer) {
      clearInterval(fulltextPollTimer);
      fulltextPollTimer = 0;
    }
  });
  es.onmessage = (ev) => {
    try {
      const data = JSON.parse(ev.data || "{}");
      applyFulltextStatus(data);
    } catch (e) {}
  };
  es.onerror = () => {
    try {
      es.close();
    } catch (e) {}
    if (fulltextProgressES === es) fulltextProgressES = null;
    if (!fulltextPollTimer) {
      fulltextPollTimer = setInterval(() => requestFulltextStatus(), 2500);
    }
    const wait = fulltextEsBackoffMs;
    fulltextEsBackoffMs = Math.min(Math.floor(fulltextEsBackoffMs * 1.5), 60000);
    if (!fulltextEsReconnectTimer) {
      fulltextEsReconnectTimer = setTimeout(() => {
        fulltextEsReconnectTimer = 0;
        startFulltextProgressStream();
      }, wait);
    }
  };
}

function applyFulltextStatus(payload) {
  state.fulltext = normalizeFulltextPayload(Object.assign({}, state.fulltext, payload || {}));
  const cfg = payload && payload.config && typeof payload.config === "object" ? payload.config : null;
  if (cfg) {
    let scheme = String(cfg.scanScheme || "").trim().toLowerCase();
    if (!scheme) {
      const useMFT = !!cfg.useMFT;
      const useEverything = !!cfg.useEverything;
      scheme = useMFT && useEverything ? "auto" : (useMFT ? "mft" : (useEverything ? "everything" : "walk"));
    }
    if (!["auto", "mft", "everything", "walk"].includes(scheme)) scheme = "auto";
    state.fulltextConfig.scanScheme = scheme;
    state.fulltextConfig.useUSN = (typeof cfg.useUSN === "boolean") ? cfg.useUSN : true;
    syncFulltextSchemeUi();
  }
  const lightIds = ["ftl1", "ftl2", "ftl3", "ftl4"];
  lightIds.forEach((id, idx) => {
    const el = document.getElementById(id);
    if (!el) return;
    el.classList.remove("off", "active", "ready", "warn");
    el.classList.add(state.fulltext.engine_lights[idx] || "off");
  });
  const progressEl = document.getElementById("ft-progress-text");
  if (progressEl) {
    const hasCounters =
      state.fulltext.discoveredFiles > 0 ||
      state.fulltext.processedFiles > 0 ||
      state.fulltext.pendingTasks > 0 ||
      state.fulltext.rootsCount > 0;
    const txt = hasCounters
      ? `宸插鐞?${state.fulltext.processedFiles} / ${state.fulltext.discoveredFiles}锛屽緟澶勭悊 ${state.fulltext.pendingTasks}锛岀储寮曟牴 ${state.fulltext.rootsCount}`
      : (state.fulltext.progressDetail || state.fulltext.progressText || `${state.fulltext.progress.toFixed(1)}%`);
    progressEl.textContent = `FT ${txt}`;
  }
  const effEl = document.getElementById("ft-efficiency-text");
  if (effEl) {
    const txt = state.fulltext.efficiencyText || `${state.fulltext.filesPerSec.toFixed(2)} 鏂囦欢/绉抈;
    effEl.textContent = txt;
    effEl.title = txt;
  }
  const fileEl = document.getElementById("ft-file");
  if (fileEl) {
    const phaseMap = {
      startup: "鍑嗗涓?,
      walking: "鎵弿鐩綍涓?,
      indexing: "鍐风储寮曚腑",
      idle_wait: "绛夊緟绌洪棽",
      ready: "绱㈠紩灏辩华",
      idle: "绌洪棽"
    };
    const phase = phaseMap[state.fulltext.scanPhase] || (state.fulltext.running ? "绱㈠紩鐩戞帶涓? : "绌洪棽");
    const t = state.fulltext.indexing_file ? `${phase} 路 ${state.fulltext.indexing_file}` : phase;
    fileEl.textContent = t;
    fileEl.title = t;
  }
  const toggleBtn = document.getElementById("btn-ft-toggle");
  if (toggleBtn) {
    if (state.fulltext.running) {
      toggleBtn.textContent = "鍋滄绱㈠紩";
      toggleBtn.title = "鐐瑰嚮鍋滄鍏ㄦ枃绱㈠紩";
    } else {
      toggleBtn.textContent = "鍚姩绱㈠紩";
      toggleBtn.title = "鐐瑰嚮鍚姩鍏ㄦ枃绱㈠紩";
    }
  }
  const scanBadge = document.getElementById("ft-scan-badge");
  if (scanBadge) {
    const lab = formatScanModeBadge(state.fulltext.scan_mode);
    scanBadge.textContent = lab;
    scanBadge.title = state.fulltext.scan_mode
      ? ("鎵弿妯″紡: " + state.fulltext.scan_mode + (state.fulltext.indexEpoch ? " 路 epoch " + state.fulltext.indexEpoch : ""))
      : "鎵弿妯″紡";
    scanBadge.style.display = lab ? "inline" : "none";
  }
}

function requestFulltextStatus() {
  postToAhk({ type: "fulltextStatusRequest", withConfig: false });
}

function syncFulltextSchemeUi() {
  const sel = document.getElementById("ft-scheme-select");
  const usn = document.getElementById("ft-usn-toggle");
  if (sel) sel.value = state.fulltextConfig.scanScheme || "auto";
  if (usn) usn.checked = !!state.fulltextConfig.useUSN;
}

function syncFulltextAdvancedUi() {
  const wrap = document.getElementById("ft-advanced-wrap");
  const btn = document.getElementById("btn-ft-advanced-toggle");
  const open = !!state.fulltextUiAdvanced;
  if (wrap) wrap.classList.toggle("hidden", !open);
  if (btn) {
    btn.textContent = open ? "收起高级" : "高级设置";
    btn.title = open ? "收起高级配置" : "显示高级配置";
  }
  try {
    localStorage.setItem(SC_FT_ADVANCED_KEY, open ? "1" : "0");
  } catch (e) {}
}

function collectFulltextSchemePayload() {
  const sel = document.getElementById("ft-scheme-select");
  const usn = document.getElementById("ft-usn-toggle");
  const scheme = sel ? String(sel.value || "auto") : "auto";
  const useUSN = usn ? !!usn.checked : true;
  return { scanScheme: scheme, useUSN };
}

function setFulltextProbeSummary(text) {
  const el = document.getElementById("ft-probe-summary");
  if (!el) return;
  el.textContent = String(text || "");
}

function humanizeProbeReason(reasonText) {
  const s = String(reasonText || "").trim();
  if (!s) return "鏈煡鍘熷洜";
  const low = s.toLowerCase();
  if (low.includes("incorrect function")) return "褰撳墠鍗蜂笉鏀寔 USN锛堝父瑙佷簬闈?NTFS 鎴栨潈闄愬彈闄愶級";
  if (low.includes("timeout")) return "妫€娴嬭秴鏃讹紙绋嶅悗閲嶈瘯锛?;
  if (low.includes("not running")) return "Everything 鏈繍琛岋紙鍙厛鍚姩 Everything锛?;
  if (low.includes("not found")) return "缁勪欢鏈畨瑁呮垨璺緞涓嶅瓨鍦?;
  if (low.includes("permission") || low.includes("access is denied")) return "鏉冮檺涓嶈冻锛堝彲灏濊瘯绠＄悊鍛樿繍琛岋級";
  return s;
}

function renderFulltextProbe(probe) {
  state.fulltextProbe.last = probe && typeof probe === "object" ? probe : null;
  const list = document.getElementById("ft-probe-list");
  if (!list) return;
  const p = state.fulltextProbe.last;
  if (!p) {
    list.innerHTML = "";
    return;
  }
  const rows = Array.isArray(p.rootChecks) ? p.rootChecks : [];
  if (!rows.length) {
    list.innerHTML = "<div class=\"ft-probe-item\">鏈繑鍥炲垎鐩樻娴嬬粨鏋?/div>";
    return;
  }
  list.innerHTML = rows.map((it) => {
    const root = escapeHtml(String(it.root || ""));
    const mftOk = !!it.mftOk;
    const usnOk = !!it.usnOk;
    const mftReason = escapeHtml(humanizeProbeReason(it.mftReason || ""));
    const usnReason = escapeHtml(humanizeProbeReason(it.usnReason || ""));
    return "<div class=\"ft-probe-item\">" +
      "<div><strong>" + root + "</strong></div>" +
      "<div>MFT: <span class=\"" + (mftOk ? "ft-probe-ok" : "ft-probe-bad") + "\">" + (mftOk ? "鍙敤" : "涓嶅彲鐢?) + "</span> 路 " + mftReason + "</div>" +
      "<div>USN: <span class=\"" + (usnOk ? "ft-probe-ok" : "ft-probe-bad") + "\">" + (usnOk ? "鍙敤" : "鍙€?) + "</span> 路 " + usnReason + "</div>" +
      "</div>";
  }).join("");
  const extra = [];
  if (typeof p.everythingOk === "boolean") {
    extra.push("Everything " + (p.everythingOk ? "鍙敤" : "涓嶅彲鐢?));
  }
  if (p.recommendedScheme) {
    const rec = String(p.recommendedScheme);
    const label = rec === "mft" ? "楂樻€ц兘锛圡FT锛? : (rec === "everything" ? "鍏煎浼樺厛锛圗verything锛? : "鐪佸績绋冲畾锛圵alk锛?);
    extra.push("寤鸿鏂规: " + label);
  }
  setFulltextProbeSummary(extra.join(" 路 "));
}

function applyRecommendedScheme() {
  const p = state.fulltextProbe.last;
  if (!p || !p.recommendedScheme) {
    setFulltextProbeSummary("璇峰厛鐐光€滄娴嬪彲琛屾€р€?);
    return;
  }
  const rec = String(p.recommendedScheme || "auto").toLowerCase();
  const sel = document.getElementById("ft-scheme-select");
  if (sel) sel.value = rec;
  // 灏忕櫧妯″紡榛樿鎶?USN 鎵撳紑锛涜嫢绯荤粺涓嶆敮鎸佷細鑷姩鍥為€€锛屼笉褰卞搷涓绘祦绋?  const usn = document.getElementById("ft-usn-toggle");
  if (usn) usn.checked = true;
  const payload = collectFulltextSchemePayload();
  setFulltextProbeSummary("姝ｅ湪鎸夊缓璁簲鐢ㄦ柟妗堚€?);
  postToAhk({ type: "fulltextConfigUpdate", payload });
}

function updateHotkeyHighlights() {
  const nodes = document.querySelectorAll(".hotkey-item");
  nodes.forEach((el) => {
    const hk = normalizeHintKey(el.dataset.hotkey || "");
    const ready = state.capsHintActive && !!hk;
    const hit = ready && state.capsPressedKey === hk;
    el.classList.toggle("caps-hotkey-ready", ready);
    el.classList.toggle("caps-hotkey-hit", hit);
  });
}

function setCapsHintActive(active) {
  const next = !!active;
  if (state.capsHintActive === next) return;
  state.capsHintActive = next;
  if (!next) state.capsPressedKey = "";
  updateHotkeyHighlights();
  syncFooterHint();
}

function setCapsPressedKey(key) {
  state.capsPressedKey = normalizeHintKey(key);
  updateHotkeyHighlights();
}

function flashCapsPressedKey(key) {
  const normalized = normalizeHintKey(key);
  if (!normalized) return;
  setCapsPressedKey(normalized);
  if (capsFlashTimer) clearTimeout(capsFlashTimer);
  capsFlashTimer = setTimeout(() => {
    if (state.capsPressedKey === normalized) {
      state.capsPressedKey = "";
      updateHotkeyHighlights();
    }
  }, 260);
}

function beginCapsHoldHint() {
  if (capsHoldTimer) clearTimeout(capsHoldTimer);
  capsHoldTimer = setTimeout(() => {
    setCapsHintActive(true);
  }, 220);
}

function endCapsHoldHint() {
  if (capsHoldTimer) clearTimeout(capsHoldTimer);
  capsHoldTimer = 0;
  if (capsFlashTimer) clearTimeout(capsFlashTimer);
  capsFlashTimer = 0;
  setCapsHintActive(false);
}

function renderCategories() {
  const wrap = document.getElementById("categories");
  wrap.innerHTML = "";
  state.categories.forEach((cat) => {
    const hotkey = getHintHotkey("category", cat.key);
    const el = document.createElement("button");
    el.className = "chip hotkey-item" + (cat.key === state.currentCategoryKey ? " active" : "");
    el.dataset.hotkey = hotkey || "";
    el.innerHTML = "<span class=\"chip-main\"><span class=\"chip-title\">" + escapeHtml(cat.text) + "</span>" + hotkeyHintHtml(hotkey) + "</span><span class=\"count\">" + (cat.selectedCount || 0) + "</span>";
    el.onclick = () => postToAhk({ type: "setCategory", category: cat.key });
    wrap.appendChild(el);
  });
  updateHotkeyHighlights();
}

function renderEngines() {
  const wrap = document.getElementById("engines");
  wrap.innerHTML = "";
  state.engines.forEach((engine) => {
    const hotkey = getHintHotkey("engine", engine.value);
    const active = state.selectedEngines.includes(engine.value);
    const el = document.createElement("button");
    el.className = "engine-chip hotkey-item" + (active ? " active" : "");
    el.dataset.hotkey = hotkey || "";
    const icon = engine.iconUrl
      ? "<span class=\"engine-icon-wrap\"><img src=\"" + engine.iconUrl + "\" alt=\"\"></span>"
      : "<span class=\"engine-icon-wrap\"><span class=\"engine-fallback\">" + escapeHtml((engine.name || "?").slice(0, 1).toUpperCase()) + "</span></span>";
    el.innerHTML = icon + "<span class=\"label\">" + escapeHtml(engine.name) + "</span>" + hotkeyHintHtml(hotkey);
    el.onclick = () => postToAhk({ type: "toggleEngine", engine: engine.value });
    wrap.appendChild(el);
  });
  updateHotkeyHighlights();
}

function renderFilters() {
  const wrap = document.getElementById("filters");
  wrap.innerHTML = "";
  state.filters.forEach((filter) => {
    const hotkey = getHintHotkey("filter", filter.key);
    const el = document.createElement("button");
    el.type = "button";
    el.className = "filter-chip hotkey-item" + (filter.key === state.filterType ? " active" : "");
    el.dataset.hotkey = hotkey || "";
    el.dataset.filterKey = filter.key || "";
    el.innerHTML = "<span class=\"filter-label\">" + escapeHtml(filter.text) + "</span>" + hotkeyHintHtml(hotkey);
    const applyFilter = () => postToAhk({ type: "setFilter", filterType: filter.key });
    let pressedHandled = false;
    let pressedAt = 0;
    // 杈撳叆闃叉姈鍥炲寘浼氶噸缁樿繃婊ゆ爮锛宲ointerdown 姣?click 鏇存棭瑙﹀彂锛岄伩鍏嶇偣鍑昏閲嶇粯鍚炴帀
    el.addEventListener("pointerdown", (e) => {
      e.preventDefault();
      pressedHandled = true;
      pressedAt = Date.now();
      applyFilter();
    });
    el.addEventListener("click", (e) => {
      e.preventDefault();
      if (pressedHandled && (Date.now() - pressedAt) < 450) {
        pressedHandled = false;
        return;
      }
      pressedHandled = false;
      applyFilter();
    });
    wrap.appendChild(el);
  });
  updateHotkeyHighlights();
}

function renderResults() {
  const list = document.getElementById("result-list");
  list.innerHTML = "";
  disconnectLoadMoreObserver();

  if (!state.results.length) {
    list.innerHTML =
      "<div class=\"empty\">鏆傛棤缁撴灉銆?br>浣犲彲浠ュ湪杈撳叆妗嗚緭鍏ュ叧閿瘝鎼滅储鏈湴鍐呭锛屾垨閫夋嫨寮曟搸鍚庢墽琛岀綉缁滄悳绱?/ CLI 鍙戦€併€?/div>" +
      buildSkeletonListHtml(7);
    renderPreview();
    return;
  }

  if (state.selectedRow < 1 || state.selectedRow > state.results.length) {
    state.selectedRow = 1;
  }

  state.results.forEach((item) => {
    const row = document.createElement("div");
    row.className = "result-item" + (item.row === state.selectedRow ? " active" : "");
    const pinMark = item.pinned ? "<span class=\"pin-ico\" title=\"缃《\">馃敐</span>" : "";
    const hitCtx = getHitContextList(item);
    let hitBlock = "";
    if (hitCtx) {
      const lines = hitCtx.map((b) => {
        if (!b || typeof b !== "object") return "";
        const lineNo = b.line != null ? b.line : b.Line;
        const sn = b.snippet != null ? b.snippet : b.Snippet;
        return "<span class=\"hit-ctx-line\">" + escapeHtml(String(lineNo || "")) + "</span> " + highlight(String(sn || ""), state.keyword);
      }).filter(Boolean);
      hitBlock =
        "<div class=\"hit-context-wrap\">" +
        "<button type=\"button\" class=\"hit-ctx-btn\">鍛戒腑涓婁笅鏂?路 " + hitCtx.length + "</button>" +
        "<div class=\"hit-ctx-body hidden\">" + lines.join("<br>") + "</div></div>";
    }
    row.innerHTML =
      "<div>" +
        "<div class=\"result-title\">" + pinMark + highlight(item.title, state.keyword) + "</div>" +
        "<div class=\"result-sub\">" + escapeHtml(item.subtitle || "") + "</div>" +
        "<div class=\"result-preview\">" + highlight(item.preview || "", state.keyword) + "</div>" +
        hitBlock +
      "</div>" +
      "<div class=\"result-meta\">" +
        "<span class=\"pill\">" + escapeHtml(item.type || "") + "</span>" +
        "<span class=\"time\">" + escapeHtml(item.time || "") + "</span>" +
      "</div>";
    if (hitCtx) {
      const btn = row.querySelector(".hit-ctx-btn");
      const body = row.querySelector(".hit-ctx-body");
      if (btn && body) {
        btn.addEventListener("click", (e) => {
          e.preventDefault();
          e.stopPropagation();
          body.classList.toggle("hidden");
        });
      }
    }
    row.onclick = () => {
      state.selectedRow = item.row;
      renderResults();
    };
    row.oncontextmenu = (ev) => {
      ev.preventDefault();
      state.selectedRow = item.row;
      renderResults();
      postToAhk({
        type: "searchCenterContextMenu",
        row: item.row,
        screenX: ev.screenX,
        screenY: ev.screenY,
      });
    };
    row.ondblclick = () => {
      postToAhk({ type: "activateResult", row: item.row });
    };
    list.appendChild(row);
  });

  if (state.results.length < 7) {
    list.insertAdjacentHTML("beforeend", buildSkeletonListHtml(7 - state.results.length));
  }

  if (state.hasMore) {
    const sent = document.createElement("div");
    sent.id = "load-sentinel";
    sent.style.height = "2px";
    sent.style.width = "100%";
    sent.style.pointerEvents = "none";
    list.appendChild(sent);
    setupLoadMoreObserver();
  }

  renderPreview();
}

function looksLikeWindowsPath(s) {
  if (!s || typeof s !== "string") return false;
  const t = s.trim();
  if (t.length < 3) return false;
  if (/^[A-Za-z]:[\\/]/.test(t)) return true;
  if (t.startsWith("\\\\")) return true;
  return false;
}

function getSelectedItemPath(item) {
  if (!item) return "";
  const p = (item.path && String(item.path).trim()) || "";
  if (p && looksLikeWindowsPath(p)) return p;
  const dt = String(item.dataType || item.type || "").toLowerCase();
  const isFileish = dt === "file" || dt === "folder" || /鏂囦欢|璺緞/.test(String(item.source || ""));
  const c = item.content ? String(item.content).trim() : "";
  if (isFileish && looksLikeWindowsPath(c)) return c;
  return "";
}

function pathExtensionLower(path) {
  if (!path) return "";
  const base = path.replace(/^.*[\\/]/, "");
  const i = base.lastIndexOf(".");
  if (i <= 0 || i === base.length - 1) return "";
  return base.slice(i + 1).toLowerCase();
}

function prismLangForExt(ext) {
  if (ext === "py") return "python";
  if (ext === "js") return "javascript";
  if (ext === "md") return "markdown";
  if (ext === "json") return "json";
  if (ext === "ahk") return "clike";
  if (ext === "txt" || ext === "log") return "plaintext";
  return "plaintext";
}

function truncateToLines(text, maxLines) {
  const lines = text.split(/\r\n|\r|\n/);
  if (lines.length <= maxLines) return { text, truncated: false };
  return { text: lines.slice(0, maxLines).join("\n"), truncated: true };
}

function setQuickLookHintVisible(show) {
  const el = document.getElementById("preview-ql-hint");
  if (!el) return;
  el.classList.toggle("hidden", !show);
  if (show) updateQuickLookInstallUi();
}

function isQuickLookInstalled() {
  const q = state.quickLook || {};
  return !!q.installed;
}

function updateChromeTopMostButton() {
  const btn = document.getElementById("chrome-topmost");
  if (!btn) return;
  const topMost = !!state.hostTopMost;
  btn.classList.toggle("active", topMost);
  btn.textContent = topMost ? "缃《" : "鏈疆椤?;
  btn.title = topMost ? "褰撳墠宸茬疆椤讹紝鐐瑰嚮鍙栨秷缃《" : "褰撳墠鏈疆椤讹紝鐐瑰嚮缃《绐楀彛";
}

/**
 * 鍗曟寜閽ā寮忥細
 * 鏈畨瑁?=> 鎸夐挳鏄剧ず鈥滃畨瑁匭uickLook鈥濓紝鐐瑰嚮鍚庣敤鎴风‘璁や笅杞藉苟瀹夎锛? * 宸插畨瑁?=> 鎸夐挳鏄剧ず鈥淨uickLook鈥濓紝鐐瑰嚮鍚庣洿鎺ヨЕ鍙?QuickLook 棰勮銆? */
function updateQuickLookInstallUi() {
  const btn = document.getElementById("preview-ql-btn");
  if (!btn) return;
  const q = state.quickLook || {};
  const installed = isQuickLookInstalled();
  const busy = !!q.installBusy;
  const err = (q.lastInstallError && String(q.lastInstallError).trim()) || "";

  if (busy) {
    const pm = (q.installProgressMsg && String(q.installProgressMsg).trim()) || "姝ｅ湪瀹夎 QuickLook鈥?;
    const pct = typeof q.installProgressPct === "number" && !Number.isNaN(q.installProgressPct) ? q.installProgressPct : null;
    btn.disabled = true;
    btn.textContent = pct != null ? `瀹夎涓?${Math.round(pct)}%` : "瀹夎涓€?;
    btn.title = pm;
    return;
  }

  btn.disabled = false;
  if (installed) {
    btn.textContent = "QuickLook";
    btn.title = "宸插畨瑁咃紝鐐瑰嚮鐩存帴浣跨敤 QuickLook 棰勮";
    return;
  }

  btn.textContent = "瀹夎QuickLook";
  btn.title = err
    ? (err + " 鐐瑰嚮閲嶈瘯瀹夎銆?)
    : "鏈畨瑁呫€傜偣鍑诲悗鍙笅杞藉苟鍚敤 QuickLook 棰勮鏈哄埗銆?;
}

function stopNativePreview() {
  postToAhk({ type: "PREVIEW_NATIVE_STOP" });
}

function setPreviewLayoutMode(mode) {
  const web = document.getElementById("preview-web-scroll");
  const host = document.getElementById("preview-host");
  if (!web || !host) return;
  if (mode === "native") {
    web.classList.add("mode-hidden");
    host.classList.add("mode-native");
    host.setAttribute("aria-hidden", "false");
  } else {
    web.classList.remove("mode-hidden");
    host.classList.remove("mode-native");
    host.setAttribute("aria-hidden", "true");
  }
}

function renderFallbackTextPreview(item, pane, meta) {
  meta.textContent = [item.source || item.subtitle || "", item.type || "", item.time || ""].filter(Boolean).join(" 路 ");
  pane.innerHTML = "";
  pane.textContent = item.previewText || item.content || item.title || "";
}

function scheduleRunPreview() {
  if (state.previewTimer) clearTimeout(state.previewTimer);
  state.iPreviewActive = false;
  state.iPreviewFailed = false;
  state.previewTimer = setTimeout(() => {
    state.previewTimer = 0;
    runPreviewForSelection();
  }, PREVIEW_DEBOUNCE_MS);
}

function collectPreviewBounds() {
  const host = document.getElementById("preview-host");
  if (!host || !host.classList.contains("mode-native")) return null;
  const r = host.getBoundingClientRect();
  if (r.width < 4 || r.height < 4) return null;
  return {
    left: r.left,
    top: r.top,
    width: r.width,
    height: r.height,
    dpr: typeof window.devicePixelRatio === "number" ? window.devicePixelRatio : 1
  };
}

function getPdfModeOptions() {
  const options = PDF_MODE_OPTIONS_BASE.slice();
  if (isQuickLookInstalled()) options.push("quicklook");
  return options;
}

function setPdfMode(mode) {
  const options = getPdfModeOptions();
  const m = options.includes(mode) ? mode : "auto";
  state.pdfMode = m;
  try { localStorage.setItem("sc_pdf_preview_mode", m); } catch {}
  updatePdfModeButton();
}

function updatePdfModeButton() {
  const btn = document.getElementById("preview-pdf-mode-btn");
  if (!btn) return;
  btn.textContent = "PDF:" + state.pdfMode;
}

function cyclePdfMode() {
  const options = getPdfModeOptions();
  const idx = options.indexOf(state.pdfMode);
  const next = options[(idx + 1) % options.length];
  setPdfMode(next);
  if (pathExtensionLower(state.previewPath) === "pdf") scheduleRunPreview();
}

function ensurePdfJsScript() {
  if (globalThis.pdfjsLib) {
    pdfjsLib.GlobalWorkerOptions.workerSrc = PDF_JS_ASSET_BASE + "pdf.worker.min.js";
    return Promise.resolve();
  }
  return new Promise((resolve, reject) => {
    const s = document.createElement("script");
    s.src = PDF_JS_ASSET_BASE + "pdf.min.js";
    s.onload = () => {
      if (!globalThis.pdfjsLib) {
        reject(new Error("pdfjsLib missing"));
        return;
      }
      pdfjsLib.GlobalWorkerOptions.workerSrc = PDF_JS_ASSET_BASE + "pdf.worker.min.js";
      resolve();
    };
    s.onerror = () => reject(new Error("pdf.min.js load error"));
    document.head.appendChild(s);
  });
}

function base64ToUint8Array(b64) {
  return fetch("data:application/pdf;base64," + b64).then((r) => r.arrayBuffer()).then((ab) => new Uint8Array(ab));
}

function renderPdfJsToPane(b64) {
  const pane = document.getElementById("preview-web-scroll");
  if (!pane) return Promise.reject(new Error("no pane"));
  return ensurePdfJsScript()
    .then(() => base64ToUint8Array(b64))
    .then((data) => pdfjsLib.getDocument({ data, verbosity: 0 }).promise)
    .then((pdf) => {
      const viewportEl = document.createElement("div");
      viewportEl.className = "pdfjs-viewport";
      const head = document.createElement("div");
      head.style.cssText = "color:#93a0ad;font-size:12px;margin-bottom:10px;text-align:center;";
      head.textContent = "鍏?" + pdf.numPages + " 椤?路 PDF.js 鍐呭祵棰勮锛堟棤闇€ QuickLook锛?;
      viewportEl.appendChild(head);
      pane.innerHTML = "";
      pane.appendChild(viewportEl);
      const hostWidth = Math.max(280, pane.clientWidth - 20);
      const maxPages = Math.min(pdf.numPages, 200);
      if (pdf.numPages > maxPages) {
        const warn = document.createElement("div");
        warn.style.cssText = "color:#ffb347;font-size:11px;text-align:center;margin:6px 0;";
        warn.textContent = "椤垫暟杩囧锛屼粎娓叉煋鍓?" + maxPages + " 椤典互淇濊瘉娴佺晠锛涘畬鏁撮槄璇昏浣跨敤澶栭儴闃呰鍣ㄣ€?;
        viewportEl.appendChild(warn);
      }
      const items = [];
      for (let p = 1; p <= maxPages; p++) {
        const wrap = document.createElement("div");
        wrap.className = "pdfjs-page-wrap";
        const ph = document.createElement("div");
        ph.className = "pdfjs-page-ph";
        ph.textContent = "绗?" + p + " 椤碘€?;
        wrap.appendChild(ph);
        viewportEl.appendChild(wrap);
        items.push({ wrap, ph, pn: p, done: false });
      }
      const io = new IntersectionObserver(
        (ents) => {
          for (const e of ents) {
            if (!e.isIntersecting) continue;
            const w = e.target;
            io.unobserve(w);
            const item = items.find((it) => it.wrap === w);
            if (item && !item.done) {
              item.done = true;
              pdf.getPage(item.pn).then((page) => {
                const baseVp = page.getViewport({ scale: 1 });
                const scale = Math.min(hostWidth / baseVp.width, 2);
                const vp = page.getViewport({ scale });
                const canvas = document.createElement("canvas");
                const ctx = canvas.getContext("2d");
                canvas.width = vp.width;
                canvas.height = vp.height;
                return page.render({ canvasContext: ctx, viewport: vp }).promise.then(() => {
                  item.ph.replaceWith(canvas);
                });
              }).catch(() => {
                item.ph.textContent = "绗?" + item.pn + " 椤垫覆鏌撳け璐?;
              });
            }
          }
        },
        { root: viewportEl, rootMargin: "400px", threshold: 0.01 }
      );
      for (const it of items) {
        io.observe(it.wrap);
      }
      return null;
    });
}

function runPdfJsPipelineFromBase64(b64) {
  renderPdfJsToPane(b64)
    .then(() => {
      finishPdfPlan(true);
    })
    .catch(() => {
      advancePdfPlan("pdfjs_render_fail");
    });
}

function onWebPdfJsBegin(payload) {
  if (Number(payload.seq) !== state.previewSeq) return;
  if (!state.pdfPlan || state.pdfPlan.done || state.pdfPlan.current !== "pdfjs") return;
  const n = Number(payload.totalParts);
  const tb = Number(payload.totalBytes);
  if (!Number.isFinite(n) || n < 1) {
    advancePdfPlan("pdfjs_begin_bad");
    return;
  }
  state.pdfJsRx = {
    seq: Number(payload.seq),
    totalParts: n,
    totalBytes: Number.isFinite(tb) ? tb : 0,
    parts: new Array(n),
    got: 0
  };
  const pane = document.getElementById("preview-web-scroll");
  if (pane) {
    const mb = state.pdfJsRx.totalBytes > 0 ? (state.pdfJsRx.totalBytes / ONE_MB).toFixed(2) : "?";
    pane.innerHTML =
      "<div class=\"preview-loading\">PDF.js 浼犺緭涓€︼紙绾?" + escapeHtml(String(mb)) + " MB 路 " + n + " 娈碉級</div>";
  }
}

function onWebPdfJsPart(payload) {
  if (Number(payload.seq) !== state.previewSeq) return;
  const rx = state.pdfJsRx;
  if (!rx || rx.seq !== Number(payload.seq)) return;
  const idx = Number(payload.index);
  if (!Number.isFinite(idx) || idx < 0 || idx >= rx.totalParts) return;
  if (rx.parts[idx] != null) return;
  rx.parts[idx] = String(payload.data || "");
  rx.got++;
  if (rx.got < rx.totalParts) return;
  const b64 = rx.parts.join("");
  state.pdfJsRx = null;
  runPdfJsPipelineFromBase64(b64);
}

function onWebPdfJsError(payload) {
  if (Number(payload.seq) !== state.previewSeq) return;
  if (!state.pdfPlan || state.pdfPlan.done) return;
  if (state.pdfPlan.current !== "pdfjs") return;
  state.pdfJsRx = null;
  advancePdfPlan("pdfjs_err");
}

function startPdfPlan(path, seq) {
  let mode = state.pdfMode || "auto";
  if (mode === "quicklook" && !isQuickLookInstalled()) {
    mode = "auto";
    setPdfMode("auto");
  }
  let chain = [];
  if (mode === "auto")
    chain = state.pdfWebBroken ? ["pdfjs", "pdfium", "ipreview"] : ["pdfjs", "web", "pdfium", "ipreview"];
  else if (mode === "quicklook")
    chain = ["quicklook"]; // only run QuickLook when explicitly selected
  else
    chain = [mode];
  state.pdfJsRx = null;
  state.pdfPlan = { path, seq, chain, idx: -1, done: false, timer: 0 };
  advancePdfPlan("start");
}

function finishPdfPlan(ok) {
  if (!state.pdfPlan) return;
  if (state.pdfPlan.timer) {
    clearTimeout(state.pdfPlan.timer);
    state.pdfPlan.timer = 0;
  }
  state.pdfPlan.done = !!ok;
}

function advancePdfPlan(reason) {
  if (!state.pdfPlan || state.pdfPlan.done) return;
  if (state.pdfPlan.timer) {
    clearTimeout(state.pdfPlan.timer);
    state.pdfPlan.timer = 0;
  }
  state.pdfPlan.idx += 1;
  if (state.pdfPlan.idx >= state.pdfPlan.chain.length) {
    const pane = document.getElementById("preview-web-scroll");
    if (pane) {
      pane.innerHTML =
        "<div class=\"preview-empty\">褰撳墠 PDF 棰勮鍧囨湭鎴愬姛锛堝凡灏濊瘯 PDF.js銆乄ebView 鍐呯疆銆丳DFium 涓庣郴缁熼瑙堬級銆?br><br>" +
        "璇风‘璁ゆ枃浠跺皬浜?40MB锛涘彲鍙屽嚮鍒楄〃鐢ㄩ粯璁ょ▼搴忔墦寮€銆傚彲閫夛細QuickLook 鎸夐挳銆?/div>";
    }
    finishPdfPlan(false);
    return;
  }

  const mode = state.pdfPlan.chain[state.pdfPlan.idx];
  state.pdfPlan.current = mode;
  const pane = document.getElementById("preview-web-scroll");
  if (!pane) return;

  if (mode === "pdfjs") {
    setPreviewLayoutMode("web");
    stopNativePreview();
    state.pdfJsRx = null;
    pane.innerHTML = "<div class=\"preview-loading\">PDF.js 鍐呭祵棰勮鍑嗗涓€?/div>";
    postToAhk({ type: "INVOKE_PDF_JS", path: state.pdfPlan.path, seq: state.pdfPlan.seq });
    return;
  }
  if (mode === "web") {
    setPreviewLayoutMode("web");
    stopNativePreview();
    pane.innerHTML = "<div class=\"preview-loading\">PDF WebView 鏂规鍔犺浇涓€?/div>";
    postToAhk({ type: "INVOKE_WEB_MEDIA", path: state.pdfPlan.path, seq: state.pdfPlan.seq });
    return;
  }
  if (mode === "pdfium") {
    setPreviewLayoutMode("web");
    stopNativePreview();
    pane.innerHTML = "<div class=\"preview-loading\">PDFium 鏂规鍔犺浇涓€?/div>";
    postToAhk({ type: "INVOKE_PDFIUM", path: state.pdfPlan.path, seq: state.pdfPlan.seq });
    return;
  }
  if (mode === "ipreview") {
    setPreviewLayoutMode("native");
    pane.innerHTML = "<div class=\"preview-loading\">IPreviewHandler 鏂规鍔犺浇涓€?/div>";
    invokeIPreviewHandler();
    return;
  }
  if (mode === "quicklook") {
    setPreviewLayoutMode("web");
    stopNativePreview();
    pane.innerHTML = "<div class=\"preview-empty\">宸插垏鎹㈠埌 QuickLook 鍏滃簳棰勮銆?/div>";
    invokeQuickLook(state.pdfPlan.path);
    finishPdfPlan(true);
  }
}

function onPdfWebMediaResult(payload) {
  if (!state.pdfPlan || state.pdfPlan.done) return;
  if (state.pdfPlan.current !== "web") return;
  if (Number(payload.seq) !== state.previewSeq) return;
  const pane = document.getElementById("preview-web-scroll");
  if (!pane) return;
  const url = payload.url ? String(payload.url) : "";
  if (!url) {
    state.pdfWebBroken = true;
    advancePdfPlan("web_empty");
    return;
  }
  pane.innerHTML = "<iframe id=\"pdf-webview-frame\" src=\"" + escapeHtml(url) + "\" style=\"width:100%;height:100%;min-height:360px;border:none;background:#111;\"></iframe>";
  const frame = document.getElementById("pdf-webview-frame");
  if (!frame) {
    advancePdfPlan("web_iframe_missing");
    return;
  }
  let settled = false;
  const ok = () => {
    if (settled) return;
    settled = true;
    state.pdfWebBroken = false;
    finishPdfPlan(true);
  };
  const fail = () => {
    if (settled) return;
    settled = true;
    state.pdfWebBroken = true;
    advancePdfPlan("web_iframe_error");
  };
  frame.addEventListener("load", ok, { once: true });
  frame.addEventListener("error", fail, { once: true });
  state.pdfPlan.timer = setTimeout(() => {
    if (!settled) fail();
  }, 4500);
}

function onWebPreviewPdfiumResult(payload) {
  if (!state.pdfPlan || state.pdfPlan.done) return;
  if (state.pdfPlan.current !== "pdfium") return;
  if (Number(payload.seq) !== state.previewSeq) return;
  const pane = document.getElementById("preview-web-scroll");
  if (!pane) return;
  const dataUrl = payload.dataUrl ? String(payload.dataUrl) : "";
  if (!dataUrl) {
    advancePdfPlan("pdfium_fail");
    return;
  }
  pane.innerHTML = "";
  const img = new Image();
  img.className = "preview-img";
  img.src = dataUrl;
  pane.appendChild(img);
  finishPdfPlan(true);
}

function onWebPreviewMediaResult(payload) {
  if (Number(payload.seq) !== state.previewSeq) return;
  const pane = document.getElementById("preview-web-scroll");
  if (!pane) return;
  const url = payload.url ? String(payload.url) : "";
  const posterUrl = payload.posterUrl ? String(payload.posterUrl) : "";
  const payloadDuration = Number(payload.durationSec);
  const payloadMediaInfo = payload.mediaInfo && typeof payload.mediaInfo === "object" ? payload.mediaInfo : null;
  if (!url) {
    pane.innerHTML = "<div class=\"preview-empty\">濯掍綋棰勮鍦板潃涓虹┖锛屾棤娉曞姞杞姐€?/div>";
    return;
  }
  const pathForMedia = (payload.path && String(payload.path).trim()) || state.previewPath || "";
  const ext = pathExtensionLower(pathForMedia);
  const fileName = pathForMedia ? String(pathForMedia).replace(/^.*[\\/]/, "") : "";
  const kind = PREVIEW_AUDIO_EXT.has(ext) ? "audio" : "video";
  const mediaId = "preview-media-el";
  const currentId = "preview-media-current";
  const durationId = "preview-media-duration";
  const statusId = "preview-media-status";
  const sizeId = "preview-media-size";
  const infoPanelId = "preview-media-info";
  const loopActive = state.mediaPrefs.loop ? " active" : "";
  const mutedActive = state.mediaPrefs.muted ? " active" : "";
  const autoplayActive = state.mediaPrefs.autoplay ? " active" : "";
  if (PREVIEW_AUDIO_EXT.has(ext)) {
    pane.innerHTML =
      "<div class=\"media-card\">" +
        "<div class=\"media-player\">" +
          "<div class=\"media-head\">" +
            "<div class=\"media-title-wrap\"><div class=\"media-title\">" + escapeHtml(fileName || "闊抽棰勮") + "</div><div class=\"media-subtitle\">鎼滅储涓績闊抽棰勮</div></div>" +
            "<div class=\"media-chips\"><span class=\"media-chip\">闊抽</span><span class=\"media-chip\" id=\"" + sizeId + "\">姝ｅ湪璇诲彇淇℃伅</span></div>" +
          "</div>" +
          "<audio id=\"" + mediaId + "\" class=\"preview-media preview-audio\" controls preload=\"metadata\" src=\"" + escapeHtml(url) + "\"></audio>" +
          "<div class=\"media-toolbar\">" +
            "<div class=\"media-actions\">" +
              "<button type=\"button\" class=\"media-btn\" data-media-action=\"info\">缂栫爜淇℃伅</button>" +
              "<button type=\"button\" class=\"media-btn" + loopActive + "\" data-media-toggle=\"loop\">寰幆鎾斁</button>" +
              "<button type=\"button\" class=\"media-btn" + mutedActive + "\" data-media-toggle=\"muted\">闈欓煶</button>" +
              "<button type=\"button\" class=\"media-btn" + autoplayActive + "\" data-media-toggle=\"autoplay\">鑷姩鎾斁</button>" +
            "</div>" +
          "</div>" +
          "<div id=\"" + infoPanelId + "\" class=\"media-info-panel\"></div>" +
          "<div class=\"media-status\"><span>褰撳墠 <strong id=\"" + currentId + "\">0:00</strong></span><span>鎬绘椂闀?<strong id=\"" + durationId + "\">--:--</strong></span><span id=\"" + statusId + "\">灏辩华</span></div>" +
        "</div>" +
      "</div>";
  } else if (PREVIEW_VIDEO_EXT.has(ext)) {
    pane.innerHTML =
      "<div class=\"media-card\">" +
        "<div class=\"media-player\">" +
          "<div class=\"media-head\">" +
            "<div class=\"media-title-wrap\"><div class=\"media-title\">" + escapeHtml(fileName || "瑙嗛棰勮") + "</div><div class=\"media-subtitle\">鎼滅储涓績瑙嗛棰勮</div></div>" +
            "<div class=\"media-chips\"><span class=\"media-chip\">瑙嗛</span><span class=\"media-chip\" id=\"" + sizeId + "\">姝ｅ湪璇诲彇淇℃伅</span></div>" +
          "</div>" +
          "<video id=\"" + mediaId + "\" class=\"preview-media preview-video\" controls preload=\"metadata\" playsinline" + (posterUrl ? " poster=\"" + escapeHtml(posterUrl) + "\"" : "") + " src=\"" + escapeHtml(url) + "\"></video>" +
          "<div class=\"media-toolbar\">" +
            "<div class=\"media-actions\">" +
              "<button type=\"button\" class=\"media-btn\" data-media-action=\"poster\">鍒锋柊灏侀潰</button>" +
              "<button type=\"button\" class=\"media-btn\" data-media-action=\"save-frame\">淇濆瓨鎴浘</button>" +
              "<button type=\"button\" class=\"media-btn\" data-media-action=\"info\">缂栫爜淇℃伅</button>" +
              "<button type=\"button\" class=\"media-btn" + loopActive + "\" data-media-toggle=\"loop\">寰幆鎾斁</button>" +
              "<button type=\"button\" class=\"media-btn" + mutedActive + "\" data-media-toggle=\"muted\">闈欓煶</button>" +
              "<button type=\"button\" class=\"media-btn" + autoplayActive + "\" data-media-toggle=\"autoplay\">鑷姩鎾斁</button>" +
            "</div>" +
          "</div>" +
          "<div id=\"" + infoPanelId + "\" class=\"media-info-panel\"></div>" +
          "<div class=\"media-status\"><span>褰撳墠 <strong id=\"" + currentId + "\">0:00</strong></span><span>鎬绘椂闀?<strong id=\"" + durationId + "\">" + escapeHtml(Number.isFinite(payloadDuration) && payloadDuration > 0 ? formatDuration(payloadDuration) : "--:--") + "</strong></span><span id=\"" + statusId + "\">灏辩华</span></div>" +
        "</div>" +
      "</div>";
  }
  if (Number.isFinite(payloadDuration) && payloadDuration > 0) {
    renderRichMeta({ Duration: formatDuration(payloadDuration) }, true);
  }
  wireMediaPreview(kind, { posterUrl, payloadDuration, mediaInfo: payloadMediaInfo });
}

function wireMediaPreview(kind, options = {}) {
  const media = document.getElementById("preview-media-el");
  if (!media) return;
  const mediaPlayer = media.closest(".media-player");
  const scrollHost = document.getElementById("preview-web-scroll");
  const currentEl = document.getElementById("preview-media-current");
  const durationEl = document.getElementById("preview-media-duration");
  const statusEl = document.getElementById("preview-media-status");
  const sizeEl = document.getElementById("preview-media-size");
  const infoPanel = document.getElementById("preview-media-info");
  const resumeTime = loadMediaResume(state.previewPath);
  let saveTick = 0;
  let seekingPoster = false;
  const applyPrefs = () => {
    media.loop = !!state.mediaPrefs.loop;
    media.muted = !!state.mediaPrefs.muted;
    media.autoplay = !!state.mediaPrefs.autoplay;
  };
  const hasPresetPoster = !!options.posterUrl;
  const syncMeta = () => {
    const totalSec = Number.isFinite(media.duration) && media.duration > 0 ? media.duration : options.payloadDuration;
    const total = formatDuration(totalSec);
    const current = formatDuration(media.currentTime);
    if (currentEl) currentEl.textContent = current;
    if (durationEl) durationEl.textContent = total;
    const extra = [];
    if (kind === "video" && Number.isFinite(media.videoWidth) && Number.isFinite(media.videoHeight) && media.videoWidth > 0) {
      extra.push(`${media.videoWidth}x${media.videoHeight}`);
      renderRichMeta({ Resolution: `${media.videoWidth} x ${media.videoHeight}` }, true);
    }
    if (Number.isFinite(totalSec) && totalSec > 0) {
      renderRichMeta({ Duration: total }, true);
      extra.unshift(total);
    }
    if (sizeEl && extra.length) sizeEl.textContent = extra.join(" 路 ");
  };
  const updateButtons = () => {
    document.querySelectorAll("[data-media-toggle]").forEach((btn) => {
      const key = btn.getAttribute("data-media-toggle");
      btn.classList.toggle("active", !!state.mediaPrefs[key]);
    });
  };
  const capturePoster = () => {
    if (kind !== "video") return;
    try {
      if (!media.videoWidth || !media.videoHeight) return;
      const canvas = document.createElement("canvas");
      canvas.width = media.videoWidth;
      canvas.height = media.videoHeight;
      const ctx = canvas.getContext("2d");
      if (!ctx) return;
      ctx.drawImage(media, 0, 0, canvas.width, canvas.height);
      media.setAttribute("poster", canvas.toDataURL("image/jpeg", 0.82));
    } catch {}
  };
  const renderInfoPanel = (info) => {
    if (!infoPanel) return;
    const data = info && typeof info === "object" ? info : {};
    const keys = Object.keys(data);
    if (!keys.length) {
      infoPanel.innerHTML = '<div class="media-info-row"><span class="media-info-val">鏆傛棤缂栫爜淇℃伅</span></div>';
      return;
    }
    infoPanel.innerHTML = keys.map((key) =>
      '<div class="media-info-row"><span class="media-info-key">' + escapeHtml(key) + ':</span><span class="media-info-val">' + escapeHtml(data[key]) + '</span></div>'
    ).join("");
  };
  const toggleInfoPanel = () => {
    if (!infoPanel) return;
    if (infoPanel.classList.contains("open")) {
      infoPanel.classList.remove("open");
      return;
    }
    if (!infoPanel.innerHTML.trim()) {
      infoPanel.innerHTML = '<div class="media-info-row"><span class="media-info-val">姝ｅ湪璇诲彇缂栫爜淇℃伅...</span></div>';
      postToAhk({ type: "GET_MEDIA_INFO", path: state.previewPath, seq: state.previewSeq });
    }
    infoPanel.classList.add("open");
  };
  const refreshPosterBySeek = () => {
    if (kind !== "video" || seekingPoster) return;
    const totalSec = Number.isFinite(media.duration) && media.duration > 0 ? media.duration : options.payloadDuration;
    const target = Math.min(Math.max(Number(totalSec || 0) * 0.12, 1.2), Math.max(Number(totalSec || 0) - 0.4, 1.2));
    const originalTime = Number.isFinite(media.currentTime) ? media.currentTime : 0;
    const wasPaused = media.paused;
    seekingPoster = true;
    const onSeeked = () => {
      capturePoster();
      const onRestore = () => {
        media.removeEventListener("seeked", onRestore);
        if (!wasPaused) {
          try { media.play(); } catch {}
        }
        seekingPoster = false;
      };
      media.addEventListener("seeked", onRestore);
      try {
        media.currentTime = originalTime > 0 ? originalTime : 0;
      } catch {
        seekingPoster = false;
      }
    };
    try {
      media.pause();
      media.addEventListener("seeked", onSeeked, { once: true });
      media.currentTime = target;
    } catch {
      seekingPoster = false;
    }
  };
  const forwardWheel = (ev) => {
    if (!scrollHost) return;
    const dy = Number(ev.deltaY) || 0;
    const dx = Number(ev.deltaX) || 0;
    if (Math.abs(dy) < 0.01 && Math.abs(dx) < 0.01) return;
    ev.preventDefault();
    scrollHost.scrollTop += dy;
    if (dx) scrollHost.scrollLeft += dx;
  };
  applyPrefs();
  updateButtons();
  if (options.mediaInfo && Object.keys(options.mediaInfo).length) {
    renderInfoPanel(options.mediaInfo);
  }
  media.addEventListener("wheel", forwardWheel, { passive: false });
  if (mediaPlayer) mediaPlayer.addEventListener("wheel", forwardWheel, { passive: false });
  media.addEventListener("loadedmetadata", () => {
    syncMeta();
    if (statusEl) statusEl.textContent = "淇℃伅宸插姞杞?;
    if (resumeTime > 1 && Number.isFinite(media.duration) && resumeTime < Math.max(2, media.duration - 2)) {
      try {
        media.currentTime = resumeTime;
        if (statusEl) statusEl.textContent = "宸叉仮澶嶄笂娆℃挱鏀句綅缃?;
      } catch {}
    }
    if (state.mediaPrefs.autoplay) {
      const playAttempt = media.play();
      if (playAttempt && typeof playAttempt.catch === "function") {
        playAttempt.catch(() => {
          if (statusEl) statusEl.textContent = "鑷姩鎾斁琚嫤鎴?;
        });
      }
    }
  }, { once: true });
  media.addEventListener("loadeddata", () => {
    if (kind === "video") {
      if (!hasPresetPoster) capturePoster();
      setTimeout(() => refreshPosterBySeek(), hasPresetPoster ? 120 : 40);
    }
  }, { once: true });
  media.addEventListener("timeupdate", () => {
    if (currentEl) currentEl.textContent = formatDuration(media.currentTime);
    if (seekingPoster) return;
    if (!state.previewPath) return;
    if (Date.now() - saveTick > 1600) {
      saveTick = Date.now();
      saveMediaResume(state.previewPath, media.currentTime);
    }
  });
  media.addEventListener("play", () => {
    if (statusEl) statusEl.textContent = "鎾斁涓?;
  });
  media.addEventListener("pause", () => {
    if (statusEl) statusEl.textContent = "宸叉殏鍋?;
  });
  media.addEventListener("ended", () => {
    if (statusEl) statusEl.textContent = media.loop ? "寰幆涓? : "鎾斁缁撴潫";
  });
  media.addEventListener("volumechange", () => {
    if (statusEl && media.muted) statusEl.textContent = "闈欓煶";
  });
  document.querySelectorAll("[data-media-toggle]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const key = btn.getAttribute("data-media-toggle");
      const next = !state.mediaPrefs[key];
      saveMediaPref(key, next);
      applyPrefs();
      updateButtons();
      if (key === "autoplay" && next) {
        try { media.play(); } catch {}
      }
    });
  });
  document.querySelectorAll("[data-media-action='poster']").forEach((btn) => {
    btn.addEventListener("click", () => refreshPosterBySeek());
  });
  document.querySelectorAll("[data-media-action='info']").forEach((btn) => {
    btn.addEventListener("click", () => toggleInfoPanel());
  });
  document.querySelectorAll("[data-media-action='save-frame']").forEach((btn) => {
    btn.addEventListener("click", () => {
      postToAhk({ type: "SAVE_MEDIA_FRAME", path: state.previewPath, timeSec: media.currentTime || 0, seq: state.previewSeq });
    });
  });
}

function runPreviewForSelection() {
  state.previewSeq += 1;
  state.pdfJsRx = null;
  const seq = state.previewSeq;
  const meta = document.getElementById("preview-meta");
  const pane = document.getElementById("preview-web-scroll");
  const item = state.results.find((entry) => entry.row == state.selectedRow);
  if (!meta || !pane) return;

  if (!item) {
    meta.textContent = "鏈€変腑缁撴灉";
    pane.innerHTML =
      "<div class=\"preview-empty\">褰撳墠鏈€変腑鏈湴缁撴灉銆?br><br>鍦ㄨ緭鍏ユ涓緭鍏ュ唴瀹瑰彲瀹炴椂杩囨护鏁版嵁锛岀偣鍑诲垪琛ㄩ」鍚庝細鍦ㄨ繖閲屾樉绀鸿缁嗛瑙堛€?br><br>" +
      "<div class=\"sk-line w1\"></div><div class=\"sk-line w3\"></div><div class=\"sk-line w2\"></div></div>";
    setPreviewLayoutMode("web");
    setQuickLookHintVisible(false);
    state.previewPath = "";
    stopNativePreview();
    return;
  }

  const isFile = !!getSelectedItemPath(item);
  const path = getSelectedItemPath(item);
  state.previewPath = path;
  setQuickLookHintVisible(!!path);

  renderRichMeta({
    "鏉ユ簮": item.source || item.subtitle || "",
    "绫诲瀷": item.type || "",
    "鏃堕棿": item.time || ""
  });

  if (!path) {
    setPreviewLayoutMode("web");
    stopNativePreview();
    renderFallbackTextPreview(item, pane, meta);
    return;
  }

  const ext = pathExtensionLower(path);
  updatePdfModeButton();

  if (PREVIEW_PDF_EXT.has(ext)) {
    startPdfPlan(path, seq);
    return;
  }

  if (PREVIEW_ARCHIVE_EXT.has(ext)) {
    setPreviewLayoutMode("web");
    stopNativePreview();
    pane.innerHTML = "<div class=\"preview-loading\">姝ｅ湪璇诲彇鍘嬬缉鍖呯洰褰曗€?/div>";
    postToAhk({ type: "INVOKE_ARCHIVE_LIST", path, seq });
    return;
  }

  if (PREVIEW_TEXT_EXT.has(ext)) {
    setPreviewLayoutMode("web");
    stopNativePreview();
    pane.innerHTML = "<div class=\"preview-loading\">鍔犺浇鏂囨湰鈥?/div>";
    postToAhk({ type: "WEB_PREVIEW_TEXT", path, seq });
    return;
  }

  if (PREVIEW_IMAGE_EXT.has(ext)) {
    setPreviewLayoutMode("web");
    stopNativePreview();
    pane.innerHTML = "<div class=\"preview-loading\">鍔犺浇鍥剧墖鈥?/div>";
    postToAhk({ type: "WEB_PREVIEW_IMAGE", path, seq });
    return;
  }

  if (PREVIEW_AUDIO_EXT.has(ext) || PREVIEW_VIDEO_EXT.has(ext)) {
    setPreviewLayoutMode("web");
    stopNativePreview();
    pane.innerHTML = "<div class=\"preview-loading\">Loading media preview...</div>";
    postToAhk({ type: "INVOKE_WEB_MEDIA", path, seq });
    return;
  }

  setPreviewLayoutMode("native");
  pane.innerHTML = "<div class=\"preview-empty\" style=\"min-height:80px\">姝ゅ涓哄師鐢熼瑙堝崰浣嶅尯鍩熴€?br><br>浣犲彲浠ョ偣鍑讳笅鏂规寜閽垨鎸夌┖鏍煎皾璇曚笉鍚岄瑙堟柟寮忋€?/div>";
  
  const isL1Handled = PREVIEW_TEXT_EXT.has(ext) || PREVIEW_IMAGE_EXT.has(ext) || PREVIEW_AUDIO_EXT.has(ext) || PREVIEW_VIDEO_EXT.has(ext);
  const qlBtn = document.getElementById("preview-ql-btn");
  const nativeBtn = document.getElementById("preview-native-btn");
  if (qlBtn) qlBtn.classList.toggle("btn-highlight", !isL1Handled);
  if (nativeBtn) nativeBtn.classList.toggle("btn-highlight", !isL1Handled && !state.iPreviewFailed);

  requestAnimationFrame(() => {
    requestAnimationFrame(() => {
      if (seq !== state.previewSeq) return;
      // 榛樿涓嶈嚜鍔ㄥ姞杞介噸鍨?IPreviewHandler锛岄櫎闈炴枃浠剁被鍨嬮潪甯告槑纭垨鏄敤鎴疯姹?    });
  });
}

function onWebPreviewTextResult(payload) {
  if (Number(payload.seq) !== state.previewSeq) return;
  const pane = document.getElementById("preview-web-scroll");
  if (!pane) return;
  const raw = payload.text != null ? String(payload.text) : "";
  const sizeBytes = Number(payload.sizeBytes) || 0;
  const truncatedServer = !!payload.truncated;
  let body = raw;
  let note = "";
  let lineTrunc = false;
  if (sizeBytes > ONE_MB || truncatedServer) {
    const t = truncateToLines(body, 1000);
    body = t.text;
    lineTrunc = t.truncated;
    note = "鏂囦欢杈冨ぇ锛屽凡鎴柇鏄剧ず锛堟渶澶氱害 1MB / 1000 琛岋級銆傚畬鏁村唴瀹硅鐢ㄥ閮ㄧ紪杈戝櫒鎵撳紑鎴栧弻鍑荤粨鏋溿€?;
  }
  const ext = pathExtensionLower(state.previewPath);
  const lang = prismLangForExt(ext);
  const esc = body
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;");
  let html = "";
  if (note) html += "<div class=\"preview-truncate-note\">" + note + (lineTrunc ? "锛堝凡闄愬埗涓哄墠 1000 琛岋級" : "") + "</div>";
  if (lang === "plaintext") {
    html += "<pre class=\"preview-plain\">" + esc + "</pre>";
  } else {
    html += "<pre><code class=\"language-" + lang + "\">" + esc + "</code></pre>";
  }
  pane.innerHTML = html;
  if (lang !== "plaintext") {
    const code = pane.querySelector("code");
    if (code && window.Prism) {
      try {
        Prism.highlightElement(code);
      } catch (e) {
        /* ignore */
      }
    }
  }
}

function onWebPreviewImageResult(payload) {
  if (Number(payload.seq) !== state.previewSeq) return;
  const pane = document.getElementById("preview-web-scroll");
  if (!pane) return;
  const url = payload.dataUrl ? String(payload.dataUrl) : "";
  if (!url) {
    pane.innerHTML = "<div class=\"preview-empty\">鏃犳硶鍔犺浇鍥剧墖棰勮銆?/div>";
    return;
  }
  const img = new Image();
  img.className = "preview-img";
  img.onload = () => {
     renderRichMeta({ "鍥剧墖灏哄": img.naturalWidth + " x " + img.naturalHeight }, true);
  };
  img.src = url;
  pane.innerHTML = "";
  pane.appendChild(img);
}

function onWebPreviewArchiveResult(payload) {
  if (Number(payload.seq) !== state.previewSeq) return;
  const pane = document.getElementById("preview-web-scroll");
  if (!pane) return;
  const entries = Array.isArray(payload.entries) ? payload.entries : [];
  const error = payload.error ? String(payload.error) : "";
  if (error) {
    pane.innerHTML =
      "<div class=\"preview-empty\">鍘嬬缉鍖呯洰褰曡鍙栧け璐ワ細" + escapeHtml(error) + "<br><br>鍙弻鍑荤敤鍏宠仈绋嬪簭鎵撳紑鍘嬬缉鍖呫€?/div>";
    return;
  }
  if (!entries.length) {
    pane.innerHTML = "<div class=\"preview-empty\">鍘嬬缉鍖呭唴娌℃湁鍙睍绀虹殑鏉＄洰銆?/div>";
    return;
  }
  let html = "<div class=\"preview-truncate-note\">Archive List (read-only)</div>";
  html += "<table style=\"width:100%; border-collapse:collapse; font-size:12px;\">";
  html += "<thead><tr><th style=\"text-align:left; padding:6px; border-bottom:1px solid #333;\">Name</th><th style=\"text-align:right; padding:6px; border-bottom:1px solid #333;\">Size</th><th style=\"text-align:right; padding:6px; border-bottom:1px solid #333;\">Packed</th><th style=\"text-align:left; padding:6px; border-bottom:1px solid #333;\">Modified</th></tr></thead><tbody>";
  entries.forEach((it) => {
    const nm = (it.folder ? "[D] " : "[F] ") + (it.path || "");
    html += "<tr>";
    html += "<td style=\"padding:6px; border-bottom:1px solid #262626; word-break:break-all;\">" + escapeHtml(nm) + "</td>";
    html += "<td style=\"padding:6px; border-bottom:1px solid #262626; text-align:right;\">" + escapeHtml(String(it.size || "")) + "</td>";
    html += "<td style=\"padding:6px; border-bottom:1px solid #262626; text-align:right;\">" + escapeHtml(String(it.packed || "")) + "</td>";
    html += "<td style=\"padding:6px; border-bottom:1px solid #262626;\">" + escapeHtml(String(it.modified || "")) + "</td>";
    html += "</tr>";
  });
  html += "</tbody></table>";
  if (payload.truncated) {
    html += "<div class=\"preview-truncate-note\">鏉＄洰杈冨锛屽凡鎴柇鏄剧ず鍓?" + escapeHtml(String(entries.length)) + " 椤广€?/div>";
  }
  pane.innerHTML = html;
}

function renderRichMeta(data, append = false) {
  const wrap = document.getElementById("preview-meta");
  if (!wrap) return;
  if (!append) wrap.innerHTML = "";
  
  Object.keys(data).forEach(key => {
    const val = data[key];
    if (val == null || val === "") return;
    
    // 濡傛灉鏄拷鍔犱笖宸插瓨鍦ㄨ Key锛屽垯鏇存柊
    let existing = wrap.querySelector(`[data-meta-key="${key}"]`);
    if (existing) {
       existing.querySelector(".preview-meta-val").textContent = val;
    } else {
       const row = document.createElement("div");
       row.className = "preview-meta-item";
       row.dataset.metaKey = key;
       row.innerHTML = `<span class="preview-meta-key">${escapeHtml(key)}:</span><span class="preview-meta-val">${escapeHtml(val)}</span>`;
       wrap.appendChild(row);
    }
  });
}

function onPreviewMetaUpdate(payload) {
  if (Number(payload.seq) !== state.previewSeq) return;
  if (payload.meta) {
    renderRichMeta(payload.meta, true);
  }
}

function onMediaInfoResult(payload) {
  if (Number(payload.seq) !== state.previewSeq) return;
  const panel = document.getElementById("preview-media-info");
  if (!panel) return;
  const info = payload.info && typeof payload.info === "object" ? payload.info : {};
  const keys = Object.keys(info);
  if (!keys.length) {
    panel.innerHTML = '<div class="media-info-row"><span class="media-info-val">鏆傛棤缂栫爜淇℃伅</span></div>';
    panel.classList.add("open");
    return;
  }
  panel.innerHTML = keys.map((key) =>
    '<div class="media-info-row"><span class="media-info-key">' + escapeHtml(key) + ':</span><span class="media-info-val">' + escapeHtml(info[key]) + '</span></div>'
  ).join("");
  panel.classList.add("open");
}

function onMediaFrameSaveResult(payload) {
  if (Number(payload.seq) !== state.previewSeq) return;
  const statusEl = document.getElementById("preview-media-status");
  if (!statusEl) return;
  statusEl.textContent = payload && payload.ok ? "鎴浘宸蹭繚瀛? : (payload.message ? String(payload.message) : "鎴浘淇濆瓨澶辫触");
}

function onNativePreviewFailed(payload) {
  state.iPreviewFailed = true;
  state.iPreviewActive = false;
  if (state.pdfPlan && !state.pdfPlan.done && state.pdfPlan.current === "ipreview") {
    advancePdfPlan("ipreview_fail");
    return;
  }
  const pane = document.getElementById("preview-web-scroll");
  if (!pane) return;
  const msg = payload.message ? String(payload.message) : "绯荤粺鍘熺敓棰勮涓嶅彲鐢ㄣ€?;
  stopNativePreview();
  setPreviewLayoutMode("web");
  pane.innerHTML =
    "<div class=\"preview-empty\">" +
    escapeHtml(msg) +
    "<br><br>渚ф爮榛樿宸蹭紭鍏堜娇鐢?PDF.js锛涘彲鎸夌┖鏍奸噸鏂板姞杞介瑙堬紝鎴栧垏鎹?PDF:pdfjs / PDF:web銆?/div>";
  
  const qlBtn = document.getElementById("preview-ql-btn");
  if (qlBtn) qlBtn.classList.add("btn-highlight");
}

function invokeIPreviewHandler() {
  if (!state.previewPath) return;
  state.iPreviewActive = true;
  state.iPreviewFailed = false; // 閲嶈瘯
  const b = collectPreviewBounds();
  postToAhk({ 
    type: "INVOKE_IPREVIEW", 
    path: state.previewPath, 
    seq: state.previewSeq,
    bounds: b 
  });
}

function invokeQuickLook(pathOverride = "") {
  const overridePath = pathOverride ? String(pathOverride).trim() : "";
  let targetPath = overridePath;
  const selectedRow = Number(state.selectedRow) || 0;
  if (!targetPath && selectedRow > 0) {
    const item = state.results.find((entry) => entry.row == selectedRow);
    targetPath = getSelectedItemPath(item) || "";
  }
  if (!targetPath) targetPath = state.previewPath || "";
  if (!targetPath) return;
  const pane = document.getElementById("preview-web-scroll");
  state.quickLook = state.quickLook || {};
  if (!isQuickLookInstalled()) {
    if (state.quickLook.installBusy) {
      if (pane) pane.innerHTML = "<div class=\"preview-loading\">姝ｅ湪瀹夎 QuickLook鈥?/div>";
      return;
    }
    const ok = window.confirm("灏氭湭瀹夎 QuickLook銆傛槸鍚︾幇鍦ㄤ笅杞藉苟鍚敤 QuickLook 棰勮鏈哄埗锛?);
    if (!ok) return;
    state.quickLook.lastInstallError = "";
    state.quickLook.pendingOpenPath = targetPath;
    state.quickLook.pendingOpenRow = selectedRow;
    if (pane) pane.innerHTML = "<div class=\"preview-loading\">姝ｅ湪涓嬭浇骞跺畨瑁?QuickLook鈥?/div>";
    postToAhk({ type: "INSTALL_QUICKLOOK" });
    updateQuickLookInstallUi();
    return;
  }

  if (pane) pane.innerHTML = "<div class=\"preview-loading\">姝ｅ湪璋冪敤 QuickLook鈥?/div>";
  postToAhk({ type: "QUICKLOOK", path: targetPath, row: selectedRow });
}

function onQuickLookOpenState(payload) {
  const pane = document.getElementById("preview-web-scroll");
  if (!pane) return;
  const status = payload && payload.status ? String(payload.status) : "";
  const msg = payload && payload.message ? String(payload.message) : "";
  const payloadPath = payload && payload.path ? String(payload.path).trim() : "";
  const currentPath = state.previewPath ? String(state.previewPath).trim() : "";
  if (payloadPath && currentPath && payloadPath !== currentPath) return;
  if (!msg) return;
  if (status === "fail") {
    pane.innerHTML = "<div class=\"preview-empty\">" + escapeHtml(msg) + "</div>";
    return;
  }
  if (status === "pending") {
    pane.innerHTML = "<div class=\"preview-loading\">" + escapeHtml(msg) + "</div>";
    return;
  }
  if (status === "ok") {
    pane.innerHTML = "<div class=\"preview-empty\">" + escapeHtml(msg) + "</div>";
  }
}

let previewHostRo = null;
function ensurePreviewHostObserver() {
  const host = document.getElementById("preview-host");
  if (!host || previewHostRo) return;
  previewHostRo = new ResizeObserver(() => {
    if (!state.previewPath) return;
    const ext = pathExtensionLower(state.previewPath);
    if (PREVIEW_TEXT_EXT.has(ext) || PREVIEW_IMAGE_EXT.has(ext)) return;
    
    // 濡傛灉 IPreviewHandler 婵€娲讳腑锛屽悓姝?Bounds
    if (state.iPreviewActive) {
      const b = collectPreviewBounds();
      postToAhk({ type: "NATIVE_PREVIEW", path: state.previewPath, seq: state.previewSeq, bounds: b });
    }
  });
  previewHostRo.observe(host);
}

function renderPreview() {
  ensurePreviewHostObserver();
  scheduleRunPreview();
}

function buildSkeletonListHtml(count) {
  let html = "<div class=\"skeleton-list\" aria-hidden=\"true\">";
  for (let i = 0; i < count; i += 1) {
    html += "<div class=\"skeleton-item\"><div><div class=\"sk-line w1\"></div><div class=\"sk-line w2\"></div><div class=\"sk-line w3\"></div></div><div class=\"sk-meta\"></div></div>";
  }
  html += "</div>";
  return html;
}

function syncRecycleBadge() {
  const badge = document.getElementById("recycle-badge");
  if (!badge) return;
  const n = Number(state.recycleCount) || 0;
  badge.textContent = String(n);
  badge.classList.toggle("muted", n < 1);
}

function renderRecycleModalList() {
  const list = document.getElementById("recycle-list");
  if (!list) return;
  const rows = state.recycleBin || [];
  if (!rows.length) {
    list.innerHTML = "<div class=\"empty\" style=\"min-height:100px\">鏆傛棤宸茬Щ闄ら」銆傚湪缁撴灉琛屼娇鐢ㄣ€屽洖鏀躲€嶅懡浠ゅ彲灏嗘潯鐩殏瀛樹簬姝ゃ€?/div>";
    return;
  }
  list.innerHTML = "";
  rows.forEach((it) => {
    const wrap = document.createElement("div");
    wrap.className = "recycle-row";
    const idx = Number(it.index) || 0;
    wrap.innerHTML =
      "<div><div class=\"t\">" + escapeHtml(it.title || "锛堟棤鏍囬锛?) + "</div>" +
      "<div class=\"p\">" + escapeHtml(it.preview || "") + "</div></div>";
    const btn = document.createElement("button");
    btn.type = "button";
    btn.className = "btn ghost";
    btn.textContent = "杩樺師";
    btn.onclick = () => postToAhk({ type: "searchCenterRestoreRecycle", index: idx });
    wrap.appendChild(btn);
    list.appendChild(wrap);
  });
}

function openRecycleModal() {
  const ov = document.getElementById("recycle-overlay");
  if (!ov) return;
  renderRecycleModalList();
  ov.classList.add("open");
  ov.setAttribute("aria-hidden", "false");
}

function closeRecycleModal() {
  const ov = document.getElementById("recycle-overlay");
  if (!ov) return;
  ov.classList.remove("open");
  ov.setAttribute("aria-hidden", "true");
}

function applyState(payload) {
  state.keyword = payload.keyword || "";
  state.limit = payload.limit || 50;
  state.categories = payload.categories || [];
  state.currentCategoryKey = payload.currentCategoryKey || "ai";
  state.engines = payload.engines || [];
  state.selectedEngines = payload.selectedEngines || [];
  state.filters = payload.filters || [];
  state.filterType = payload.filterType || "";
  if (payload.engineMode === "go" || payload.engineMode === "ahk") {
    state.engineMode = payload.engineMode;
    try {
      localStorage.setItem(SC_ENGINE_MODE_KEY, state.engineMode);
    } catch (e) {}
  }
  state.results = payload.results || [];
  state.hasMore = !!payload.hasMore;
  state.loading = false;
  state.isCliCategory = !!payload.isCliCategory;
  state.statusLine = payload.statusLine || "";
  state.recycleBin = Array.isArray(payload.recycleBin) ? payload.recycleBin : [];
  state.recycleCount = typeof payload.recycleCount === "number" ? payload.recycleCount : state.recycleBin.length;
  if (typeof payload.hostTopMost === "boolean") state.hostTopMost = payload.hostTopMost;

  if (payload.quickLook && typeof payload.quickLook === "object") {
    const q = payload.quickLook;
    state.quickLook = state.quickLook || {};
    if (typeof q.installed === "boolean") state.quickLook.installed = q.installed;
    if (q.path != null) state.quickLook.path = String(q.path);
    if (q.version != null) state.quickLook.version = String(q.version);
    if (typeof q.installBusy === "boolean") state.quickLook.installBusy = q.installBusy;
    updateQuickLookInstallUi();
    if (!isQuickLookInstalled() && state.pdfMode === "quicklook") {
      setPdfMode("auto");
    }
  }

  const wasSelected = state.selectedRow;
  if (!state.results.some((item) => item.row == wasSelected)) {
    state.selectedRow = state.results.length ? state.results[0].row : 1;
  }

  document.getElementById("search").value = state.keyword;
  document.getElementById("limit").value = String(state.limit);
  document.getElementById("status").textContent = state.statusLine || "宸插悓姝?;
  applyFulltextStatus(state.fulltext);
  document.getElementById("result-count").textContent = String(state.results.length) + " 鏉?;
  document.getElementById("btn-run").textContent = "鎼滅储";
  document.getElementById("btn-open-cli").style.display = state.isCliCategory ? "inline-flex" : "none";
  syncFooterHint();
  syncRecycleBadge();
  if (document.getElementById("recycle-overlay") && document.getElementById("recycle-overlay").classList.contains("open")) {
    renderRecycleModalList();
  }

  renderCategories();
  renderEngines();
  renderFilters();
  renderResults();
  syncEngineModeButton();
  updateChromeTopMostButton();
  requestAnimationFrame(() => {
    window.dispatchEvent(new Event("resize"));
  });
}

let searchDebounceTimer = 0;
const SEARCH_INPUT_DEBOUNCE_MS = 180;
function triggerSearch() {
  if (searchDebounceTimer) clearTimeout(searchDebounceTimer);
  searchDebounceTimer = setTimeout(() => {
    searchDebounceTimer = 0;
    if (state.engineMode === "go") {
      try {
        runSearchGoPipeline(0);
      } catch (e) {
        fallbackToAhkSearch();
      }
    } else {
      postToAhk({ type: "search", keyword: state.keyword });
    }
  }, SEARCH_INPUT_DEBOUNCE_MS);
}

function cancelPendingSearchDebounce() {
  if (searchDebounceTimer) {
    clearTimeout(searchDebounceTimer);
    searchDebounceTimer = 0;
  }
}

function runSearchNow() {
  const input = document.getElementById("search");
  const keyword = input ? String(input.value || "") : "";
  state.keyword = keyword;
  cancelPendingSearchDebounce();
  if (state.engineMode === "go") {
    try {
      runSearchGoPipeline(0);
    } catch (e) {
      fallbackToAhkSearch();
    }
  } else {
    postToAhk({ type: "search", keyword });
  }
}

let loadMoreObserver = null;
function disconnectLoadMoreObserver() {
  if (loadMoreObserver) {
    loadMoreObserver.disconnect();
    loadMoreObserver = null;
  }
}

function requestLoadMore() {
  if (!state.hasMore || state.loading) return;
  if (Date.now() < state.loadMoreCooldownUntil) return;
  state.loading = true;
  state.loadMoreCooldownUntil = Date.now() + 350;
  if (state.engineMode === "go") {
    try {
      runSearchGoPipeline(state.results.length);
    } catch (e) {
      postToAhk({ type: "loadMore", offset: state.results.length });
    }
    state.loading = false;
    return;
  }
  postToAhk({ type: "loadMore", offset: state.results.length });
}

function setupLoadMoreObserver() {
  const list = document.getElementById("result-list");
  const sent = document.getElementById("load-sentinel");
  if (!list || !sent || !state.hasMore) return;
  loadMoreObserver = new IntersectionObserver((entries) => {
    const e = entries[0];
    if (!e || !e.isIntersecting) return;
    requestLoadMore();
  }, { root: list, rootMargin: "0px 0px 320px 0px", threshold: 0 });
  loadMoreObserver.observe(sent);
}

let searchCompositionActive = false;
const searchInputEl = document.getElementById("search");
if (searchInputEl) {
  searchInputEl.addEventListener("compositionstart", () => {
    searchCompositionActive = true;
  });
  searchInputEl.addEventListener("compositionend", (event) => {
    searchCompositionActive = false;
    state.keyword = event.target.value;
    triggerSearch();
  });
  searchInputEl.addEventListener("input", (event) => {
    if (searchCompositionActive) return;
    state.keyword = event.target.value;
    triggerSearch();
  });
}

document.getElementById("limit").addEventListener("change", (event) => {
  postToAhk({ type: "setLimit", limit: Number(event.target.value) || 50 });
});

document.getElementById("btn-run").addEventListener("click", () => {
