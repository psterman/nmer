  });
}
const ftProbeBtn = document.getElementById("btn-ft-probe");
if (ftProbeBtn) {
  ftProbeBtn.addEventListener("click", () => {
    state.fulltextProbe.busy = true;
    setFulltextProbeSummary("姝ｅ湪妫€娴嬪彲琛屾€р€?);
    postToAhk({ type: "fulltextProbeRequest" });
  });
}
const ftRecommendBtn = document.getElementById("btn-ft-recommend");
if (ftRecommendBtn) {
