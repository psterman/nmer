    if (!state.recycleCount) return;
    if (!window.confirm("娓呯┖鎼滅储涓績鍥炴敹绔欙紵宸茬Щ闄ょ殑鏉＄洰灏嗘棤娉曚粠姝ゅ杩樺師銆?)) return;
    postToAhk({ type: "searchCenterEmptyRecycle" });
  });
}
const recycleOverlay = document.getElementById("recycle-overlay");
if (recycleOverlay) {
