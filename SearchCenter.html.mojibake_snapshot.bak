<script src="https://app.local/assets/vendor/prism/components/prism-clike.min.js"></script>
<script src="https://app.local/assets/vendor/prism/components/prism-markup-templating.min.js"></script>
<script src="https://app.local/assets/vendor/prism/components/prism-javascript.min.js"></script>
<script src="https://app.local/assets/vendor/prism/components/prism-python.min.js"></script>
