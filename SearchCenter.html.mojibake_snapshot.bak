  state.fulltextUiProbePrompted = true;
}

(function initChromeDrag() {
  const dragHost = document.getElementById("chrome-header");
  const dragTitle = document.getElementById("chrome-drag");
  const startHostDrag = (e) => {
    if (e.target && e.target.closest(".chrome-btn")) return;
    if (e.button !== 0) return;
    e.preventDefault();
    postToAhk({ type: "dragHost" });
  };
  const bindDragStart = (el) => {
    if (!el) return;
    if (window.PointerEvent) {
      el.addEventListener("pointerdown", startHostDrag);
    } else {
      el.addEventListener("mousedown", startHostDrag);
    }
  };
  bindDragStart(dragHost);
  if (dragTitle && dragTitle !== dragHost) bindDragStart(dragTitle);
})();

document.addEventListener("keydown", (event) => {
  if (event.key === "CapsLock") {
    beginCapsHoldHint();
  } else if (state.capsHintActive) {
    const pressed = normalizeHintKey(event.key);
    if (pressed) setCapsPressedKey(pressed);
  }

  const activeTag = document.activeElement ? document.activeElement.tagName : "";
  const isTyping = activeTag === "INPUT" || activeTag === "TEXTAREA" || activeTag === "SELECT";

  if (event.key === "Escape") {
    event.preventDefault();
    postToAhk({ type: "close" });
    return;
  }

  if (event.key === "Enter" && document.activeElement && document.activeElement.id === "search") {
    event.preventDefault();
    runSearchNow();
    return;
  }

  if (isTyping) return;

  if (event.key === " ") {
    event.preventDefault();
    if (state.previewPath) {
      scheduleRunPreview();
    }
    return;
  }

  if (event.key === "ArrowDown" && state.results.length) {
    event.preventDefault();
    const current = state.results.findIndex((item) => item.row === state.selectedRow);
    const next = Math.min(state.results.length - 1, Math.max(0, current + 1));
    state.selectedRow = state.results[next].row;
    renderResults();
  }

  if (event.key === "ArrowUp" && state.results.length) {
    event.preventDefault();
    const current = state.results.findIndex((item) => item.row === state.selectedRow);
    const next = Math.max(0, (current < 0 ? 0 : current) - 1);
    state.selectedRow = state.results[next].row;
    renderResults();
  }

  if (event.key === "Enter" && state.results.length) {
    event.preventDefault();
    postToAhk({ type: "activateResult", row: state.selectedRow });
  }
});

document.addEventListener("keyup", (event) => {
  if (event.key === "CapsLock") {
    endCapsHoldHint();
    return;
  }
  if (!state.capsHintActive) return;
  const released = normalizeHintKey(event.key);
  if (released && state.capsPressedKey === released) {
    state.capsPressedKey = "";
    updateHotkeyHighlights();
  }
});

window.addEventListener("resize", () => {
  scheduleRunPreview();
});

window.addEventListener("blur", () => {
  endCapsHoldHint();
});

document.addEventListener("visibilitychange", () => {
  if (document.hidden) endCapsHoldHint();
});

if (window.chrome && window.chrome.webview) {
  window.chrome.webview.addEventListener("message", (event) => {
    const payload = event.data;
    if (!payload || !payload.type) return;
    if (payload.type === "capsHint") {
      setCapsHintActive(!!payload.active);
      return;
    }
    if (payload.type === "capsHintPress") {
      flashCapsPressedKey(payload.key || "");
      return;
    }
    if (payload.type === "setCategory") {
      postToAhk({ type: "setCategory", category: payload.category || "" });
      return;
    }
    if (payload.type === "toggleEngine") {
      postToAhk({ type: "toggleEngine", engine: payload.engine || "" });
      return;
    }
    if (payload.type === "setFilter") {
      postToAhk({ type: "setFilter", filterType: payload.filterType || "" });
      return;
    }
    if (payload.type === "setLimit") {
      postToAhk({ type: "setLimit", limit: Number(payload.limit) || 50 });
      return;
    }
    if (payload.type === "activateResult") {
      postToAhk({ type: "activateResult", row: Number(payload.row) || state.selectedRow || 1 });
      return;
    }
    if (payload.type === "focus_input") {
      const input = document.getElementById("search");
      if (input) input.focus();
      return;
    }
    if (payload.type === "set_input") {
      const input = document.getElementById("search");
      if (input) {
        state.keyword = payload.keyword || "";
        input.value = state.keyword;
        input.focus();
        input.select();
      }
      return;
    }
    if (payload.type === "WEB_PREVIEW_TEXT_RESULT") {
      onWebPreviewTextResult(payload);
      return;
    }
    if (payload.type === "WEB_PREVIEW_IMAGE_RESULT") {
      onWebPreviewImageResult(payload);
      return;
    }
    if (payload.type === "WEB_PREVIEW_PDF_JS_BEGIN") {
      onWebPdfJsBegin(payload);
      return;
    }
    if (payload.type === "WEB_PREVIEW_PDF_JS_PART") {
      onWebPdfJsPart(payload);
      return;
    }
    if (payload.type === "WEB_PREVIEW_PDF_JS_ERROR") {
      onWebPdfJsError(payload);
      return;
    }
    if (payload.type === "WEB_PREVIEW_MEDIA_RESULT") {
      const pathForExt = (payload.path && String(payload.path).trim()) || state.previewPath || "";
      const ext = pathExtensionLower(pathForExt);
      if (ext === "pdf") {
        onPdfWebMediaResult(payload);
      } else if (PREVIEW_AUDIO_EXT.has(ext) || PREVIEW_VIDEO_EXT.has(ext)) {
        onWebPreviewMediaResult(payload);
      }
      return;
    }
    if (payload.type === "WEB_PREVIEW_PDFIUM_RESULT") {
      onWebPreviewPdfiumResult(payload);
      return;
    }
    if (payload.type === "WEB_PREVIEW_ARCHIVE_RESULT") {
      onWebPreviewArchiveResult(payload);
      return;
    }
    if (payload.type === "NATIVE_PREVIEW_FAILED") {
      onNativePreviewFailed(payload);
      return;
    }
    if (payload.type === "PREVIEW_META_UPDATE") {
      onPreviewMetaUpdate(payload);
      return;
    }
    if (payload.type === "MEDIA_INFO_RESULT") {
      onMediaInfoResult(payload);
      return;
    }
    if (payload.type === "MEDIA_FRAME_SAVE_RESULT") {
      onMediaFrameSaveResult(payload);
      return;
    }
    if (payload.type === "quicklook_open_state") {
      onQuickLookOpenState(payload);
      return;
    }
    if (payload.type === "requestSearchGo") {
      if (state.engineMode === "go" && (state.keyword || "").trim()) {
        try {
          runSearchGoPipeline(0);
        } catch (e) {
          fallbackToAhkSearch();
        }
      }
      return;
    }
    if (payload.type === "quicklook_install_progress") {
      state.quickLook = state.quickLook || {};
      state.quickLook.installBusy = true;
      state.quickLook.installProgressMsg = String(payload.message || "瀹夎涓€?);
      state.quickLook.installProgressPct = typeof payload.percent === "number" ? payload.percent : null;
      state.quickLook.lastInstallError = "";
      updateQuickLookInstallUi();
      return;
    }
    if (payload.type === "quicklook_install_state") {
      state.quickLook = state.quickLook || {};
      state.quickLook.installBusy = false;
      state.quickLook.installProgressMsg = "";
      state.quickLook.installProgressPct = null;
      if (payload.ok) {
        state.quickLook.installed = true;
        state.quickLook.lastInstallError = "";
        if (payload.path) state.quickLook.path = String(payload.path);
        const pendingPath = state.quickLook.pendingOpenPath ? String(state.quickLook.pendingOpenPath) : "";
        const pendingRow = Number(state.quickLook.pendingOpenRow) || 0;
        state.quickLook.pendingOpenPath = "";
        state.quickLook.pendingOpenRow = 0;
        if (pendingPath) {
          setTimeout(() => {
            invokeQuickLook(pendingPath);
          }, 80);
        } else if (pendingRow > 0) {
          setTimeout(() => {
            const item = state.results.find((entry) => entry.row == pendingRow);
            const p = getSelectedItemPath(item);
            if (p) invokeQuickLook(p);
          }, 80);
        }
      } else {
        state.quickLook.lastInstallError = String(payload.message || "瀹夎澶辫触");
        state.quickLook.pendingOpenPath = "";
        state.quickLook.pendingOpenRow = 0;
      }
      updateQuickLookInstallUi();
      if (!isQuickLookInstalled() && state.pdfMode === "quicklook") setPdfMode("auto");
      return;
    }
    if (payload.type === "fulltextStatus") {
      applyFulltextStatus(payload.payload || {});
      return;
    }
    if (payload.type === "fulltextActionResult") {
      if (!payload.ok) {
        const tip = payload.error ? String(payload.error) : "鍏ㄦ枃绱㈠紩鎿嶄綔澶辫触";
        document.getElementById("status").textContent = tip;
      }
      return;
    }
    if (payload.type === "fulltextConfigResult") {
      if (payload.ok) {
        setFulltextProbeSummary("鎵弿鏂规宸插簲鐢?);
      } else {
        setFulltextProbeSummary(payload.error ? String(payload.error) : "鎵弿鏂规鏇存柊澶辫触");
      }
      postToAhk({ type: "fulltextStatusRequest", withConfig: true });
      return;
    }
    if (payload.type === "fulltextProbeResult") {
      state.fulltextProbe.busy = false;
      if (payload.ok) {
        renderFulltextProbe(payload.probe || {});
      } else {
        setFulltextProbeSummary(payload.error ? String(payload.error) : "鍙鎬ф娴嬪け璐?);
      }
      return;
    }
    if (payload.type === "init" || payload.type === "state") {
      applyState(payload);
    }
  });
  postToAhk({ type: "ready" });
  requestFulltextStatus();
  startFulltextProgressStream();
}

(function initEngineModeButton() {
  const setMode = (mode) => {
    const next = mode === "ahk" ? "ahk" : "go";
    if (state.engineMode === next) return;
    state.engineMode = next;
    try {
      localStorage.setItem(SC_ENGINE_MODE_KEY, state.engineMode);
    } catch (e) {}
    syncEngineModeButton();
    postToAhk({ type: "setEngineMode", mode: state.engineMode });
    if (state.engineMode === "go") {
      try { runSearchGoPipeline(0); } catch (e) { fallbackToAhkSearch(); }
    } else {
      postToAhk({ type: "search", keyword: state.keyword });
    }
  };
  syncEngineModeButton();
  [
    "engine-mode-go", "engine-mode-ahk",
    "engine-mode-go-inline", "engine-mode-ahk-inline"
  ].forEach((id) => {
    const b = document.getElementById(id);
    if (!b) return;
    b.addEventListener("click", () => setMode(b.getAttribute("data-engine") || "go"));
  });
})();
</script>
</body>
</html>
