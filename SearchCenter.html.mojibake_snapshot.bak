<script src="https://app.local/assets/vendor/prism/components/prism-markdown.min.js"></script>
</head>
<body>
<div id="app">
    <header id="chrome-header" class="chrome-header window-titlebar">
    <div class="chrome-drag" id="chrome-drag" title="鎷栧姩绐楀彛">鎼滅储涓績</div>
    <div class="chrome-controls">
      <div class="engine-mode-group" role="group" aria-label="鎼滅储寮曟搸妯″紡">
        <button type="button" id="engine-mode-go" class="engine-mode-btn" data-engine="go" title="鏋侀€燂細Go SearchCenterCore">鏋侀€?路 Go</button>
        <button type="button" id="engine-mode-ahk" class="engine-mode-btn" data-engine="ahk" title="鏍囧噯锛欰HK 鏈湴寮曟搸">鏍囧噯 路 AHK</button>
      </div>
      <button type="button" id="btn-ft-settings-top" class="chrome-btn" title="鎼滅储璁剧疆"><span class="icon">鈿?/span><span>鎼滅储璁剧疆</span></button>
      <button type="button" id="chrome-topmost" class="chrome-btn" title="缃《绐楀彛">缃《</button>
    </div>
  </header>

  <div id="tag-card" class="card">
    <div id="categories"></div>
    <div id="engines">    </div>
  </div>

  <div id="search-bar" class="card">
    <span id="search-icon-inline">&#128269;</span>
    <div class="search-input-wrap">
      <input id="search" type="text" placeholder="鎼滅储鏈湴缁撴灉锛屾垨鐩存帴浣滀负缃戠粶鎼滅储 / CLI 鎻愮ず璇嶅彂閫?>
      <div id="status" class="search-status-inline">鍑嗗涓?..</div>
      <div id="fulltext-inline" class="fulltext-inline">
        <span class="ft-mini-light" id="ftl1"></span>
        <span class="ft-mini-light" id="ftl2"></span>
        <span class="ft-mini-light" id="ftl3"></span>
        <span class="ft-mini-light" id="ftl4"></span>
        <span id="ft-progress-text">FT 0.0%</span>
        <span id="ft-scan-badge" class="ft-scan-badge" style="display:none" title=""></span>
        <span id="ft-efficiency-text" class="ft-mini-file">0 鏂囦欢/绉?/span>
        <span id="ft-file" class="ft-mini-file">绌洪棽</span>
      </div>
      <div id="ft-scheme-panel" class="ft-scheme-panel">
        <button type="button" id="btn-ft-probe" class="mini-btn" title="妫€娴?MFT / Everything / USN 鍙鎬?>妫€娴嬪彲琛屾€?/button>
        <button type="button" id="btn-ft-recommend" class="mini-btn" title="鎸夋娴嬪缓璁嚜鍔ㄨ缃?>涓€閿帹鑽?/button>
        <button type="button" id="btn-ft-advanced-toggle" class="mini-btn" title="鏄剧ず楂樼骇閰嶇疆">楂樼骇璁剧疆</button>
        <div id="ft-advanced-wrap" class="ft-advanced-wrap hidden">
          <select id="ft-scheme-select" class="mini-select" title="鎵弿鏂规">
            <option value="auto">鎺ㄨ崘锛堣嚜鍔級</option>
            <option value="mft">楂樻€ц兘锛堜紭鍏?MFT锛?/option>
            <option value="everything">鍏煎浼樺厛锛圗verything锛?/option>
            <option value="walk">鐪佸績绋冲畾锛堜粎 Walk锛?/option>
          </select>
          <label class="mini-check" title="寮€鍚?USN 澧為噺璺熻釜">
            <input id="ft-usn-toggle" type="checkbox" checked>
            USN 澧為噺
          </label>
          <button type="button" id="btn-ft-scheme-apply" class="mini-btn" title="淇濆瓨骞堕噸鍚储寮?>搴旂敤鏂规</button>
        </div>
        <span id="ft-probe-summary" class="ft-probe-summary"></span>
      </div>
      <div id="ft-probe-list" class="ft-probe-list"></div>
    </div>
    <div class="search-actions">
      <div class="engine-mode-group" role="group" aria-label="鎼滅储寮曟搸妯″紡">
        <button type="button" id="engine-mode-go-inline" class="engine-mode-btn" data-engine="go" title="鏋侀€燂細Go SearchCenterCore">鏋侀€?路 Go</button>
        <button type="button" id="engine-mode-ahk-inline" class="engine-mode-btn" data-engine="ahk" title="鏍囧噯锛欰HK 鏈湴寮曟搸">鏍囧噯 路 AHK</button>
      </div>
      <select id="limit">
        <option value="10">10 鏉?/option>
          <option value="20">20 鏉?/option>
          <option value="30">30 鏉?/option>
          <option value="50">50 鏉?/option>
        <option value="100">100 鏉?/option>
        <option value="200">200 鏉?/option>
        <option value="500">鍏ㄩ儴鎼滅储缁撴灉</option>
      </select>
      <button id="btn-run" class="btn primary">鎼滅储</button>
      <button id="btn-web-search" class="btn">缃戦〉鎼滅储</button>
      <button id="btn-open-cli" class="btn">鎵撳紑鎵€閫夌粓绔?/button>
      <button id="btn-ft-toggle" class="btn" title="鍚姩鎴栧仠姝㈠叏鏂囩储寮?>鍚姩绱㈠紩</button>
    </div>
  </div>

  <div id="layout">
    <div id="results-card" class="card">
      <div id="results-head">
        <div>
          <div class="head-title">鏈湴缁撴灉</div>
        </div>
        <div id="head-filters"><div id="filters"></div></div>
        <div class="head-sub" id="result-count">0 鏉?/div>
      </div>
      <div id="result-list"></div>
    </div>
    <div id="preview-card" class="card">
      <div id="preview-head">
        <div style="width: 100%;">
          <div class="head-title">棰勮</div>
          <div id="preview-meta" class="preview-meta-grid">
             <div class="preview-empty-meta">鏈€変腑缁撴灉</div>
          </div>
        </div>
      </div>
      <div id="preview-panel">
        <div id="preview-main">
          <div id="preview-web-scroll">褰撳墠鏈€変腑鏈湴缁撴灉銆?
鍦ㄨ緭鍏ユ涓緭鍏ュ唴瀹瑰彲瀹炴椂杩囨护鏁版嵁锛岀偣鍑诲垪琛ㄩ」鍚庝細鍦ㄨ繖閲屾樉绀鸿缁嗛瑙堛€?/div>
          <div id="preview-host" aria-hidden="true"></div>
        </div>
        <div id="preview-ql-hint" class="hidden">
          <div class="ql-row">
            <span class="ql-text">鎸?<kbd>Space</kbd> 閲嶆柊鍔犺浇棰勮 路 閫夐」锛?/span>
            <div class="ql-btns">
              <button type="button" id="preview-pdf-mode-btn" class="preview-ctrl-btn" title="PDF 棰勮绛栫暐">PDF:auto</button>
              <button type="button" id="preview-native-btn" class="preview-ctrl-btn" title="璋冪敤绯荤粺鍘熺敓 IPreviewHandler">IPreview</button>
              <button type="button" id="preview-ql-btn" title="鍙€夛細璋冪敤渚挎惡鐗?QuickLook.exe">QuickLook</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div id="footer">
    <div class="footer-row-main">
      <span>Enter 鎵ц涓绘搷浣?路 Esc 鍏抽棴 路 鍙屽嚮缁撴灉绔嬪嵆澶勭悊</span>
      <div class="footer-inline-btns">
        <button type="button" id="btn-sc-recycle" class="btn ghost">鎼滅储鍥炴敹绔?span class="recycle-badge muted" id="recycle-badge">0</span></button>
        <button type="button" id="btn-win-recycle-sc" class="btn ghost">绯荤粺鍥炴敹绔?/button>
      </div>
    </div>
    <div id="footer-hint">WebView2 妯″紡</div>
  </div>

  <div id="recycle-overlay" class="recycle-overlay" aria-hidden="true">
    <div class="recycle-dialog card" role="dialog" aria-modal="true" aria-labelledby="recycle-dlg-title">
      <div class="recycle-dialog-head">
        <span id="recycle-dlg-title">鎼滅储涓績鍥炴敹绔?/span>
        <button type="button" id="recycle-close" class="chrome-btn" title="鍏抽棴">脳</button>
      </div>
      <div id="recycle-list" class="recycle-list"></div>
      <div class="recycle-dialog-foot">
        <button type="button" id="recycle-empty-all" class="btn">鍏ㄩ儴娓呯┖</button>
      </div>
    </div>
  </div>
</div>

<script>
if (typeof BasePanel === 'undefined') {
  window.BasePanel = {
    PROTO_VERSION: 1,
    postToAhk(obj) {
      if (!window.chrome || !window.chrome.webview) return;
      const src = (obj && typeof obj === 'object' && !Array.isArray(obj)) ? obj : {};
      const p = Object.assign({ v: 1, timestamp: Date.now() }, src);
      if (p.action === undefined && p.type !== undefined) p.action = p.type;
      window.chrome.webview.postMessage(p);
    }
  };
}
const SC_ENGINE_MODE_KEY = "sc_engine_mode";
const SC_FT_ADVANCED_KEY = "sc_ft_advanced_ui_v1";
/** 涓?SearchCenterCore HTTP 鐩戝惉涓€鑷达紱EventSource 鐩磋繛杩涘害娴侊紙澶辫触鏃跺洖閫€ AHK 杞锛?*/
const SEARCH_CORE_ORIGIN = "http://127.0.0.1:8080";
let fulltextProgressES = null;
let fulltextPollTimer = 0;
let fulltextEsBackoffMs = 2000;
let fulltextEsReconnectTimer = 0;

const state = {
  keyword: "",
  limit: 30,
  engineMode: (typeof localStorage !== "undefined" && localStorage.getItem(SC_ENGINE_MODE_KEY)) || "go",
  categories: [],
  currentCategoryKey: "ai",
  engines: [],
  selectedEngines: [],
  filters: [],
  filterType: "",
  results: [],
  hasMore: false,
