Clipboard.db
CursorData.db
CursorHelper.db

# 用户数据目录（含 CursorData.db、截图缓存等）
Data/

# 本地配置（每人不同，不宜进仓库）
CursorShortcut.ini
PromptTemplates.ini

# 调试日志（根目录）
clipboard_debug.log

